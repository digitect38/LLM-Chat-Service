{
  "Urls": "http://0.0.0.0:5003",
  "Nats": {
    "Url": "nats://localhost:4222"
  },
  "Ollama": {
    "BaseUrl": "http://localhost:11434",
    "ChatModel": "exaone3.5:7.8b",
    "EmbeddingModel": "nomic-embed-text"
  },
  "Qdrant": {
    "Host": "localhost",
    "GrpcPort": 6334,
    "HttpPort": 6333,
    "DefaultCollection": "knowledge",
    "VectorSize": 768
  },
  "Redis": {
    "ConnectionString": "localhost:6379",
    "DefaultDatabase": 0,
    "KeyPrefix": "fab:"
  },
  "Rag": {
    "MinScore": 0.45,
    "DefaultTopK": 3,
    "WatchFolder": "knowledge-docs",
    "DebounceMs": 500,
    "ScanOnStartup": true,
    "EnableQueryRewriting": true,
    "EnableLlmReranking": true,
    "LlmRerankCandidateCount": 20,
    "EnableGraphLookup": false,
    "GraphMaxDepth": 2,
    "ExtractEntitiesOnIngest": false,
    "DefaultMaxAgenticIterations": 3,
    "EnableBm25": true,
    "Bm25K1": 1.2,
    "Bm25B": 0.75,
    "EnableHybridSearch": true,
    "VectorWeight": 1.0,
    "Bm25Weight": 1.0,
    "EnableMmr": true,
    "MmrLambda": 0.7,
    "EnableRagCache": true,
    "RagCacheTtlHours": 24,
    "DefaultPipelineMode": "Naive"
  },
  "Observability": {
    "ServiceName": "fab-copilot-rag-service",
    "EnableTracing": true,
    "EnableMetrics": true,
    "LogFilePath": "logs/rag-service-.log"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  }
}
