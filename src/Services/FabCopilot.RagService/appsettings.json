{
  "Nats": {
    "Url": "nats://localhost:4222"
  },
  "Ollama": {
    "BaseUrl": "http://localhost:11434",
    "ChatModel": "llama3.1:8b",
    "EmbeddingModel": "nomic-embed-text"
  },
  "Qdrant": {
    "Host": "localhost",
    "GrpcPort": 6334,
    "HttpPort": 6333,
    "DefaultCollection": "knowledge",
    "VectorSize": 768
  },
  "Rag": {
    "MinScore": 0.3,
    "DefaultTopK": 5,
    "WatchFolder": "knowledge-docs",
    "DebounceMs": 500,
    "ScanOnStartup": true
  },
  "Observability": {
    "ServiceName": "fab-copilot-rag-service",
    "EnableTracing": true,
    "EnableMetrics": true,
    "LogFilePath": "logs/rag-service-.log"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  }
}
