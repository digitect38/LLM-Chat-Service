@using Microsoft.AspNetCore.Components.Web
@namespace FabCopilot.WebClient.Pages
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <base href="~/" />
    <link href="css/app.css" rel="stylesheet" asp-append-version="true" />
    <link href="FabCopilot.WebClient.styles.css" rel="stylesheet" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/highlightjs/cdn-release@11.9.0/build/styles/vs2015.min.css" />
    <title>Fab Copilot</title>
    <component type="typeof(HeadOutlet)" render-mode="ServerPrerendered" />
</head>
<body>
    @RenderBody()

    <div id="blazor-error-ui">
        <environment include="Staging,Production">
            An error has occurred. This application may no longer respond until reloaded.
        </environment>
        <environment include="Development">
            An unhandled exception has occurred. See browser dev tools for details.
        </environment>
        <a href="" class="reload">Reload</a>
        <a class="dismiss">X</a>
    </div>

    <script src="_framework/blazor.server.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/marked@12.0.2/marked.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.js"></script>
    <script src="https://cdn.jsdelivr.net/gh/highlightjs/cdn-release@11.9.0/build/highlight.min.js"></script>
    <script src="https://cdn.jsdelivr.net/gh/highlightjs/cdn-release@11.9.0/build/languages/erlang.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js"></script>
    <script>
        // ─── Scroll ───────────────────────────────────────────────
        window.chatScroll = {
            scrollToBottom: function (elementId) {
                var el = document.getElementById(elementId);
                if (el) el.scrollTop = el.scrollHeight;
            }
        };

        // ─── Input auto-resize ────────────────────────────────────
        window.chatInput = {
            autoResize: function (elementId) {
                var el = document.getElementById(elementId);
                if (!el) return;
                el.style.height = 'auto';
                el.style.height = Math.min(el.scrollHeight, 200) + 'px';
            },
            resetHeight: function (elementId) {
                var el = document.getElementById(elementId);
                if (el) el.style.height = 'auto';
            }
        };

        // ─── Clipboard ───────────────────────────────────────────
        window.clipboard = {
            copyText: async function (text) {
                try {
                    await navigator.clipboard.writeText(text);
                    return true;
                } catch {
                    // Fallback for older browsers or insecure contexts
                    var ta = document.createElement('textarea');
                    ta.value = text;
                    ta.style.position = 'fixed';
                    ta.style.opacity = '0';
                    document.body.appendChild(ta);
                    ta.select();
                    document.execCommand('copy');
                    document.body.removeChild(ta);
                    return true;
                }
            }
        };

        // ─── Markdown + KaTeX renderer ────────────────────────────
        window.chatRenderer = {
            renderMarkdown: function (text) {
                if (!text) return '';

                // Guard: check libraries loaded
                if (typeof marked === 'undefined' || typeof marked.parse !== 'function') {
                    console.error('[chatRenderer] marked.js not loaded');
                    return text;
                }
                if (typeof katex === 'undefined' || typeof katex.renderToString !== 'function') {
                    console.error('[chatRenderer] katex.js not loaded');
                    return marked.parse(text);
                }

                try {
                    return this._render(text);
                } catch (e) {
                    console.error('[chatRenderer] render failed:', e);
                    return text;
                }
            },

            _render: function (text) {
                var blockMath = [];
                var inlineMath = [];

                // 1. Extract block math delimiters FIRST: $$...$$ and \[...\]
                //    (must come before \begin{env} to avoid double-capture of matrices)
                text = text.replace(/\$\$([\s\S]*?)\$\$/g, function (m, f) {
                    blockMath.push(f.trim());
                    return '%%BLOCKMATH' + (blockMath.length - 1) + '%%';
                });
                text = text.replace(/\\\[([\s\S]*?)\\\]/g, function (m, f) {
                    blockMath.push(f.trim());
                    return '%%BLOCKMATH' + (blockMath.length - 1) + '%%';
                });

                // 2. Extract standalone \begin{env}...\end{env} not already captured
                text = text.replace(/\\begin\{(equation|align|aligned|gather|gathered|multline|cases|bmatrix|pmatrix|vmatrix|Bmatrix|Vmatrix|smallmatrix|matrix|array)\*?\}([\s\S]*?)\\end\{\1\*?\}/g, function (m) {
                    blockMath.push(m);
                    return '%%BLOCKMATH' + (blockMath.length - 1) + '%%';
                });

                // 3. Extract inline math: \(...\) first, then $...$
                text = text.replace(/\\\(([\s\S]*?)\\\)/g, function (m, f) {
                    inlineMath.push(f.trim());
                    return '%%INLINEMATH' + (inlineMath.length - 1) + '%%';
                });
                text = text.replace(/\$([^\$\n]+?)\$/g, function (m, f) {
                    inlineMath.push(f.trim());
                    return '%%INLINEMATH' + (inlineMath.length - 1) + '%%';
                });

                // 3c. Cleanup orphaned delimiters (truncated responses)
                text = text.replace(/\\\[([\s\S]+)$/g, function (m, f) {
                    blockMath.push(f.trim());
                    return '%%BLOCKMATH' + (blockMath.length - 1) + '%%';
                });
                text = text.replace(/\\\(([\s\S]+)$/g, function (m, f) {
                    inlineMath.push(f.trim());
                    return '%%INLINEMATH' + (inlineMath.length - 1) + '%%';
                });

                // 3. Render markdown
                var html = marked.parse(text);

                // 3b. Syntax highlighting for code blocks
                if (typeof hljs !== 'undefined') {
                    var tempDiv = document.createElement('div');
                    tempDiv.innerHTML = html;
                    tempDiv.querySelectorAll('pre code').forEach(function (block) {
                        var lang = (block.className.match(/language-(\w+)/) || [, ''])[1];
                        var code = block.textContent;
                        try {
                            var result;
                            if (lang && hljs.getLanguage(lang)) {
                                result = hljs.highlight(code, { language: lang });
                            } else {
                                result = hljs.highlightAuto(code);
                            }
                            block.innerHTML = result.value;
                            block.classList.add('hljs');
                        } catch (e) {}
                    });
                    html = tempDiv.innerHTML;
                }

                // 4. Restore block math (use <span> to avoid breaking <li>/<p> structure)
                html = html.replace(/%%BLOCKMATH(\d+)%%/g, function (m, i) {
                    try {
                        return '<span class="katex-block">' +
                            katex.renderToString(blockMath[parseInt(i)], { displayMode: true, throwOnError: false }) +
                            '</span>';
                    } catch (e) {
                        console.warn('[chatRenderer] block math error:', e.message);
                        return '<span class="katex-block katex-error">' + blockMath[parseInt(i)] + '</span>';
                    }
                });

                // 5. Restore inline math
                html = html.replace(/%%INLINEMATH(\d+)%%/g, function (m, i) {
                    try {
                        return '<span class="katex-inline">' +
                            katex.renderToString(inlineMath[parseInt(i)], { displayMode: false, throwOnError: false }) +
                            '</span>';
                    } catch (e) {
                        console.warn('[chatRenderer] inline math error:', e.message);
                        return '<span class="katex-error">' + inlineMath[parseInt(i)] + '</span>';
                    }
                });

                // Post-process: convert [Page XX] references into clickable links
                html = html.replace(/\[Page\s+(\d+(?:\s*,\s*\d+)*)\]/g, function (match, pages) {
                    var pageNums = pages.split(/\s*,\s*/);
                    var links = pageNums.map(function (p) {
                        return '<a class="citation-page-link" data-page="' + p.trim() + '" onclick="citationInterop.onPageLinkClick(' + p.trim() + '); return false;" href="#">Page ' + p.trim() + '</a>';
                    });
                    return '[' + links.join(', ') + ']';
                });

                return html;
            },

            // Lite renderer: markdown + hljs only, KaTeX skipped (for JIT streaming)
            renderMarkdownLite: function (text) {
                if (!text) return '';
                if (typeof marked === 'undefined' || typeof marked.parse !== 'function') return text;
                try {
                    var mathBlocks = [];
                    // Protect $$...$$
                    text = text.replace(/\$\$([\s\S]*?)\$\$/g, function (m) {
                        mathBlocks.push(m); return '%%MATHBLOCK' + (mathBlocks.length - 1) + '%%';
                    });
                    // Protect \[...\]
                    text = text.replace(/\\\[([\s\S]*?)\\\]/g, function (m) {
                        mathBlocks.push(m); return '%%MATHBLOCK' + (mathBlocks.length - 1) + '%%';
                    });
                    // Protect \begin{env}...\end{env}
                    text = text.replace(/\\begin\{[^}]+\}[\s\S]*?\\end\{[^}]+\}/g, function (m) {
                        mathBlocks.push(m); return '%%MATHBLOCK' + (mathBlocks.length - 1) + '%%';
                    });
                    // Protect \(...\)
                    text = text.replace(/\\\(([\s\S]*?)\\\)/g, function (m) {
                        mathBlocks.push(m); return '%%MATHBLOCK' + (mathBlocks.length - 1) + '%%';
                    });
                    // Protect $...$
                    text = text.replace(/\$([^\$\n]+?)\$/g, function (m) {
                        mathBlocks.push(m); return '%%MATHBLOCK' + (mathBlocks.length - 1) + '%%';
                    });
                    // Protect unclosed math (streaming truncation)
                    text = text.replace(/(\$\$|\\\[)[\s\S]*$/g, function (m) {
                        mathBlocks.push(m); return '%%MATHBLOCK' + (mathBlocks.length - 1) + '%%';
                    });

                    var html = marked.parse(text);

                    // Syntax highlighting
                    if (typeof hljs !== 'undefined') {
                        var tmp = document.createElement('div');
                        tmp.innerHTML = html;
                        tmp.querySelectorAll('pre code').forEach(function (block) {
                            var lang = (block.className.match(/language-(\w+)/) || [, ''])[1];
                            try {
                                var r = lang && hljs.getLanguage(lang)
                                    ? hljs.highlight(block.textContent, { language: lang })
                                    : hljs.highlightAuto(block.textContent);
                                block.innerHTML = r.value;
                                block.classList.add('hljs');
                            } catch (e) {}
                        });
                        html = tmp.innerHTML;
                    }

                    // Restore math as styled raw text
                    html = html.replace(/%%MATHBLOCK(\d+)%%/g, function (m, i) {
                        var orig = mathBlocks[parseInt(i)];
                        return '<span class="math-pending">' +
                            orig.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;') +
                            '</span>';
                    });

                    return html;
                } catch (e) { return text; }
            }
        };

        // ─── Citation interop (Blazor ↔ JS) ───────────────────────────
        window.citationInterop = {
            _dotNetRef: null,
            init: function (dotNetRef) {
                this._dotNetRef = dotNetRef;
            },
            onPageLinkClick: function (page) {
                if (this._dotNetRef) {
                    this._dotNetRef.invokeMethodAsync('OnCitationPageClick', page);
                }
            },
            dispose: function () {
                this._dotNetRef = null;
            }
        };

        // ─── pdf.js viewer interop ──────────────────────────────────
        window.pdfViewer = {
            _doc: null,
            _pageCount: 0,

            load: async function (url) {
                if (typeof pdfjsLib === 'undefined') {
                    console.error('pdf.js not loaded');
                    return 0;
                }
                pdfjsLib.GlobalWorkerOptions.workerSrc =
                    'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';
                try {
                    this._doc = await pdfjsLib.getDocument(url).promise;
                    this._pageCount = this._doc.numPages;
                    return this._pageCount;
                } catch (e) {
                    console.error('PDF load failed:', e);
                    return 0;
                }
            },

            renderPage: async function (canvasId, pageNum, scale) {
                if (!this._doc) return false;
                try {
                    var page = await this._doc.getPage(pageNum);
                    var viewport = page.getViewport({ scale: scale || 1.0 });
                    var canvas = document.getElementById(canvasId);
                    if (!canvas) return false;
                    var ctx = canvas.getContext('2d');
                    canvas.width = viewport.width;
                    canvas.height = viewport.height;
                    await page.render({ canvasContext: ctx, viewport: viewport }).promise;
                    return true;
                } catch (e) {
                    console.error('PDF render failed:', e);
                    return false;
                }
            },

            getPageCount: function () {
                return this._pageCount;
            },

            highlightText: async function (canvasId, overlayId, charStart, charEnd, scale) {
                if (!this._doc) return false;
                var overlay = document.getElementById(overlayId);
                var canvas = document.getElementById(canvasId);
                if (!overlay || !canvas) return false;
                overlay.innerHTML = '';

                var pageNum = parseInt(canvas.dataset.pageNum || '1');
                var highlighted = false;
                try {
                    var page = await this._doc.getPage(pageNum);
                    var viewport = page.getViewport({ scale: scale || 1.0 });
                    var textContent = await page.getTextContent();

                    var currentOffset = 0;
                    for (var i = 0; i < textContent.items.length; i++) {
                        var item = textContent.items[i];
                        if (!item.str) continue;
                        var itemStart = currentOffset;
                        var itemEnd = currentOffset + item.str.length;

                        if (itemEnd > charStart && itemStart < charEnd) {
                            var tx = pdfjsLib.Util.transform(viewport.transform, item.transform);
                            var rect = document.createElement('div');
                            rect.className = 'highlight-rect';
                            rect.style.left = tx[4] + 'px';
                            rect.style.top = (canvas.height - tx[5] - item.height * (scale || 1.0)) + 'px';
                            rect.style.width = item.width * (scale || 1.0) + 'px';
                            rect.style.height = item.height * (scale || 1.0) + 'px';
                            overlay.appendChild(rect);
                            highlighted = true;
                        }
                        currentOffset = itemEnd;
                    }
                } catch (e) {
                    console.error('Highlight failed:', e);
                }
                return highlighted;
            },

            showFallbackHighlight: function (overlayId, canvasWidth, canvasHeight) {
                var overlay = document.getElementById(overlayId);
                if (!overlay) return;
                overlay.innerHTML = '';
                var fallback = document.createElement('div');
                fallback.className = 'highlight-fallback-overlay';
                fallback.style.width = canvasWidth + 'px';
                fallback.style.height = canvasHeight + 'px';
                var text = document.createElement('span');
                text.className = 'highlight-fallback-text';
                text.textContent = '정확한 위치를 표시할 수 없습니다';
                fallback.appendChild(text);
                overlay.appendChild(fallback);
            }
        };

        // ─── Client Settings (localStorage) ─────────────────────────
        window.clientSettings = {
            getCodeFont: function() {
                return localStorage.getItem('fab-code-font') || 'Cascadia Code';
            },
            setCodeFont: function(font) {
                localStorage.setItem('fab-code-font', font);
                document.documentElement.style.setProperty('--code-font',
                    "'" + font + "', 'Fira Code', 'Consolas', monospace");
            },
            getSttEngine: function() {
                return localStorage.getItem('sttEngine') || 'auto';
            },
            setSttEngine: function(v) {
                localStorage.setItem('sttEngine', v);
                if (window.audioRecorder) window.audioRecorder.setEngine(v);
            },
            getRenderMode: function() {
                var v = localStorage.getItem('renderMode');
                // Migrate old values
                if (v === 'stream') { localStorage.setItem('renderMode', 'jit'); return 'jit'; }
                return v || 'jit';
            },
            setRenderMode: function(v) {
                localStorage.setItem('renderMode', v);
            },
            getTimeoutBudget: function() {
                return localStorage.getItem('timeoutBudget') || '180';
            },
            setTimeoutBudget: function(v) {
                localStorage.setItem('timeoutBudget', v);
            },
            init: function() {
                this.setCodeFont(this.getCodeFont());
            }
        };
        window.clientSettings.init();

        // ─── TTS (Text-to-Speech) ────────────────────────────────────────
        // ─── TTS Debug overlay (visible on screen for mobile debugging) ───
        window._ttsDebug = {
            _el: null,
            _lines: [],
            log: function(msg) {
                console.log('[TTS] ' + msg);
                this._lines.push(new Date().toLocaleTimeString() + ' ' + msg);
                if (this._lines.length > 12) this._lines.shift();
                if (!this._el) {
                    this._el = document.createElement('div');
                    this._el.id = 'tts-debug';
                    this._el.style.cssText = 'position:fixed;bottom:0;left:0;right:0;background:rgba(0,0,0,0.85);color:#0f0;font:11px/1.4 monospace;padding:8px;z-index:99999;max-height:40vh;overflow-y:auto;pointer-events:auto;';
                    this._el.onclick = function() { window._ttsDebug._el.style.display = 'none'; };
                    document.body.appendChild(this._el);
                }
                this._el.style.display = 'block';
                this._el.innerText = this._lines.join('\n');
                this._el.scrollTop = this._el.scrollHeight;
            }
        };

        window.fabTts = {
            _dotNetRef: null,
            _audioCtx: null,
            _sourceNode: null,
            _gainNode: null,
            _playing: false,
            _utterance: null,
            _voicesReady: false,

            _getGatewayUrl: function() {
                // Use same origin — WebClient proxies TTS/STT to ChatGateway
                return window.location.origin;
            },

            _ensureCtx: function() {
                if (!this._audioCtx) {
                    this._audioCtx = new (window.AudioContext || window.webkitAudioContext)();
                    this._gainNode = this._audioCtx.createGain();
                    this._gainNode.gain.value = 1.0;
                    this._gainNode.connect(this._audioCtx.destination);
                }
                return this._audioCtx;
            },

            unlockAudio: function() {
                var D = window._ttsDebug;
                try {
                    // 1) Unlock Web Audio
                    var ctx = this._ensureCtx();
                    if (ctx.state === 'suspended') ctx.resume();
                    var buf = ctx.createBuffer(1, 1, 22050);
                    var src = ctx.createBufferSource();
                    src.buffer = buf;
                    src.connect(this._gainNode);
                    src.start(0);

                    // 2) Prime SpeechSynthesis in user gesture context (iOS REQUIRES this)
                    if (window.speechSynthesis) {
                        window.speechSynthesis.cancel();
                        var primer = new SpeechSynthesisUtterance('\u200B');  // zero-width space
                        primer.volume = 0.01;
                        primer.rate = 10;
                        primer.lang = 'ko-KR';
                        window.speechSynthesis.speak(primer);
                        this._ssPrimed = true;
                        D.log('unlock: ctx=' + ctx.state + ' SS primed');
                    } else {
                        D.log('unlock: ctx=' + ctx.state + ' no SS');
                    }

                    // 3) Pre-load voices
                    if (window.speechSynthesis && !this._voicesReady) {
                        window.speechSynthesis.getVoices();
                        var self = this;
                        window.speechSynthesis.onvoiceschanged = function() {
                            self._voicesReady = true;
                            D.log('voices loaded: ' + window.speechSynthesis.getVoices().length);
                        };
                    }
                } catch(e) {
                    D.log('unlock FAIL: ' + e.message);
                }
            },

            play: async function(gatewayBaseIgnored, text, dotNetRef) {
                this._dotNetRef = dotNetRef;
                this.stop();
                this._playing = true;
                var gatewayBase = this._getGatewayUrl();
                var D = window._ttsDebug;
                D.log('play: ' + text.length + ' chars, primed=' + !!this._ssPrimed);

                // ── Step 1: Try XTTS via Web Audio (with 5s timeout) ──
                var xttsOk = false;
                try {
                    var ctx = this._ensureCtx();
                    if (ctx.state === 'suspended') {
                        await ctx.resume();
                        await new Promise(function(r) { setTimeout(r, 100); });
                    }
                    D.log('1. ctx=' + ctx.state);

                    if (ctx.state !== 'running') {
                        throw new Error('ctx ' + ctx.state);
                    }

                    D.log('2. fetching XTTS...');
                    var ac = new AbortController();
                    var timer = setTimeout(function() { ac.abort(); }, 30000);
                    var resp = await fetch(gatewayBase + '/api/tts/synthesize', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ text: text, language: 'ko' }),
                        signal: ac.signal
                    });
                    clearTimeout(timer);
                    if (!resp.ok) {
                        var errText = '';
                        try { errText = await resp.text(); } catch(e2) {}
                        D.log('3. HTTP ' + resp.status + ': ' + errText.substring(0, 200));
                        throw new Error('HTTP ' + resp.status);
                    }
                    D.log('3. HTTP 200');

                    var arrayBuf = await resp.arrayBuffer();
                    D.log('4. got ' + arrayBuf.byteLength + ' bytes');
                    if (!this._playing || arrayBuf.byteLength < 100) throw new Error('empty');

                    var audioBuf = await ctx.decodeAudioData(arrayBuf);
                    D.log('5. decoded ' + audioBuf.duration.toFixed(1) + 's ' + audioBuf.sampleRate + 'Hz');
                    if (!this._playing) return;

                    var source = ctx.createBufferSource();
                    source.buffer = audioBuf;
                    source.connect(this._gainNode);
                    this._sourceNode = source;

                    var self = this;
                    source.onended = function() {
                        D.log('6. XTTS ended');
                        self._sourceNode = null;
                        self._playing = false;
                        if (dotNetRef) dotNetRef.invokeMethodAsync('OnTtsEnded');
                    };
                    source.start(0);
                    xttsOk = true;
                    D.log('6. XTTS PLAYING ✓ gain=' + this._gainNode.gain.value);
                } catch(ex) {
                    D.log('XTTS FAIL: ' + ex.message);
                }

                // ── Step 2: Fallback to SpeechSynthesis ──
                if (!xttsOk && this._playing) {
                    D.log('→ SpeechSynthesis fallback');
                    this._playSpeechSynthesis(text, dotNetRef);
                }
            },

            _playSpeechSynthesis: function(text, dotNetRef) {
                var D = window._ttsDebug;
                if (!window.speechSynthesis) {
                    D.log('SS: not available!');
                    this._playing = false;
                    if (dotNetRef) dotNetRef.invokeMethodAsync('OnTtsError', 'TTS 불가');
                    return;
                }

                window.speechSynthesis.cancel();

                var spText = text.length > 3000 ? text.substring(0, 3000) + '...' : text;
                var utt = new SpeechSynthesisUtterance(spText);
                utt.lang = 'ko-KR';
                utt.rate = 1.05;
                utt.volume = 1.0;
                utt.pitch = 1.0;

                var voices = window.speechSynthesis.getVoices();
                D.log('SS: voices=' + voices.length);
                if (voices.length > 0) {
                    var koVoice = voices.find(function(v) { return v.lang && v.lang.startsWith('ko'); });
                    if (koVoice) {
                        utt.voice = koVoice;
                        D.log('SS: voice=' + koVoice.name + ' ' + koVoice.lang);
                    } else {
                        utt.voice = voices[0];
                        D.log('SS: no ko, using ' + voices[0].name);
                    }
                } else {
                    D.log('SS: no voices! default lang');
                }

                var self = this;
                utt.onstart = function() { D.log('SS: started'); };
                utt.onend = function() {
                    D.log('SS: ended');
                    self._playing = false;
                    if (self._synthResumeTimer) { clearInterval(self._synthResumeTimer); self._synthResumeTimer = null; }
                    if (dotNetRef) dotNetRef.invokeMethodAsync('OnTtsEnded');
                };
                utt.onerror = function(e) {
                    D.log('SS: ERROR ' + (e.error || 'unknown'));
                    self._playing = false;
                    if (self._synthResumeTimer) { clearInterval(self._synthResumeTimer); self._synthResumeTimer = null; }
                    if (dotNetRef) dotNetRef.invokeMethodAsync('OnTtsError', e.error || 'TTS 오류');
                };

                this._utterance = utt;
                window.speechSynthesis.speak(utt);
                D.log('SS: speak() speaking=' + window.speechSynthesis.speaking);

                // iOS bug: speechSynthesis pauses after ~15s. Keep poking it.
                this._synthResumeTimer = setInterval(function() {
                    if (!self._playing) {
                        clearInterval(self._synthResumeTimer);
                        return;
                    }
                    if (window.speechSynthesis.paused) {
                        window.speechSynthesis.resume();
                    }
                }, 5000);

                console.log('[TTS] SpeechSynthesis started, text:', spText.length, 'chars');
            },

            stop: function() {
                this._playing = false;
                if (this._sourceNode) {
                    try { this._sourceNode.stop(); } catch(e) {}
                    this._sourceNode = null;
                }
                if (window.speechSynthesis) {
                    window.speechSynthesis.cancel();
                }
                if (this._synthResumeTimer) {
                    clearInterval(this._synthResumeTimer);
                    this._synthResumeTimer = null;
                }
                this._utterance = null;
            }
        };

        // ─── Auto-unlock AudioContext on first user gesture (iOS requirement) ───
        // iOS WebKit requires AudioContext.resume() within a direct touch/click handler.
        // Blazor Server's SignalR round-trip loses the user gesture context,
        // so we hook the FIRST touch/click at document level to pre-unlock.
        (function() {
            var unlocked = false;
            function autoUnlock() {
                if (unlocked) return;
                unlocked = true;
                document.removeEventListener('touchstart', autoUnlock, true);
                document.removeEventListener('touchend', autoUnlock, true);
                document.removeEventListener('click', autoUnlock, true);
                if (window.fabTts) {
                    window.fabTts.unlockAudio();
                    console.log('[TTS] Auto-unlocked AudioContext on first user gesture');
                }
            }
            document.addEventListener('touchstart', autoUnlock, true);
            document.addEventListener('touchend', autoUnlock, true);
            document.addEventListener('click', autoUnlock, true);
        })();

        // ─── Audio Recorder (STT) — Dual Engine ─────────────────────────
        window.audioRecorder = {
            _mediaRecorder: null,
            _chunks: [],
            _dotNetRef: null,
            _gatewayUrl: '',
            _equipmentId: 'default',
            _engine: 'whisper',           // 'whisper' | 'webspeech'
            _engineSetting: 'auto',       // 'auto' | 'whisper' | 'webspeech'
            _recognition: null,           // SpeechRecognition instance
            _startTime: null,
            _timerInterval: null,
            _disabled: false,

            // Domain prompt biasing terms for CMP equipment
            _domainPrompts: {
                'default': 'CMP polishing pad slurry MRR wafer removal rate planarization',
                'cmp': 'CMP chemical mechanical polishing pad conditioner slurry MRR removal rate WIWNU planarization endpoint detection retaining ring carrier head platen',
                'etch': 'etch plasma RF chamber selectivity etch rate uniformity endpoint polymer residue',
                'cvd': 'CVD deposition film thickness uniformity precursor chamber temperature pressure'
            },

            init: async function(dotNetRef, equipmentId) {
                this._dotNetRef = dotNetRef;
                // Use same origin — WebClient proxies TTS/STT to ChatGateway
                this._gatewayUrl = window.location.origin;
                this._equipmentId = equipmentId || 'default';

                // Load saved engine preference
                this._engineSetting = localStorage.getItem('sttEngine') || 'auto';
                if (this._engineSetting === 'auto') {
                    await this.autoDetectEngine();
                } else {
                    this._engine = this._engineSetting;
                }
            },

            updateEquipmentId: function(equipmentId) {
                this._equipmentId = equipmentId;
            },

            setEngine: async function(engine) {
                this._engineSetting = engine;
                if (engine === 'auto') {
                    await this.autoDetectEngine();
                } else if (engine === 'whisper') {
                    var ok = await this._checkWhisperAvailable();
                    this._engine = 'whisper';
                    this._disabled = !ok;
                    if (!ok && this._dotNetRef)
                        this._dotNetRef.invokeMethodAsync('OnTranscriptionError',
                            'Whisper 서버에 연결할 수 없습니다. --profile whisper 로 컨테이너를 시작하세요.');
                } else {
                    this._engine = engine;
                    this._disabled = false;
                }
            },

            _checkWebSpeechAvailable: function() {
                return !!(window.SpeechRecognition || window.webkitSpeechRecognition);
            },

            _checkWhisperAvailable: async function() {
                try {
                    var resp = await fetch(this._gatewayUrl + '/api/transcribe/health', { signal: AbortSignal.timeout(3000) });
                    return resp.ok;
                } catch { return false; }
            },

            autoDetectEngine: async function() {
                var whisperOk = await this._checkWhisperAvailable();
                if (whisperOk) {
                    this._engine = 'whisper';
                    this._disabled = false;
                    return 'whisper';
                }
                if (this._checkWebSpeechAvailable()) {
                    this._engine = 'webspeech';
                    this._disabled = false;
                    return 'webspeech';
                }
                this._disabled = true;
                return 'disabled';
            },

            getEngine: function() { return this._engine; },
            isDisabled: function() { return this._disabled; },

            start: async function() {
                if (this._disabled) {
                    if (this._dotNetRef)
                        this._dotNetRef.invokeMethodAsync('OnTranscriptionError', 'STT 엔진을 사용할 수 없습니다');
                    return false;
                }
                if (this._engine === 'webspeech') {
                    return this._startWebSpeech();
                }
                return this._startWhisper();
            },

            // ── Web Speech API mode ──
            _startWebSpeech: function() {
                try {
                    var SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
                    if (!SpeechRecognition) {
                        if (this._dotNetRef)
                            this._dotNetRef.invokeMethodAsync('OnTranscriptionError', 'Web Speech API를 지원하지 않는 브라우저입니다');
                        return false;
                    }
                    this._recognition = new SpeechRecognition();
                    this._recognition.lang = 'ko-KR';
                    this._recognition.interimResults = true;
                    this._recognition.continuous = false;
                    this._recognition.maxAlternatives = 1;
                    var self = this;

                    this._recognition.onresult = function(event) {
                        var transcript = '';
                        var isFinal = false;
                        for (var i = event.resultIndex; i < event.results.length; i++) {
                            transcript += event.results[i][0].transcript;
                            if (event.results[i].isFinal) isFinal = true;
                        }
                        if (self._dotNetRef) {
                            self._dotNetRef.invokeMethodAsync('OnInterimResult', transcript, isFinal);
                        }
                    };

                    this._recognition.onerror = function(event) {
                        self._stopTimer();
                        var msg = '음성 인식 오류';
                        if (event.error === 'not-allowed') msg = '마이크 권한이 거부되었습니다';
                        else if (event.error === 'no-speech') msg = '음성이 감지되지 않았습니다';
                        else if (event.error === 'network') msg = '네트워크 오류';
                        if (self._dotNetRef) self._dotNetRef.invokeMethodAsync('OnTranscriptionError', msg);
                    };

                    this._recognition.onend = function() {
                        self._stopTimer();
                        // In voice mode, WebSpeech auto-stops — notify Blazor recording ended
                        // (OnInterimResult with isFinal=true already handles the text)
                    };

                    this._recognition.start();
                    this._startTimer();
                    return true;
                } catch (err) {
                    if (this._dotNetRef)
                        this._dotNetRef.invokeMethodAsync('OnTranscriptionError', err.message);
                    return false;
                }
            },

            // ── Whisper (MediaRecorder) mode ──
            _silenceCtx: null,
            _silenceAnalyser: null,
            _silenceInterval: null,
            _silenceStart: 0,
            _speechDetected: false,
            _voiceMode: false,          // set by Blazor before start()
            _persistentStream: null,    // kept alive during voice mode

            setVoiceMode: async function(on) {
                this._voiceMode = !!on;
                if (on) {
                    // Pre-acquire mic on user gesture — single permission prompt for entire session
                    if (!this._persistentStream) {
                        try {
                            this._persistentStream = await navigator.mediaDevices.getUserMedia({ audio: true });
                            console.log('[STT] Mic acquired for voice mode session');
                        } catch(e) {
                            console.error('[STT] Mic acquire failed:', e);
                        }
                    }
                } else {
                    this._releasePersistentStream();
                }
            },

            _releasePersistentStream: function() {
                if (this._persistentStream) {
                    this._persistentStream.getTracks().forEach(function(t) { t.stop(); });
                    this._persistentStream = null;
                    console.log('[STT] Mic released');
                }
            },

            _startWhisper: async function() {
                try {
                    if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) {
                        throw { name: 'NotSupportedError',
                                message: 'HTTPS 연결이 필요합니다 (Tailscale HTTPS 또는 localhost만 지원)' };
                    }

                    var stream;
                    if (this._voiceMode && this._persistentStream &&
                        this._persistentStream.active &&
                        this._persistentStream.getTracks().some(function(t) { return t.readyState === 'live'; })) {
                        // Reuse existing stream — no permission prompt
                        stream = this._persistentStream;
                        console.log('[STT] Reusing persistent mic stream');
                    } else {
                        stream = await navigator.mediaDevices.getUserMedia({ audio: true });
                        if (this._voiceMode) {
                            this._persistentStream = stream;
                            console.log('[STT] New mic stream acquired');
                        }
                    }

                    this._chunks = [];
                    var mimeType = MediaRecorder.isTypeSupported('audio/webm;codecs=opus')
                        ? 'audio/webm;codecs=opus' : 'audio/webm';
                    this._mediaRecorder = new MediaRecorder(stream, { mimeType: mimeType });
                    var self = this;
                    this._mediaRecorder.ondataavailable = function(e) {
                        if (e.data.size > 0) self._chunks.push(e.data);
                    };
                    this._mediaRecorder.onstop = function() {
                        // Only release stream if NOT in voice mode
                        if (!self._voiceMode) {
                            stream.getTracks().forEach(function(t) { t.stop(); });
                        }
                        self._stopTimer();
                        self._stopSilenceDetector();
                        self._sendAudio();
                    };
                    this._mediaRecorder.start();
                    this._startTimer();

                    // Silence detection for auto-stop in voice mode
                    if (this._voiceMode) {
                        this._startSilenceDetector(stream);
                    }

                    return true;
                } catch (err) {
                    if (this._dotNetRef)
                        this._dotNetRef.invokeMethodAsync('OnTranscriptionError',
                            err.name === 'NotAllowedError' ? '마이크 권한이 거부되었습니다' : err.message);
                    return false;
                }
            },

            _startSilenceDetector: function(stream) {
                try {
                    this._silenceCtx = new (window.AudioContext || window.webkitAudioContext)();
                    var source = this._silenceCtx.createMediaStreamSource(stream);
                    this._silenceAnalyser = this._silenceCtx.createAnalyser();
                    this._silenceAnalyser.fftSize = 512;
                    source.connect(this._silenceAnalyser);

                    var bufLen = this._silenceAnalyser.fftSize;
                    var buf = new Float32Array(bufLen);
                    this._speechDetected = false;
                    this._silenceStart = 0;
                    var self = this;
                    var SPEECH_THRESHOLD = 0.015;   // RMS above this = speech
                    var SILENCE_DURATION = 2000;    // ms of silence to auto-stop

                    this._silenceInterval = setInterval(function() {
                        if (!self._silenceAnalyser) return;
                        self._silenceAnalyser.getFloatTimeDomainData(buf);
                        // RMS level
                        var sum = 0;
                        for (var i = 0; i < bufLen; i++) sum += buf[i] * buf[i];
                        var rms = Math.sqrt(sum / bufLen);

                        if (rms > SPEECH_THRESHOLD) {
                            self._speechDetected = true;
                            self._silenceStart = 0;
                        } else if (self._speechDetected) {
                            // Speech was detected, now silence
                            if (self._silenceStart === 0) {
                                self._silenceStart = Date.now();
                            } else if (Date.now() - self._silenceStart > SILENCE_DURATION) {
                                console.log('[STT] Silence detected for', SILENCE_DURATION, 'ms — auto-stopping');
                                self.stop();
                            }
                        }
                    }, 100);
                } catch(e) {
                    console.warn('[STT] Silence detector init failed:', e);
                }
            },

            _stopSilenceDetector: function() {
                if (this._silenceInterval) {
                    clearInterval(this._silenceInterval);
                    this._silenceInterval = null;
                }
                if (this._silenceCtx) {
                    try { this._silenceCtx.close(); } catch {}
                    this._silenceCtx = null;
                }
                this._silenceAnalyser = null;
            },

            stop: function() {
                if (this._engine === 'webspeech' && this._recognition) {
                    this._recognition.stop();
                    this._recognition = null;
                } else if (this._mediaRecorder && this._mediaRecorder.state === 'recording') {
                    this._mediaRecorder.stop();
                }
            },

            _getDomainPrompt: function() {
                var eqLower = (this._equipmentId || '').toLowerCase();
                for (var key in this._domainPrompts) {
                    if (key !== 'default' && eqLower.indexOf(key) !== -1) return this._domainPrompts[key];
                }
                return this._domainPrompts['default'];
            },

            _sendAudio: async function() {
                var blob = new Blob(this._chunks, { type: 'audio/webm' });
                var form = new FormData();
                form.append('audio', blob, 'recording.webm');
                // Domain prompt biasing
                var prompt = this._getDomainPrompt();
                if (prompt) form.append('prompt', prompt);
                try {
                    var resp = await fetch(
                        this._gatewayUrl + '/api/transcribe/' + encodeURIComponent(this._equipmentId),
                        { method: 'POST', body: form });
                    if (!resp.ok) {
                        var errBody = await resp.text();
                        var errMsg = 'HTTP ' + resp.status;
                        try { errMsg = JSON.parse(errBody).error || errMsg; } catch {}
                        throw new Error(errMsg);
                    }
                    var data = await resp.json();
                    if (this._dotNetRef)
                        this._dotNetRef.invokeMethodAsync('OnTranscriptionComplete', data.text || '');
                } catch (err) {
                    var msg = err.message || '음성 변환 실패';
                    if (err.name === 'TypeError' && msg.indexOf('fetch') !== -1)
                        msg = 'Gateway 서버에 연결할 수 없습니다 (port 5000)';
                    if (this._dotNetRef)
                        this._dotNetRef.invokeMethodAsync('OnTranscriptionError', msg);
                }
            },

            // ── Recording timer ──
            _startTimer: function() {
                this._startTime = Date.now();
                var self = this;
                this._timerInterval = setInterval(function() {
                    var elapsed = Math.floor((Date.now() - self._startTime) / 1000);
                    if (self._dotNetRef) self._dotNetRef.invokeMethodAsync('OnRecordingTick', elapsed);
                }, 1000);
            },

            _stopTimer: function() {
                if (this._timerInterval) {
                    clearInterval(this._timerInterval);
                    this._timerInterval = null;
                }
                this._startTime = null;
            },

            dispose: function() {
                this._stopTimer();
                this._stopSilenceDetector();
                this._releasePersistentStream();
                if (this._recognition) { try { this._recognition.abort(); } catch {} this._recognition = null; }
                if (this._mediaRecorder && this._mediaRecorder.state === 'recording')
                    this._mediaRecorder.stop();
                this._dotNetRef = null;
            }
        };

        // ─── Citation pane drag-resize ──────────────────────────────
        window.citationResize = {
            init: function (paneSelector, handleSelector, minWidth) {
                var handle = document.querySelector(handleSelector);
                var pane = document.querySelector(paneSelector);
                if (!handle || !pane) return;

                var startX, startWidth;
                handle.addEventListener('mousedown', function (e) {
                    startX = e.clientX;
                    startWidth = pane.offsetWidth;
                    e.preventDefault();

                    function onMove(ev) {
                        var delta = startX - ev.clientX;
                        var maxWidth = window.innerWidth * 0.6;
                        var newWidth = Math.max(minWidth, Math.min(maxWidth, startWidth + delta));
                        pane.style.width = newWidth + 'px';
                    }
                    function onUp() {
                        document.removeEventListener('mousemove', onMove);
                        document.removeEventListener('mouseup', onUp);
                    }
                    document.addEventListener('mousemove', onMove);
                    document.addEventListener('mouseup', onUp);
                });
            }
        };

        // ─── Mobile keyboard viewport fix ────────────────────────────
        (function () {
            if (!window.visualViewport) return;
            window.visualViewport.addEventListener('resize', function () {
                // When keyboard closes (viewport height recovers), reset scroll
                window.scrollTo(0, 0);
                document.documentElement.scrollTop = 0;
                document.body.scrollTop = 0;
            });
            // Also fix on focus out (keyboard dismiss)
            document.addEventListener('focusout', function () {
                setTimeout(function () {
                    window.scrollTo(0, 0);
                }, 100);
            });
        })();
    </script>
</body>
</html>
