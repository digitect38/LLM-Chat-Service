                    e.preventDefault();

                    function onMove(ev) {
                        var delta = startX - ev.clientX;
                        var maxWidth = window.innerWidth * 0.6;
                        var newWidth = Math.max(minWidth, Math.min(maxWidth, startWidth + delta));
                        pane.style.width = newWidth + 'px';
                    }
                    function onUp() {
                        document.removeEventListener('mousemove', onMove);
                        document.removeEventListener('mouseup', onUp);
                    }
                    document.addEventListener('mousemove', onMove);
                    document.addEventListener('mouseup', onUp);
                });
            }
        };

        // ─── Panel swipe navigation (mobile, finger-tracking) ────────
        window.panelSwipe = {
            _ref: null,
            _track: null,       // .panel-track element
            _startX: 0,
            _startY: 0,
            _startTime: 0,
            _lastX: 0,
            _lastTime: 0,
            _dragging: false,   // true once horizontal intent confirmed
            _decided: false,    // true once direction (h vs v) is decided
            _baseOffset: 0,     // translateX at touchstart (px)
            _panelWidth: 0,     // single panel width (px)
            _panelCount: 4,
            _currentPanel: 0,
            init: function (dotnetRef) {
                this._ref = dotnetRef;
                var vp = document.querySelector('.panel-viewport');
                if (!vp || vp._swipeAttached) return;
                vp._swipeAttached = true;
                var self = this;

                vp.addEventListener('touchstart', function (e) {
                    if (window.innerWidth > 768) return;
                    // Skip if user is selecting text
                    var sel = window.getSelection();
                    if (sel && sel.type === 'Range') { self._decided = true; self._dragging = false; return; }
                    if (sel && !sel.isCollapsed) { self._decided = true; self._dragging = false; return; }
                    self._track = vp.querySelector('.panel-track');
                    if (!self._track) return;
                    var t = e.touches[0];
                    self._startX = t.clientX;
                    self._startY = t.clientY;
                    self._lastX = t.clientX;
                    self._startTime = Date.now();
                    self._lastTime = self._startTime;
                    self._dragging = false;
                    self._decided = false;
                    self._panelWidth = vp.offsetWidth;
                    // Read current panel from the inline style (translateX(-N%))
                    var style = self._track.style.transform || '';
                    var m = style.match(/translateX\(-?(\d+)%\)/);
                    self._currentPanel = m ? Math.round(parseInt(m[1]) / 25) : 0;
                    self._baseOffset = -self._currentPanel * self._panelWidth;
                }, { passive: true });

                vp.addEventListener('touchmove', function (e) {
                    if (window.innerWidth > 768 || !self._track) return;
                    // Abort if text selection started during drag
                    var sel = window.getSelection();
                    if (sel && (sel.type === 'Range' || !sel.isCollapsed)) {
                        if (self._dragging && self._track) {
                            self._track.style.transition = '';
                            self._track.style.transform = 'translateX(-' + (self._currentPanel * 25) + '%)';
                        }
                        self._dragging = false;
                        self._decided = true;
                        return;
                    }
                    var t = e.touches[0];
                    var dx = t.clientX - self._startX;
                    var dy = t.clientY - self._startY;
                    var adx = Math.abs(dx);
                    var ady = Math.abs(dy);

                    // Decide direction once (>8px movement)
                    if (!self._decided && (adx > 8 || ady > 8)) {
                        self._decided = true;
                        self._dragging = adx > ady; // horizontal wins
                        if (self._dragging) {
                            // Kill the CSS transition for direct finger tracking
                            self._track.style.transition = 'none';
                        }
                    }

                    if (!self._dragging) return;
                    e.preventDefault();

                    // Clamp: don't scroll past first/last panel
                    var raw = self._baseOffset + dx;
                    var minOffset = -(self._panelCount - 1) * self._panelWidth;
                    // Add rubber-band resistance at edges (30% of overscroll)
                    if (raw > 0) raw = raw * 0.3;
                    else if (raw < minOffset) raw = minOffset + (raw - minOffset) * 0.3;

                    self._track.style.transform = 'translateX(' + raw + 'px)';
                    self._lastX = t.clientX;
                    self._lastTime = Date.now();
                }, { passive: false });

                vp.addEventListener('touchend', function () {
                    if (!self._dragging || !self._track) {
                        self._dragging = false;
                        self._decided = false;
                        return;
                    }
                    var dx = self._lastX - self._startX;
                    var dt = self._lastTime - self._startTime;
                    var velocity = dt > 0 ? Math.abs(dx) / dt : 0; // px/ms

                    // Decide target: flick (velocity > 0.3 px/ms) or distance > 25% of panel
                    var threshold = self._panelWidth * 0.25;
                    var target = self._currentPanel;
                    if (dx < -threshold || (dx < -20 && velocity > 0.3)) {
                        target = Math.min(self._currentPanel + 1, self._panelCount - 1);
                    } else if (dx > threshold || (dx > 20 && velocity > 0.3)) {
                        target = Math.max(self._currentPanel - 1, 0);
                    }

                    // Snap with smooth transition (speed proportional to remaining distance)
                    var targetPx = -target * self._panelWidth;
                    var currentPx = self._baseOffset + dx;
                    var dist = Math.abs(targetPx - currentPx);
                    // Duration: 150~300ms proportional to distance
                    var duration = Math.max(150, Math.min(300, dist / self._panelWidth * 300));
                    self._track.style.transition = 'transform ' + duration + 'ms cubic-bezier(0.25,0.1,0.25,1)';
                    self._track.style.transform = 'translateX(-' + (target * 25) + '%)';

                    // Clean up inline transition after snap completes
                    var cleanup = function () {
                        self._track.style.transition = '';
                        self._track.removeEventListener('transitionend', cleanup);
                    };
                    self._track.addEventListener('transitionend', cleanup);

                    // Notify Blazor if panel changed
                    if (target !== self._currentPanel) {
                        if (target > self._currentPanel) self._ref.invokeMethodAsync('SwipeNext');
                        else self._ref.invokeMethodAsync('SwipePrev');
                    }

                    self._dragging = false;
                    self._decided = false;
                }, { passive: true });
            }
        };

        // ─── Mobile keyboard viewport fix ────────────────────────────
        (function () {
            var appEl = document.querySelector('.chat-app');
            if (!appEl) return;

            function setAppHeight() {
                // visualViewport.height shrinks when keyboard is open
                var h = window.visualViewport
                    ? window.visualViewport.height
                    : window.innerHeight;
                appEl.style.setProperty('--app-height', h + 'px');
                // Also set bottom to keep the app pinned to the top of the visible area
                appEl.style.top = (window.visualViewport ? window.visualViewport.offsetTop : 0) + 'px';
                appEl.style.height = h + 'px';
            }

            // Initial set
            setAppHeight();

            if (window.visualViewport) {
                window.visualViewport.addEventListener('resize', setAppHeight);
                window.visualViewport.addEventListener('scroll', setAppHeight);
            } else {
                window.addEventListener('resize', setAppHeight);
            }

            // When keyboard dismisses, reset scroll position
            document.addEventListener('focusout', function () {
                setTimeout(function () {
                    window.scrollTo(0, 0);
                }, 100);
            });

            // On iOS, ensure input stays visible after focus
            document.addEventListener('focusin', function (e) {
                if (e.target && (e.target.tagName === 'TEXTAREA' || e.target.tagName === 'INPUT')) {
                    setTimeout(function () {
                        setAppHeight();
                        e.target.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
                    }, 300);
                }
            });
        })();
    </script>
</body>
</html>
