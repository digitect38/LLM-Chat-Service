@using Microsoft.AspNetCore.Components.Web
@namespace FabCopilot.WebClient.Pages
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <base href="~/" />
    <link href="css/app.css" rel="stylesheet" asp-append-version="true" />
    <link href="FabCopilot.WebClient.styles.css" rel="stylesheet" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/highlightjs/cdn-release@11.9.0/build/styles/vs2015.min.css" />
    <title>Fab Copilot</title>
    <component type="typeof(HeadOutlet)" render-mode="ServerPrerendered" />
</head>
<body>
    @RenderBody()

    <div id="blazor-error-ui">
        <environment include="Staging,Production">
            An error has occurred. This application may no longer respond until reloaded.
        </environment>
        <environment include="Development">
            An unhandled exception has occurred. See browser dev tools for details.
        </environment>
        <a href="" class="reload">Reload</a>
        <a class="dismiss">X</a>
    </div>

    <script src="_framework/blazor.server.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/marked@12.0.2/marked.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.js"></script>
    <script src="https://cdn.jsdelivr.net/gh/highlightjs/cdn-release@11.9.0/build/highlight.min.js"></script>
    <script src="https://cdn.jsdelivr.net/gh/highlightjs/cdn-release@11.9.0/build/languages/erlang.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js"></script>
    <script>
        // ─── Scroll ───────────────────────────────────────────────
        window.chatScroll = {
            scrollToBottom: function (elementId) {
                var el = document.getElementById(elementId);
                if (el) el.scrollTop = el.scrollHeight;
            }
        };

        // ─── Input auto-resize ────────────────────────────────────
        window.chatInput = {
            autoResize: function (elementId) {
                var el = document.getElementById(elementId);
                if (!el) return;
                el.style.height = 'auto';
                el.style.height = Math.min(el.scrollHeight, 200) + 'px';
            },
            resetHeight: function (elementId) {
                var el = document.getElementById(elementId);
                if (el) el.style.height = 'auto';
            }
        };

        // ─── Clipboard ───────────────────────────────────────────
        window.clipboard = {
            copyText: async function (text) {
                try {
                    await navigator.clipboard.writeText(text);
                    return true;
                } catch {
                    // Fallback for older browsers or insecure contexts
                    var ta = document.createElement('textarea');
                    ta.value = text;
                    ta.style.position = 'fixed';
                    ta.style.opacity = '0';
                    document.body.appendChild(ta);
                    ta.select();
                    document.execCommand('copy');
                    document.body.removeChild(ta);
                    return true;
                }
            }
        };

        // ─── Markdown + KaTeX renderer ────────────────────────────
        window.chatRenderer = {
            renderMarkdown: function (text) {
                if (!text) return '';

                // Guard: check libraries loaded
                if (typeof marked === 'undefined' || typeof marked.parse !== 'function') {
                    console.error('[chatRenderer] marked.js not loaded');
                    return text;
                }
                if (typeof katex === 'undefined' || typeof katex.renderToString !== 'function') {
                    console.error('[chatRenderer] katex.js not loaded');
                    return marked.parse(text);
                }

                try {
                    return this._render(text);
                } catch (e) {
                    console.error('[chatRenderer] render failed:', e);
                    return text;
                }
            },

            _render: function (text) {
                var blockMath = [];
                var inlineMath = [];

                // 1. Extract block math delimiters FIRST: $$...$$ and \[...\]
                //    (must come before \begin{env} to avoid double-capture of matrices)
                text = text.replace(/\$\$([\s\S]*?)\$\$/g, function (m, f) {
                    blockMath.push(f.trim());
                    return '%%BLOCKMATH' + (blockMath.length - 1) + '%%';
                });
                text = text.replace(/\\\[([\s\S]*?)\\\]/g, function (m, f) {
                    blockMath.push(f.trim());
                    return '%%BLOCKMATH' + (blockMath.length - 1) + '%%';
                });

                // 2. Extract standalone \begin{env}...\end{env} not already captured
                text = text.replace(/\\begin\{(equation|align|aligned|gather|gathered|multline|cases|bmatrix|pmatrix|vmatrix|Bmatrix|Vmatrix|smallmatrix|matrix|array)\*?\}([\s\S]*?)\\end\{\1\*?\}/g, function (m) {
                    blockMath.push(m);
                    return '%%BLOCKMATH' + (blockMath.length - 1) + '%%';
                });

                // 3. Extract inline math: \(...\) first, then $...$
                text = text.replace(/\\\(([\s\S]*?)\\\)/g, function (m, f) {
                    inlineMath.push(f.trim());
                    return '%%INLINEMATH' + (inlineMath.length - 1) + '%%';
                });
                text = text.replace(/\$([^\$\n]+?)\$/g, function (m, f) {
                    inlineMath.push(f.trim());
                    return '%%INLINEMATH' + (inlineMath.length - 1) + '%%';
                });

                // 3c. Cleanup orphaned delimiters (truncated responses)
                text = text.replace(/\\\[([\s\S]+)$/g, function (m, f) {
                    blockMath.push(f.trim());
                    return '%%BLOCKMATH' + (blockMath.length - 1) + '%%';
                });
                text = text.replace(/\\\(([\s\S]+)$/g, function (m, f) {
                    inlineMath.push(f.trim());
                    return '%%INLINEMATH' + (inlineMath.length - 1) + '%%';
                });

                // 3. Render markdown
                var html = marked.parse(text);

                // 3b. Syntax highlighting for code blocks
                if (typeof hljs !== 'undefined') {
                    var tempDiv = document.createElement('div');
                    tempDiv.innerHTML = html;
                    tempDiv.querySelectorAll('pre code').forEach(function (block) {
                        var lang = (block.className.match(/language-(\w+)/) || [, ''])[1];
                        var code = block.textContent;
                        try {
                            var result;
                            if (lang && hljs.getLanguage(lang)) {
                                result = hljs.highlight(code, { language: lang });
                            } else {
                                result = hljs.highlightAuto(code);
                            }
                            block.innerHTML = result.value;
                            block.classList.add('hljs');
                        } catch (e) {}
                    });
                    html = tempDiv.innerHTML;
                }

                // 4. Restore block math (use <span> to avoid breaking <li>/<p> structure)
                html = html.replace(/%%BLOCKMATH(\d+)%%/g, function (m, i) {
                    try {
                        return '<span class="katex-block">' +
                            katex.renderToString(blockMath[parseInt(i)], { displayMode: true, throwOnError: false }) +
                            '</span>';
                    } catch (e) {
                        console.warn('[chatRenderer] block math error:', e.message);
                        return '<span class="katex-block katex-error">' + blockMath[parseInt(i)] + '</span>';
                    }
                });

                // 5. Restore inline math
                html = html.replace(/%%INLINEMATH(\d+)%%/g, function (m, i) {
                    try {
                        return '<span class="katex-inline">' +
                            katex.renderToString(inlineMath[parseInt(i)], { displayMode: false, throwOnError: false }) +
                            '</span>';
                    } catch (e) {
                        console.warn('[chatRenderer] inline math error:', e.message);
                        return '<span class="katex-error">' + inlineMath[parseInt(i)] + '</span>';
                    }
                });

                // Post-process: convert [Page XX] references into clickable links
                html = html.replace(/\[Page\s+(\d+(?:\s*,\s*\d+)*)\]/g, function (match, pages) {
                    var pageNums = pages.split(/\s*,\s*/);
                    var links = pageNums.map(function (p) {
                        return '<a class="citation-page-link" data-page="' + p.trim() + '" onclick="citationInterop.onPageLinkClick(' + p.trim() + '); return false;" href="#">Page ' + p.trim() + '</a>';
                    });
                    return '[' + links.join(', ') + ']';
                });

                return html;
            }
        };

        // ─── Citation interop (Blazor ↔ JS) ───────────────────────────
        window.citationInterop = {
            _dotNetRef: null,
            init: function (dotNetRef) {
                this._dotNetRef = dotNetRef;
            },
            onPageLinkClick: function (page) {
                if (this._dotNetRef) {
                    this._dotNetRef.invokeMethodAsync('OnCitationPageClick', page);
                }
            },
            dispose: function () {
                this._dotNetRef = null;
            }
        };

        // ─── pdf.js viewer interop ──────────────────────────────────
        window.pdfViewer = {
            _doc: null,
            _pageCount: 0,

            load: async function (url) {
                if (typeof pdfjsLib === 'undefined') {
                    console.error('pdf.js not loaded');
                    return 0;
                }
                pdfjsLib.GlobalWorkerOptions.workerSrc =
                    'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';
                try {
                    this._doc = await pdfjsLib.getDocument(url).promise;
                    this._pageCount = this._doc.numPages;
                    return this._pageCount;
                } catch (e) {
                    console.error('PDF load failed:', e);
                    return 0;
                }
            },

            renderPage: async function (canvasId, pageNum, scale) {
                if (!this._doc) return false;
                try {
                    var page = await this._doc.getPage(pageNum);
                    var viewport = page.getViewport({ scale: scale || 1.0 });
                    var canvas = document.getElementById(canvasId);
                    if (!canvas) return false;
                    var ctx = canvas.getContext('2d');
                    canvas.width = viewport.width;
                    canvas.height = viewport.height;
                    await page.render({ canvasContext: ctx, viewport: viewport }).promise;
                    return true;
                } catch (e) {
                    console.error('PDF render failed:', e);
                    return false;
                }
            },

            getPageCount: function () {
                return this._pageCount;
            },

            highlightText: async function (canvasId, overlayId, charStart, charEnd, scale) {
                if (!this._doc) return false;
                var overlay = document.getElementById(overlayId);
                var canvas = document.getElementById(canvasId);
                if (!overlay || !canvas) return false;
                overlay.innerHTML = '';

                var pageNum = parseInt(canvas.dataset.pageNum || '1');
                var highlighted = false;
                try {
                    var page = await this._doc.getPage(pageNum);
                    var viewport = page.getViewport({ scale: scale || 1.0 });
                    var textContent = await page.getTextContent();

                    var currentOffset = 0;
                    for (var i = 0; i < textContent.items.length; i++) {
                        var item = textContent.items[i];
                        if (!item.str) continue;
                        var itemStart = currentOffset;
                        var itemEnd = currentOffset + item.str.length;

                        if (itemEnd > charStart && itemStart < charEnd) {
                            var tx = pdfjsLib.Util.transform(viewport.transform, item.transform);
                            var rect = document.createElement('div');
                            rect.className = 'highlight-rect';
                            rect.style.left = tx[4] + 'px';
                            rect.style.top = (canvas.height - tx[5] - item.height * (scale || 1.0)) + 'px';
                            rect.style.width = item.width * (scale || 1.0) + 'px';
                            rect.style.height = item.height * (scale || 1.0) + 'px';
                            overlay.appendChild(rect);
                            highlighted = true;
                        }
                        currentOffset = itemEnd;
                    }
                } catch (e) {
                    console.error('Highlight failed:', e);
                }
                return highlighted;
            },

            showFallbackHighlight: function (overlayId, canvasWidth, canvasHeight) {
                var overlay = document.getElementById(overlayId);
                if (!overlay) return;
                overlay.innerHTML = '';
                var fallback = document.createElement('div');
                fallback.className = 'highlight-fallback-overlay';
                fallback.style.width = canvasWidth + 'px';
                fallback.style.height = canvasHeight + 'px';
                var text = document.createElement('span');
                text.className = 'highlight-fallback-text';
                text.textContent = '정확한 위치를 표시할 수 없습니다';
                fallback.appendChild(text);
                overlay.appendChild(fallback);
            }
        };

        // ─── Client Settings (localStorage) ─────────────────────────
        window.clientSettings = {
            getCodeFont: function() {
                return localStorage.getItem('fab-code-font') || 'Cascadia Code';
            },
            setCodeFont: function(font) {
                localStorage.setItem('fab-code-font', font);
                document.documentElement.style.setProperty('--code-font',
                    "'" + font + "', 'Fira Code', 'Consolas', monospace");
            },
            getSttEngine: function() {
                return localStorage.getItem('sttEngine') || 'auto';
            },
            setSttEngine: function(v) {
                localStorage.setItem('sttEngine', v);
                if (window.audioRecorder) window.audioRecorder.setEngine(v);
            },
            init: function() {
                this.setCodeFont(this.getCodeFont());
            }
        };
        window.clientSettings.init();

        // ─── Audio Recorder (STT) — Dual Engine ─────────────────────────
        window.audioRecorder = {
            _mediaRecorder: null,
            _chunks: [],
            _dotNetRef: null,
            _gatewayUrl: '',
            _equipmentId: 'default',
            _engine: 'whisper',           // 'whisper' | 'webspeech'
            _engineSetting: 'auto',       // 'auto' | 'whisper' | 'webspeech'
            _recognition: null,           // SpeechRecognition instance
            _startTime: null,
            _timerInterval: null,
            _disabled: false,

            // Domain prompt biasing terms for CMP equipment
            _domainPrompts: {
                'default': 'CMP polishing pad slurry MRR wafer removal rate planarization',
                'cmp': 'CMP chemical mechanical polishing pad conditioner slurry MRR removal rate WIWNU planarization endpoint detection retaining ring carrier head platen',
                'etch': 'etch plasma RF chamber selectivity etch rate uniformity endpoint polymer residue',
                'cvd': 'CVD deposition film thickness uniformity precursor chamber temperature pressure'
            },

            init: async function(dotNetRef, equipmentId) {
                this._dotNetRef = dotNetRef;
                var gwPort = window.location.protocol === 'https:' ? '5001' : '5000';
                this._gatewayUrl = window.location.protocol + '//' + window.location.hostname + ':' + gwPort;
                this._equipmentId = equipmentId || 'default';

                // Load saved engine preference
                this._engineSetting = localStorage.getItem('sttEngine') || 'auto';
                if (this._engineSetting === 'auto') {
                    await this.autoDetectEngine();
                } else {
                    this._engine = this._engineSetting;
                }
            },

            updateEquipmentId: function(equipmentId) {
                this._equipmentId = equipmentId;
            },

            setEngine: function(engine) {
                this._engineSetting = engine;
                if (engine === 'auto') {
                    this.autoDetectEngine();
                } else {
                    this._engine = engine;
                    this._disabled = false;
                }
            },

            _checkWebSpeechAvailable: function() {
                return !!(window.SpeechRecognition || window.webkitSpeechRecognition);
            },

            _checkWhisperAvailable: async function() {
                try {
                    var resp = await fetch(this._gatewayUrl + '/api/transcribe/health', { signal: AbortSignal.timeout(3000) });
                    return resp.ok;
                } catch { return false; }
            },

            autoDetectEngine: async function() {
                var whisperOk = await this._checkWhisperAvailable();
                if (whisperOk) {
                    this._engine = 'whisper';
                    this._disabled = false;
                    return 'whisper';
                }
                if (this._checkWebSpeechAvailable()) {
                    this._engine = 'webspeech';
                    this._disabled = false;
                    return 'webspeech';
                }
                this._disabled = true;
                return 'disabled';
            },

            getEngine: function() { return this._engine; },
            isDisabled: function() { return this._disabled; },

            start: async function() {
                if (this._disabled) {
                    if (this._dotNetRef)
                        this._dotNetRef.invokeMethodAsync('OnTranscriptionError', 'STT 엔진을 사용할 수 없습니다');
                    return false;
                }
                if (this._engine === 'webspeech') {
                    return this._startWebSpeech();
                }
                return this._startWhisper();
            },

            // ── Web Speech API mode ──
            _startWebSpeech: function() {
                try {
                    var SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
                    if (!SpeechRecognition) {
                        if (this._dotNetRef)
                            this._dotNetRef.invokeMethodAsync('OnTranscriptionError', 'Web Speech API를 지원하지 않는 브라우저입니다');
                        return false;
                    }
                    this._recognition = new SpeechRecognition();
                    this._recognition.lang = 'ko-KR';
                    this._recognition.interimResults = true;
                    this._recognition.continuous = false;
                    this._recognition.maxAlternatives = 1;
                    var self = this;

                    this._recognition.onresult = function(event) {
                        var transcript = '';
                        var isFinal = false;
                        for (var i = event.resultIndex; i < event.results.length; i++) {
                            transcript += event.results[i][0].transcript;
                            if (event.results[i].isFinal) isFinal = true;
                        }
                        if (self._dotNetRef) {
                            self._dotNetRef.invokeMethodAsync('OnInterimResult', transcript, isFinal);
                        }
                    };

                    this._recognition.onerror = function(event) {
                        self._stopTimer();
                        var msg = '음성 인식 오류';
                        if (event.error === 'not-allowed') msg = '마이크 권한이 거부되었습니다';
                        else if (event.error === 'no-speech') msg = '음성이 감지되지 않았습니다';
                        else if (event.error === 'network') msg = '네트워크 오류';
                        if (self._dotNetRef) self._dotNetRef.invokeMethodAsync('OnTranscriptionError', msg);
                    };

                    this._recognition.onend = function() {
                        self._stopTimer();
                    };

                    this._recognition.start();
                    this._startTimer();
                    return true;
                } catch (err) {
                    if (this._dotNetRef)
                        this._dotNetRef.invokeMethodAsync('OnTranscriptionError', err.message);
                    return false;
                }
            },

            // ── Whisper (MediaRecorder) mode ──
            _startWhisper: async function() {
                try {
                    if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) {
                        throw { name: 'NotSupportedError',
                                message: 'HTTPS 연결이 필요합니다 (Tailscale HTTPS 또는 localhost만 지원)' };
                    }
                    var stream = await navigator.mediaDevices.getUserMedia({ audio: true });
                    this._chunks = [];
                    var mimeType = MediaRecorder.isTypeSupported('audio/webm;codecs=opus')
                        ? 'audio/webm;codecs=opus' : 'audio/webm';
                    this._mediaRecorder = new MediaRecorder(stream, { mimeType: mimeType });
                    var self = this;
                    this._mediaRecorder.ondataavailable = function(e) {
                        if (e.data.size > 0) self._chunks.push(e.data);
                    };
                    this._mediaRecorder.onstop = function() {
                        stream.getTracks().forEach(function(t) { t.stop(); });
                        self._stopTimer();
                        self._sendAudio();
                    };
                    this._mediaRecorder.start();
                    this._startTimer();
                    return true;
                } catch (err) {
                    if (this._dotNetRef)
                        this._dotNetRef.invokeMethodAsync('OnTranscriptionError',
                            err.name === 'NotAllowedError' ? '마이크 권한이 거부되었습니다' : err.message);
                    return false;
                }
            },

            stop: function() {
                if (this._engine === 'webspeech' && this._recognition) {
                    this._recognition.stop();
                    this._recognition = null;
                } else if (this._mediaRecorder && this._mediaRecorder.state === 'recording') {
                    this._mediaRecorder.stop();
                }
            },

            _getDomainPrompt: function() {
                var eqLower = (this._equipmentId || '').toLowerCase();
                for (var key in this._domainPrompts) {
                    if (key !== 'default' && eqLower.indexOf(key) !== -1) return this._domainPrompts[key];
                }
                return this._domainPrompts['default'];
            },

            _sendAudio: async function() {
                var blob = new Blob(this._chunks, { type: 'audio/webm' });
                var form = new FormData();
                form.append('audio', blob, 'recording.webm');
                // Domain prompt biasing
                var prompt = this._getDomainPrompt();
                if (prompt) form.append('prompt', prompt);
                try {
                    var resp = await fetch(
                        this._gatewayUrl + '/api/transcribe/' + encodeURIComponent(this._equipmentId),
                        { method: 'POST', body: form });
                    if (!resp.ok) {
                        var errText = await resp.text();
                        throw new Error(errText || 'HTTP ' + resp.status);
                    }
                    var data = await resp.json();
                    if (this._dotNetRef)
                        this._dotNetRef.invokeMethodAsync('OnTranscriptionComplete', data.text || '');
                } catch (err) {
                    if (this._dotNetRef)
                        this._dotNetRef.invokeMethodAsync('OnTranscriptionError',
                            err.message || '음성 변환 실패');
                }
            },

            // ── Recording timer ──
            _startTimer: function() {
                this._startTime = Date.now();
                var self = this;
                this._timerInterval = setInterval(function() {
                    var elapsed = Math.floor((Date.now() - self._startTime) / 1000);
                    if (self._dotNetRef) self._dotNetRef.invokeMethodAsync('OnRecordingTick', elapsed);
                }, 1000);
            },

            _stopTimer: function() {
                if (this._timerInterval) {
                    clearInterval(this._timerInterval);
                    this._timerInterval = null;
                }
                this._startTime = null;
            },

            dispose: function() {
                this._stopTimer();
                if (this._recognition) { try { this._recognition.abort(); } catch {} this._recognition = null; }
                if (this._mediaRecorder && this._mediaRecorder.state === 'recording')
                    this._mediaRecorder.stop();
                this._dotNetRef = null;
            }
        };

        // ─── Citation pane drag-resize ──────────────────────────────
        window.citationResize = {
            init: function (paneSelector, handleSelector, minWidth) {
                var handle = document.querySelector(handleSelector);
                var pane = document.querySelector(paneSelector);
                if (!handle || !pane) return;

                var startX, startWidth;
                handle.addEventListener('mousedown', function (e) {
                    startX = e.clientX;
                    startWidth = pane.offsetWidth;
                    e.preventDefault();

                    function onMove(ev) {
                        var delta = startX - ev.clientX;
                        var maxWidth = window.innerWidth * 0.6;
                        var newWidth = Math.max(minWidth, Math.min(maxWidth, startWidth + delta));
                        pane.style.width = newWidth + 'px';
                    }
                    function onUp() {
                        document.removeEventListener('mousemove', onMove);
                        document.removeEventListener('mouseup', onUp);
                    }
                    document.addEventListener('mousemove', onMove);
                    document.addEventListener('mouseup', onUp);
                });
            }
        };

        // ─── Mobile keyboard viewport fix ────────────────────────────
        (function () {
            if (!window.visualViewport) return;
            window.visualViewport.addEventListener('resize', function () {
                // When keyboard closes (viewport height recovers), reset scroll
                window.scrollTo(0, 0);
                document.documentElement.scrollTop = 0;
                document.body.scrollTop = 0;
            });
            // Also fix on focus out (keyboard dismiss)
            document.addEventListener('focusout', function () {
                setTimeout(function () {
                    window.scrollTo(0, 0);
                }, 100);
            });
        })();
    </script>
</body>
</html>
