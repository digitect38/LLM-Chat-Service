@page "/server/settings"
@using System.Net.Http.Json
@using Microsoft.Extensions.Options
@using FabCopilot.WebClient.Configuration
@using FabCopilot.WebClient.Services
@inject IOptions<AdminOptions> AdminOpts
@inject EmbeddingConfigService EmbeddingConfigService
@inject IOptions<ModelOptions> ModelOptionsAccessor
@inject NavigationManager Navigation

<div class="settings-page">
    <div class="settings-container">

        <!-- ===== Navigation Bar ===== -->
        <div style="display:flex; justify-content:flex-end; gap:8px;">
            <button class="btn-secondary-sm" @onclick='() => Navigation.NavigateTo("/settings")'>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
                클라이언트 설정
            </button>
            <button class="btn-secondary-sm" @onclick='() => Navigation.NavigateTo("/")'>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
                채팅으로
            </button>
        </div>

        @if (!_isAuthenticated)
        {
            <!-- ═══════════════════════════════════════════════════════════
                 PASSWORD GATE
                 ═══════════════════════════════════════════════════════════ -->
            <div class="settings-card">
                <div class="auth-gate">
                    <div class="auth-icon">
                        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
                    </div>
                    <h2 class="auth-title">서버 설정</h2>
                    <p class="auth-subtitle">관리자 비밀번호를 입력하세요</p>
                    <form class="auth-form" @onsubmit="Authenticate" @onsubmit:preventDefault>
                        <input type="password"
                               class="auth-input"
                               placeholder="비밀번호"
                               @bind="_passwordInput"
                               @bind:event="oninput" />
                        <button type="submit" class="btn-primary-sm">확인</button>
                    </form>
                    @if (_authError)
                    {
                        <div class="auth-error">비밀번호가 올바르지 않습니다</div>
                    }
                </div>
            </div>
        }
        else
        {
            <!-- ═══════════════════════════════════════════════════════════
                 SERVER SETTINGS CARD (authenticated)
                 ═══════════════════════════════════════════════════════════ -->
            <div class="settings-card">
                <div class="settings-header">
                    <h1 class="settings-title">
                        <span class="settings-title-icon">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="8" rx="2" ry="2"/><rect x="2" y="14" width="20" height="8" rx="2" ry="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/></svg>
                            서버 설정
                        </span>
                    </h1>
                    <button class="btn-secondary-sm" @onclick="Logout">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                        로그아웃
                    </button>
                </div>

                <div class="settings-body">
                    <!-- LLM Model -->
                    <div class="config-section">
                        <label class="config-label">LLM 모델</label>
                        <select class="config-select" @bind="_selectedModelId">
                            @foreach (var m in _availableModels)
                            {
                                <option value="@m.Id">@m.DisplayName</option>
                            }
                        </select>
                    </div>

                    <!-- Search Mode -->
                    <div class="config-section">
                        <label class="config-label">검색 모드</label>
                        <div class="search-mode-toggle">
                            <button class="toggle-btn @(_searchMode == "hybrid" ? "toggle-active" : "")"
                                    @onclick='() => _searchMode = "hybrid"'>Hybrid</button>
                            <button class="toggle-btn @(_searchMode == "strict" ? "toggle-active" : "")"
                                    @onclick='() => _searchMode = "strict"'>Strict</button>
                        </div>
                        <span class="config-hint">
                            @(_searchMode == "strict" ? "Strict Grounded: 높은 신뢰도만 응답" : "Hybrid: 유연한 검색")
                        </span>
                    </div>

                    <!-- Chat Provider -->
                    <div class="config-section">
                        <label class="config-label">Chat Provider</label>
                        <select class="config-select" @bind="_llmProvider">
                            <option value="Ollama">Ollama</option>
                            <option value="Tgi">HuggingFace TGI</option>
                        </select>
                        @if (_llmProviderChanged)
                        {
                            <div class="config-warning">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                                Provider 변경 시 서비스 재시작이 필요합니다
                            </div>
                        }
                    </div>

                    <!-- Embedding Provider -->
                    <div class="config-section">
                        <label class="config-label">Embedding Provider</label>
                        <select class="config-select" @bind="_embeddingProvider">
                            <option value="Ollama">Ollama</option>
                            <option value="Tei">HuggingFace TEI</option>
                        </select>
                        @if (_embeddingProviderChanged)
                        {
                            <div class="config-warning">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                                Provider 변경 시 서비스 재시작이 필요합니다
                            </div>
                        }
                    </div>

                    <!-- Dual Index Management -->
                    <div class="config-section">
                        <label class="config-label">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-2px;margin-right:4px"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>
                            Dual Index 관리
                        </label>

                        @if (_dualIndexStatus is not null)
                        {
                            <div class="policy-grid" style="margin-bottom:12px">
                                <div class="policy-item">
                                    <span class="policy-name">Active Collection</span>
                                    <span class="policy-badge badge-on">@_dualIndexStatus.ActiveCollection</span>
                                </div>
                                <div class="policy-item">
                                    <span class="policy-name">Active Model</span>
                                    <span class="policy-value">@_dualIndexStatus.ActiveModelId</span>
                                </div>
                                <div class="policy-item">
                                    <span class="policy-name">Standby Collection</span>
                                    <span class="policy-badge @(_dualIndexStatus.StandbyCollection is not null ? "badge-on" : "badge-off")">
                                        @(_dualIndexStatus.StandbyCollection ?? "—")
                                    </span>
                                </div>
                                <div class="policy-item">
                                    <span class="policy-name">Standby Model</span>
                                    <span class="policy-value">@(_dualIndexStatus.StandbyModelId ?? "—")</span>
                                </div>
                            </div>

                            <!-- Prepare Standby -->
                            <div style="display:flex;gap:8px;margin-bottom:8px">
                                <input type="text" class="config-input" placeholder="Model ID" @bind="_prepareModelId" style="flex:1" />
                                <input type="number" class="config-input" placeholder="Vector Size" @bind="_prepareVectorSize" style="width:100px" />
                                <button class="btn-primary-sm" @onclick="PrepareStandby" disabled="@_dualIndexLoading">준비</button>
                            </div>

                            <!-- Promote / Rollback -->
                            <div style="display:flex;gap:8px">
                                <button class="btn-primary-sm" @onclick="PromoteStandby"
                                        disabled="@(_dualIndexLoading || _dualIndexStatus.StandbyCollection is null)">
                                    승격
                                </button>
                                <button class="btn-secondary-sm" @onclick="() => _showRollbackInput = !_showRollbackInput"
                                        disabled="@_dualIndexLoading">
                                    롤백
                                </button>
                                <button class="btn-secondary-sm" @onclick="RefreshDualIndexStatus" disabled="@_dualIndexLoading">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 11-2.12-9.36L23 10"/></svg>
                                </button>
                            </div>

                            @if (_showRollbackInput)
                            {
                                <div style="display:flex;gap:8px;margin-top:8px">
                                    <input type="text" class="config-input" placeholder="Previous Model ID" @bind="_rollbackModelId" style="flex:1" />
                                    <button class="btn-primary-sm" @onclick="RollbackIndex" disabled="@_dualIndexLoading">실행</button>
                                </div>
                            }
                        }
                        else if (_dualIndexLoading)
                        {
                            <span class="config-hint">로딩 중...</span>
                        }
                        else
                        {
                            <div style="display:flex;align-items:center;gap:8px">
                                <span class="config-hint">KnowledgeService 연결 필요</span>
                                <button class="btn-secondary-sm" @onclick="RefreshDualIndexStatus">연결</button>
                            </div>
                        }

                        @if (!string.IsNullOrEmpty(_dualIndexMessage))
                        {
                            <div class="config-warning" style="margin-top:8px;@(_dualIndexIsError ? "background:#fef2f2;border-color:#fecaca;color:#dc2626" : "background:#f0fdf4;border-color:#bbf7d0;color:#16a34a")">
                                @_dualIndexMessage
                            </div>
                        }
                    </div>

                    <!-- RAG Pipeline Toggles -->
                    <div class="config-section">
                        <label class="config-label">RAG 파이프라인</label>
                        <div class="policy-grid">
                            <div class="policy-item">
                                <span class="policy-name">Query Rewriting (LLM 쿼리 재작성)</span>
                                <div class="search-mode-toggle">
                                    <button class="toggle-btn @(_ragQueryRewriting ? "toggle-active" : "")"
                                            @onclick="() => _ragQueryRewriting = true">ON</button>
                                    <button class="toggle-btn @(!_ragQueryRewriting ? "toggle-active" : "")"
                                            @onclick="() => _ragQueryRewriting = false">OFF</button>
                                </div>
                            </div>
                            <div class="policy-item">
                                <span class="policy-name">LLM Reranking (LLM 재정렬)</span>
                                <div class="search-mode-toggle">
                                    <button class="toggle-btn @(_ragLlmReranking ? "toggle-active" : "")"
                                            @onclick="() => _ragLlmReranking = true">ON</button>
                                    <button class="toggle-btn @(!_ragLlmReranking ? "toggle-active" : "")"
                                            @onclick="() => _ragLlmReranking = false">OFF</button>
                                </div>
                            </div>
                            <div class="policy-item">
                                <span class="policy-name">Graph Lookup (지식 그래프 탐색)</span>
                                <div class="search-mode-toggle">
                                    <button class="toggle-btn @(_ragGraphLookup ? "toggle-active" : "")"
                                            @onclick="() => _ragGraphLookup = true">ON</button>
                                    <button class="toggle-btn @(!_ragGraphLookup ? "toggle-active" : "")"
                                            @onclick="() => _ragGraphLookup = false">OFF</button>
                                </div>
                            </div>
                            <div class="policy-item">
                                <span class="policy-name">Hybrid Search (벡터+BM25 융합)</span>
                                <div class="search-mode-toggle">
                                    <button class="toggle-btn @(_ragHybridSearch ? "toggle-active" : "")"
                                            @onclick="() => _ragHybridSearch = true">ON</button>
                                    <button class="toggle-btn @(!_ragHybridSearch ? "toggle-active" : "")"
                                            @onclick="() => _ragHybridSearch = false">OFF</button>
                                </div>
                            </div>
                            <div class="policy-item">
                                <span class="policy-name">MMR (다양성 선택)</span>
                                <div class="search-mode-toggle">
                                    <button class="toggle-btn @(_ragMmr ? "toggle-active" : "")"
                                            @onclick="() => _ragMmr = true">ON</button>
                                    <button class="toggle-btn @(!_ragMmr ? "toggle-active" : "")"
                                            @onclick="() => _ragMmr = false">OFF</button>
                                </div>
                            </div>
                            <div class="policy-item">
                                <span class="policy-name">RAG Cache (결과 캐시)</span>
                                <div class="search-mode-toggle">
                                    <button class="toggle-btn @(_ragCache ? "toggle-active" : "")"
                                            @onclick="() => _ragCache = true">ON</button>
                                    <button class="toggle-btn @(!_ragCache ? "toggle-active" : "")"
                                            @onclick="() => _ragCache = false">OFF</button>
                                </div>
                            </div>
                        </div>
                        @if (_ragToggleChanged)
                        {
                            <div class="config-warning">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                                RAG 설정 변경 시 RagService 재시작이 필요합니다
                            </div>
                        }
                    </div>

                    <!-- Response Policy (read-only) -->
                    <div class="config-section">
                        <label class="config-label">Response Policy</label>
                        <div class="policy-grid">
                            <div class="policy-item">
                                <span class="policy-name">Gate A (Relevance Threshold)</span>
                                <span class="policy-value">0.55</span>
                            </div>
                            <div class="policy-item">
                                <span class="policy-name">Gate B (Faithfulness)</span>
                                <span class="policy-badge badge-on">활성</span>
                            </div>
                            <div class="policy-item">
                                <span class="policy-name">Gate C (Safety)</span>
                                <span class="policy-badge badge-on">활성</span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="settings-footer">
                    @if (!string.IsNullOrEmpty(_serverStatus))
                    {
                        <span class="settings-status @(_serverStatusIsError ? "status-error" : "status-success")">@_serverStatus</span>
                    }
                    <button class="btn-primary-sm" @onclick="ApplyServerSettings">적용</button>
                </div>
            </div>

            <!-- Update History Button -->
            <div style="text-align:center;">
                <button class="btn-secondary-sm" @onclick="() => _historyOpen = true">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                    업데이트 히스토리
                </button>
            </div>
        }

    </div>
</div>

@* ───── Update History Modal ───── *@
@if (_historyOpen)
{
    <div class="changelog-overlay" @onclick="() => _historyOpen = false">
        <div class="changelog-modal" @onclick:stopPropagation="true">
            <div class="changelog-modal-header">
                <h2 class="changelog-modal-title">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                    업데이트 히스토리
                </h2>
                <button class="changelog-modal-close" @onclick="() => _historyOpen = false">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                </button>
            </div>
            <div class="changelog-modal-body">
                @foreach (var ver in Changelog)
                {
                    <div class="changelog-entry">
                        <div class="changelog-header-row">
                            <span class="changelog-version">@ver.Version</span>
                            <span class="changelog-date">@ver.Date</span>
                        </div>
                        <ul class="changelog-items">
                            @foreach (var item in ver.Items)
                            {
                                <li>@item</li>
                            }
                        </ul>
                    </div>
                }
            </div>
        </div>
    </div>
}

@code {
    // ─── Auth state ──────────────────────────────────────────────
    private bool _isAuthenticated;
    private string _passwordInput = string.Empty;
    private bool _authError;

    // ─── Update history modal ─────────────────────────────────
    private bool _historyOpen;

    private record ChangelogEntry(string Version, string Date, string[] Items);

    private static readonly ChangelogEntry[] Changelog =
    [
        new("v1.9.0", "2025-02-27", [
            "듀얼 STT 엔진 지원 (Whisper + Web Speech API)",
            "음성 인식 엔진 자동 감지 및 수동 전환",
            "실시간 interim 인식 결과 표시",
            "녹음 타이머 및 도메인 프롬프트 바이어싱",
            "JIT / Fade / Batch 스트리밍 렌더링 모드"
        ]),
        new("v1.8.0", "2025-02-20", [
            "E2E 통합 테스트 프로젝트 (15개 WebSocket 테스트)",
            "대화 삭제 기능",
            "Settings 네비게이션 버그 수정"
        ]),
        new("v1.7.0", "2025-02-10", [
            "100개 문서 참조 테스트 추가",
            "RAG 파이프라인 토글 UI (Query Rewriting, LLM Reranking 등)",
            "Query Rewriting 기본 활성화"
        ]),
        new("v1.6.0", "2025-02-01", [
            "멀티클라이언트 WebSocket 라우팅 수정",
            "스트리밍 안정화 (truncation, stale stream 감지)",
            "크로스 브라우저 LaTeX 렌더링 수정"
        ]),
        new("v1.5.0", "2025-01-28", [
            "LaTeX/KaTeX 수학 수식 렌더링",
            "코드 블록 구문 강조 (highlight.js)",
            "Erlang 구문 강조 지원",
            "코드 폰트 설정 (Cascadia Code 등)"
        ]),
        new("v1.4.0", "2025-01-25", [
            "Graph RAG: 지식 그래프 양방향 탐색",
            "배치 엔티티 추출 및 그래프 관리 API",
            "그래프 컨텍스트 Advanced 파이프라인 통합"
        ]),
        new("v1.3.0", "2025-01-22", [
            "HuggingFace TGI Chat Provider 전환 (Ollama ↔ TGI)",
            "인용 텍스트 마크다운 렌더링",
            "PDF 인용 뷰어 패널"
        ]),
        new("v1.2.0", "2025-01-20", [
            "설정 페이지 분리 (클라이언트/서버)",
            "Tailscale VPN 외부 접속 스크립트",
            "Gate C (Safety), Gate B (Faithfulness) 강화",
            "Intent Routing 및 폴더 태그"
        ]),
        new("v1.1.0", "2025-01-18", [
            "Embedding Provider 전환 (Ollama/TEI)",
            "설정 모달 UI",
            "snowflake-arctic-embed2 임베딩 모델"
        ]),
        new("v1.0.0", "2025-01-15", [
            "초기 릴리스",
            "WebSocket 실시간 채팅 (NATS 메시지 브로커)",
            "RAG 파이프라인 (Qdrant 벡터 검색)",
            "Ollama LLM 스트리밍 응답",
            "Redis 대화 기록 저장",
            "Blazor Server 웹 클라이언트"
        ])
    ];

    // ─── Server settings ─────────────────────────────────────────
    private string _selectedModelId = string.Empty;
    private string _selectedModelIdOriginal = string.Empty;
    private bool _modelChanged => _selectedModelId != _selectedModelIdOriginal;
    private string _searchMode = "hybrid";
    private string _searchModeOriginal = "hybrid";
    private bool _searchModeChanged => _searchMode != _searchModeOriginal;
    private string _llmProvider = "Ollama";
    private string _llmProviderOriginal = "Ollama";
    private bool _llmProviderChanged => _llmProvider != _llmProviderOriginal;
    private string _embeddingProvider = "Ollama";
    private string _embeddingProviderOriginal = "Ollama";
    private bool _embeddingProviderChanged => _embeddingProvider != _embeddingProviderOriginal;
    private List<ModelEntry> _availableModels = new();
    private string? _serverStatus;
    private bool _serverStatusIsError;

    // ─── Dual Index state ─────────────────────────────────────────
    private DualIndexStatusDto? _dualIndexStatus;
    private bool _dualIndexLoading;
    private string? _dualIndexMessage;
    private bool _dualIndexIsError;
    private string _prepareModelId = string.Empty;
    private int _prepareVectorSize = 1024;
    private string _rollbackModelId = string.Empty;
    private bool _showRollbackInput;

    private sealed class DualIndexStatusDto
    {
        public string ActiveCollection { get; set; } = "";
        public string? StandbyCollection { get; set; }
        public string ActiveModelId { get; set; } = "";
        public string? StandbyModelId { get; set; }
    }

    // ─── RAG pipeline toggles ────────────────────────────────────
    private bool _ragQueryRewriting;
    private bool _ragLlmReranking;
    private bool _ragGraphLookup;
    private bool _ragHybridSearch;
    private bool _ragMmr;
    private bool _ragCache;
    private bool _ragQueryRewritingOrig;
    private bool _ragLlmRerankingOrig;
    private bool _ragGraphLookupOrig;
    private bool _ragHybridSearchOrig;
    private bool _ragMmrOrig;
    private bool _ragCacheOrig;
    private bool _ragToggleChanged =>
        _ragQueryRewriting != _ragQueryRewritingOrig ||
        _ragLlmReranking != _ragLlmRerankingOrig ||
        _ragGraphLookup != _ragGraphLookupOrig ||
        _ragHybridSearch != _ragHybridSearchOrig ||
        _ragMmr != _ragMmrOrig ||
        _ragCache != _ragCacheOrig;

    protected override void OnInitialized()
    {
        var opts = ModelOptionsAccessor.Value;
        _availableModels = opts.Available;

        // Load persisted model (from LlmService config), fall back to WebClient default
        var persistedModel = EmbeddingConfigService.GetCurrentLlmModel();
        _selectedModelId = !string.IsNullOrEmpty(persistedModel)
            ? persistedModel
            : (!string.IsNullOrEmpty(opts.Default) ? opts.Default : _availableModels.FirstOrDefault()?.Id ?? "");
        _selectedModelIdOriginal = _selectedModelId;

        _searchMode = EmbeddingConfigService.GetCurrentSearchMode();
        _searchModeOriginal = _searchMode;

        _llmProvider = EmbeddingConfigService.GetCurrentLlmProvider();
        _llmProviderOriginal = _llmProvider;

        _embeddingProvider = EmbeddingConfigService.GetCurrentProvider();
        _embeddingProviderOriginal = _embeddingProvider;

        LoadRagToggles();
    }

    private void LoadRagToggles()
    {
        var toggles = EmbeddingConfigService.GetRagToggles();
        _ragQueryRewriting = toggles["EnableQueryRewriting"];
        _ragLlmReranking = toggles["EnableLlmReranking"];
        _ragGraphLookup = toggles["EnableGraphLookup"];
        _ragHybridSearch = toggles["EnableHybridSearch"];
        _ragMmr = toggles["EnableMmr"];
        _ragCache = toggles["EnableRagCache"];
        _ragQueryRewritingOrig = _ragQueryRewriting;
        _ragLlmRerankingOrig = _ragLlmReranking;
        _ragGraphLookupOrig = _ragGraphLookup;
        _ragHybridSearchOrig = _ragHybridSearch;
        _ragMmrOrig = _ragMmr;
        _ragCacheOrig = _ragCache;
    }

    private void Authenticate()
    {
        if (_passwordInput == AdminOpts.Value.Password)
        {
            _isAuthenticated = true;
            _authError = false;
            _passwordInput = string.Empty;
        }
        else
        {
            _authError = true;
        }
    }

    private void Logout()
    {
        _isAuthenticated = false;
        _passwordInput = string.Empty;
        _authError = false;
    }

    private void ApplyServerSettings()
    {
        try
        {
            if (_modelChanged)
            {
                EmbeddingConfigService.SetLlmModel(_selectedModelId);
                _selectedModelIdOriginal = _selectedModelId;
            }

            if (_searchModeChanged)
            {
                EmbeddingConfigService.SetSearchMode(_searchMode);
                _searchModeOriginal = _searchMode;
            }

            if (_llmProviderChanged)
            {
                EmbeddingConfigService.SetLlmProvider(_llmProvider);
                _llmProviderOriginal = _llmProvider;
            }

            if (_embeddingProviderChanged)
            {
                EmbeddingConfigService.SetProvider(_embeddingProvider);
                _embeddingProviderOriginal = _embeddingProvider;
            }

            if (_ragToggleChanged)
            {
                EmbeddingConfigService.SetRagToggles(new Dictionary<string, bool>
                {
                    ["EnableQueryRewriting"] = _ragQueryRewriting,
                    ["EnableLlmReranking"] = _ragLlmReranking,
                    ["EnableGraphLookup"] = _ragGraphLookup,
                    ["EnableHybridSearch"] = _ragHybridSearch,
                    ["EnableMmr"] = _ragMmr,
                    ["EnableRagCache"] = _ragCache,
                });
                _ragQueryRewritingOrig = _ragQueryRewriting;
                _ragLlmRerankingOrig = _ragLlmReranking;
                _ragGraphLookupOrig = _ragGraphLookup;
                _ragHybridSearchOrig = _ragHybridSearch;
                _ragMmrOrig = _ragMmr;
                _ragCacheOrig = _ragCache;
            }

            var restartNeeded = _llmProviderChanged || _embeddingProviderChanged || _modelChanged;
            _serverStatus = restartNeeded
                ? "서버 설정이 적용되었습니다. Provider/모델 변경은 서비스 재시작 후 반영됩니다."
                : "서버 설정이 적용되었습니다.";
            _serverStatusIsError = false;
        }
        catch (Exception ex)
        {
            _serverStatus = $"적용 실패: {ex.Message}";
            _serverStatusIsError = true;
        }
    }

    // ─── Dual Index API calls ────────────────────────────────────

    private const string KnowledgeServiceBase = "http://localhost:5002";
    private static readonly HttpClient DualIndexHttp = new() { BaseAddress = new Uri(KnowledgeServiceBase) };

    private async Task RefreshDualIndexStatus()
    {
        _dualIndexLoading = true;
        _dualIndexMessage = null;
        StateHasChanged();

        try
        {
            var status = await DualIndexHttp.GetFromJsonAsync<DualIndexStatusDto>("/api/dual-index/status");
            _dualIndexStatus = status;
        }
        catch (Exception ex)
        {
            _dualIndexMessage = $"상태 조회 실패: {ex.Message}";
            _dualIndexIsError = true;
        }
        finally
        {
            _dualIndexLoading = false;
            StateHasChanged();
        }
    }

    private async Task PrepareStandby()
    {
        if (string.IsNullOrWhiteSpace(_prepareModelId))
        {
            _dualIndexMessage = "Model ID를 입력하세요";
            _dualIndexIsError = true;
            return;
        }

        _dualIndexLoading = true;
        _dualIndexMessage = null;
        StateHasChanged();

        try
        {
            var body = new { modelId = _prepareModelId, vectorSize = _prepareVectorSize };
            var response = await DualIndexHttp.PostAsJsonAsync("/api/dual-index/prepare", body);
            response.EnsureSuccessStatusCode();

            _dualIndexMessage = $"Standby 컬렉션 준비 완료 (model: {_prepareModelId}, dim: {_prepareVectorSize})";
            _dualIndexIsError = false;
            _prepareModelId = string.Empty;

            await RefreshDualIndexStatus();
        }
        catch (Exception ex)
        {
            _dualIndexMessage = $"Standby 준비 실패: {ex.Message}";
            _dualIndexIsError = true;
            _dualIndexLoading = false;
            StateHasChanged();
        }
    }

    private async Task PromoteStandby()
    {
        _dualIndexLoading = true;
        _dualIndexMessage = null;
        StateHasChanged();

        try
        {
            var response = await DualIndexHttp.PostAsync("/api/dual-index/promote", null);
            if (!response.IsSuccessStatusCode)
            {
                var error = await response.Content.ReadAsStringAsync();
                _dualIndexMessage = $"승격 실패: {error}";
                _dualIndexIsError = true;
            }
            else
            {
                _dualIndexMessage = "Standby → Active 승격 완료";
                _dualIndexIsError = false;
            }

            await RefreshDualIndexStatus();
        }
        catch (Exception ex)
        {
            _dualIndexMessage = $"승격 실패: {ex.Message}";
            _dualIndexIsError = true;
            _dualIndexLoading = false;
            StateHasChanged();
        }
    }

    private async Task RollbackIndex()
    {
        if (string.IsNullOrWhiteSpace(_rollbackModelId))
        {
            _dualIndexMessage = "Previous Model ID를 입력하세요";
            _dualIndexIsError = true;
            return;
        }

        _dualIndexLoading = true;
        _dualIndexMessage = null;
        StateHasChanged();

        try
        {
            var body = new { previousModelId = _rollbackModelId };
            var response = await DualIndexHttp.PostAsJsonAsync("/api/dual-index/rollback", body);
            response.EnsureSuccessStatusCode();

            _dualIndexMessage = $"롤백 완료 (model: {_rollbackModelId})";
            _dualIndexIsError = false;
            _rollbackModelId = string.Empty;
            _showRollbackInput = false;

            await RefreshDualIndexStatus();
        }
        catch (Exception ex)
        {
            _dualIndexMessage = $"롤백 실패: {ex.Message}";
            _dualIndexIsError = true;
            _dualIndexLoading = false;
            StateHasChanged();
        }
    }
}
