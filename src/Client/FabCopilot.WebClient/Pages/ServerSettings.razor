    private void OnTtsProviderChanged()
    {
        _ttsVoiceOptions = TtsVoiceMap.TryGetValue(_ttsProvider, out var voices) ? voices.ToList() : ["default"];
        _ttsVoice = _ttsVoiceOptions.First();
    }

    // ─── RAG pipeline toggles ────────────────────────────────────
    private bool _ragQueryRewriting;
    private bool _ragLlmReranking;
    private bool _ragGraphLookup;
    private bool _ragHybridSearch;
    private bool _ragMmr;
    private bool _ragCache;
    private bool _ragQueryRewritingOrig;
    private bool _ragLlmRerankingOrig;
    private bool _ragGraphLookupOrig;
    private bool _ragHybridSearchOrig;
    private bool _ragMmrOrig;
    private bool _ragCacheOrig;
    private bool _ragToggleChanged =>
        _ragQueryRewriting != _ragQueryRewritingOrig ||
        _ragLlmReranking != _ragLlmRerankingOrig ||
        _ragGraphLookup != _ragGraphLookupOrig ||
        _ragHybridSearch != _ragHybridSearchOrig ||
        _ragMmr != _ragMmrOrig ||
        _ragCache != _ragCacheOrig;

    protected override void OnInitialized()
    {
        var knowledgeBaseUrl = Configuration["KnowledgeService:BaseUrl"] ?? "http://localhost:5002";
        _dualIndexHttp = new HttpClient { BaseAddress = new Uri(knowledgeBaseUrl) };

        var opts = ModelOptionsAccessor.Value;
        _availableModels = opts.Available;

        // Load persisted model (from LlmService config), fall back to WebClient default
        var persistedModel = EmbeddingConfigService.GetCurrentLlmModel();
        _selectedModelId = !string.IsNullOrEmpty(persistedModel)
            ? persistedModel
            : (!string.IsNullOrEmpty(opts.Default) ? opts.Default : _availableModels.FirstOrDefault()?.Id ?? "");
        _selectedModelIdOriginal = _selectedModelId;

        _searchMode = EmbeddingConfigService.GetCurrentSearchMode();
        _searchModeOriginal = _searchMode;

        _llmProvider = EmbeddingConfigService.GetCurrentLlmProvider();
        _llmProviderOriginal = _llmProvider;

        _embeddingProvider = EmbeddingConfigService.GetCurrentProvider();
        _embeddingProviderOriginal = _embeddingProvider;

        // Load TTS config
        var (ttsProvider, ttsVoice, _) = EmbeddingConfigService.GetCurrentTtsConfig();
        _ttsProvider = ttsProvider;
        _ttsProviderOriginal = ttsProvider;
        _ttsVoice = ttsVoice;
        _ttsVoiceOriginal = ttsVoice;
        _ttsVoiceOptions = TtsVoiceMap.TryGetValue(_ttsProvider, out var ttsVoices) ? ttsVoices.ToList() : ["default"];

        LoadRagToggles();
    }

    protected override Task OnAfterRenderAsync(bool firstRender) => Task.CompletedTask;

    private void LoadRagToggles()
    {
        var toggles = EmbeddingConfigService.GetRagToggles();
        _ragQueryRewriting = toggles["EnableQueryRewriting"];
        _ragLlmReranking = toggles["EnableLlmReranking"];
        _ragGraphLookup = toggles["EnableGraphLookup"];
        _ragHybridSearch = toggles["EnableHybridSearch"];
        _ragMmr = toggles["EnableMmr"];
        _ragCache = toggles["EnableRagCache"];
        _ragQueryRewritingOrig = _ragQueryRewriting;
        _ragLlmRerankingOrig = _ragLlmReranking;
        _ragGraphLookupOrig = _ragGraphLookup;
        _ragHybridSearchOrig = _ragHybridSearch;
        _ragMmrOrig = _ragMmr;
        _ragCacheOrig = _ragCache;
    }

    private void Authenticate()
    {
        if (_passwordInput == AdminOpts.Value.Password)
        {
            _isAuthenticated = true;
            _authError = false;
            _passwordInput = string.Empty;
        }
        else
        {
            _authError = true;
        }
    }

    private void Logout()
    {
        _isAuthenticated = false;
        _passwordInput = string.Empty;
        _authError = false;
    }

    private async Task ApplyServerSettings()
    {
        try
        {
            if (_modelChanged)
            {
                EmbeddingConfigService.SetLlmModel(_selectedModelId);
                _selectedModelIdOriginal = _selectedModelId;
            }

            if (_searchModeChanged)
            {
                EmbeddingConfigService.SetSearchMode(_searchMode);
                _searchModeOriginal = _searchMode;
            }

            if (_llmProviderChanged)
            {
                EmbeddingConfigService.SetLlmProvider(_llmProvider);
                _llmProviderOriginal = _llmProvider;
            }

            if (_embeddingProviderChanged)
            {
                EmbeddingConfigService.SetProvider(_embeddingProvider);
                _embeddingProviderOriginal = _embeddingProvider;
            }

            if (_ragToggleChanged)
            {
                EmbeddingConfigService.SetRagToggles(new Dictionary<string, bool>
                {
                    ["EnableQueryRewriting"] = _ragQueryRewriting,
                    ["EnableLlmReranking"] = _ragLlmReranking,
                    ["EnableGraphLookup"] = _ragGraphLookup,
                    ["EnableHybridSearch"] = _ragHybridSearch,
                    ["EnableMmr"] = _ragMmr,
                    ["EnableRagCache"] = _ragCache,
                });
                _ragQueryRewritingOrig = _ragQueryRewriting;
                _ragLlmRerankingOrig = _ragLlmReranking;
                _ragGraphLookupOrig = _ragGraphLookup;
                _ragHybridSearchOrig = _ragHybridSearch;
                _ragMmrOrig = _ragMmr;
                _ragCacheOrig = _ragCache;
            }

            if (_ttsProviderChanged)
            {
                EmbeddingConfigService.SetTtsProvider(_ttsProvider, _ttsVoice);
                _ttsProviderOriginal = _ttsProvider;
                _ttsVoiceOriginal = _ttsVoice;
            }

            var restartNeeded = _llmProviderChanged || _embeddingProviderChanged || _modelChanged;
            _serverStatus = restartNeeded
                ? "서버 설정이 적용되었습니다. Provider/모델 변경은 서비스 재시작 후 반영됩니다."
                : "서버 설정이 적용되었습니다.";
            _serverStatusIsError = false;
        }
        catch (Exception ex)
        {
            _serverStatus = $"적용 실패: {ex.Message}";
            _serverStatusIsError = true;
        }
    }

    // ─── Dual Index API calls ────────────────────────────────────

    private HttpClient? _dualIndexHttp;

    private async Task RefreshDualIndexStatus()
    {
        _dualIndexLoading = true;
        _dualIndexMessage = null;
        StateHasChanged();

        try
        {
            var status = await _dualIndexHttp!.GetFromJsonAsync<DualIndexStatusDto>("/api/dual-index/status");
            _dualIndexStatus = status;
        }
        catch (Exception ex)
        {
            _dualIndexMessage = $"상태 조회 실패: {ex.Message}";
            _dualIndexIsError = true;
        }
        finally
        {
            _dualIndexLoading = false;
            StateHasChanged();
        }
    }

    private async Task PrepareStandby()
    {
        if (string.IsNullOrWhiteSpace(_prepareModelId))
        {
            _dualIndexMessage = "Model ID를 입력하세요";
            _dualIndexIsError = true;
            return;
        }

        _dualIndexLoading = true;
        _dualIndexMessage = null;
        StateHasChanged();

        try
        {
            var body = new { modelId = _prepareModelId, vectorSize = _prepareVectorSize };
            var response = await _dualIndexHttp!.PostAsJsonAsync("/api/dual-index/prepare", body);
            response.EnsureSuccessStatusCode();

            _dualIndexMessage = $"Standby 컬렉션 준비 완료 (model: {_prepareModelId}, dim: {_prepareVectorSize})";
            _dualIndexIsError = false;
            _prepareModelId = string.Empty;

            await RefreshDualIndexStatus();
        }
        catch (Exception ex)
        {
            _dualIndexMessage = $"Standby 준비 실패: {ex.Message}";
            _dualIndexIsError = true;
            _dualIndexLoading = false;
            StateHasChanged();
        }
    }

    private async Task PromoteStandby()
    {
        _dualIndexLoading = true;
        _dualIndexMessage = null;
        StateHasChanged();

        try
        {
            var response = await _dualIndexHttp!.PostAsync("/api/dual-index/promote", null);
            if (!response.IsSuccessStatusCode)
            {
                var error = await response.Content.ReadAsStringAsync();
                _dualIndexMessage = $"승격 실패: {error}";
                _dualIndexIsError = true;
            }
            else
            {
                _dualIndexMessage = "Standby → Active 승격 완료";
                _dualIndexIsError = false;
            }

            await RefreshDualIndexStatus();
        }
        catch (Exception ex)
        {
            _dualIndexMessage = $"승격 실패: {ex.Message}";
            _dualIndexIsError = true;
            _dualIndexLoading = false;
            StateHasChanged();
        }
    }

    private async Task RollbackIndex()
    {
        if (string.IsNullOrWhiteSpace(_rollbackModelId))
        {
            _dualIndexMessage = "Previous Model ID를 입력하세요";
            _dualIndexIsError = true;
            return;
        }

        _dualIndexLoading = true;
        _dualIndexMessage = null;
        StateHasChanged();

        try
        {
            var body = new { previousModelId = _rollbackModelId };
            var response = await _dualIndexHttp!.PostAsJsonAsync("/api/dual-index/rollback", body);
            response.EnsureSuccessStatusCode();

            _dualIndexMessage = $"롤백 완료 (model: {_rollbackModelId})";
            _dualIndexIsError = false;
            _rollbackModelId = string.Empty;
            _showRollbackInput = false;

            await RefreshDualIndexStatus();
        }
        catch (Exception ex)
        {
            _dualIndexMessage = $"롤백 실패: {ex.Message}";
            _dualIndexIsError = true;
            _dualIndexLoading = false;
            StateHasChanged();
        }
    }
}
