    // ─── Server settings ─────────────────────────────────────────
    private string _selectedModelId = string.Empty;
    private string _selectedModelIdOriginal = string.Empty;
    private bool _modelChanged => _selectedModelId != _selectedModelIdOriginal;
    private string _searchMode = "hybrid";
    private string _searchModeOriginal = "hybrid";
    private bool _searchModeChanged => _searchMode != _searchModeOriginal;
    private string _llmProvider = "Ollama";
    private string _llmProviderOriginal = "Ollama";
    private bool _llmProviderChanged => _llmProvider != _llmProviderOriginal;
    private string _embeddingProvider = "Ollama";
    private string _embeddingProviderOriginal = "Ollama";
    private bool _embeddingProviderChanged => _embeddingProvider != _embeddingProviderOriginal;
    private List<ModelEntry> _availableModels = new();
    private string? _serverStatus;
    private bool _serverStatusIsError;

    // ─── Dual Index state ─────────────────────────────────────────
    private DualIndexStatusDto? _dualIndexStatus;
    private bool _dualIndexLoading;
    private string? _dualIndexMessage;
    private bool _dualIndexIsError;
    private string _prepareModelId = string.Empty;
    private int _prepareVectorSize = 1024;
    private string _rollbackModelId = string.Empty;
    private bool _showRollbackInput;

    private sealed class DualIndexStatusDto
    {
        public string ActiveCollection { get; set; } = "";
        public string? StandbyCollection { get; set; }
        public string ActiveModelId { get; set; } = "";
        public string? StandbyModelId { get; set; }
    }

    // ─── TTS settings ───────────────────────────────────────────
    private string _ttsProvider = "EdgeTts";
    private string _ttsProviderOriginal = "EdgeTts";
    private string _ttsVoice = "ko-KR-SunHiNeural";
    private string _ttsVoiceOriginal = "ko-KR-SunHiNeural";
    private bool _ttsProviderChanged => _ttsProvider != _ttsProviderOriginal || _ttsVoice != _ttsVoiceOriginal;
    private List<string> _ttsVoiceOptions = new();

    private static readonly Dictionary<string, string[]> TtsVoiceMap = new()
    {
        ["Kokoro"] = ["af_heart", "af_sky", "af_bella", "am_adam", "am_michael", "bf_emma", "bm_george", "bf_isabella"],
        ["CosyVoice"] = ["korean_female", "korean_male", "chinese_female", "chinese_male", "english_female", "english_male"],
        ["Orpheus"] = ["tara", "leah", "jess", "leo", "dan", "mia", "zac", "zoe"],
        ["EdgeTts"] = ["ko-KR-SunHiNeural", "ko-KR-InJoonNeural", "en-US-JennyNeural", "en-US-GuyNeural", "ja-JP-NanamiNeural"],
        ["Piper"] = ["ko_KR-kss-low", "en_US-lessac-medium", "en_US-amy-medium", "en_GB-alba-medium"],
        ["FishSpeech"] = ["default"],
