@page "/settings"
@inject NavigationManager Navigation
@inject IJSRuntime JS

<div class="settings-page">
    <div class="settings-container">

        <!-- ===== Navigation Bar ===== -->
        <div style="display:flex; justify-content:flex-end;">
            <button class="btn-secondary-sm" @onclick='() => Navigation.NavigateTo("/")'>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
                채팅으로
            </button>
        </div>

        <!-- ═══════════════════════════════════════════════════════════
             CLIENT SETTINGS CARD
             ═══════════════════════════════════════════════════════════ -->
        <div class="settings-card">
            <div class="settings-header">
                <h1 class="settings-title">
                    <span class="settings-title-icon">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
                        클라이언트 설정
                    </span>
                </h1>
                <span class="config-hint" style="margin:0">브라우저 로컬 저장, 재시작 불필요</span>
            </div>

            <div class="settings-body">
                <!-- Code Font -->
                <div class="config-section">
                    <label class="config-label">코드 폰트</label>
                    <select class="config-select" @bind="_codeFont">
                        <option value="Cascadia Code">Cascadia Code</option>
                        <option value="Fira Code">Fira Code</option>
                        <option value="Consolas">Consolas</option>
                        <option value="JetBrains Mono">JetBrains Mono</option>
                        <option value="D2Coding">D2Coding</option>
                    </select>
                    <span class="config-hint">코드 블록에 사용할 폰트 (로컬 설치 필요)</span>
                </div>

                <!-- STT Engine -->
                <div class="config-section">
                    <label class="config-label">음성 인식 엔진</label>
                    <select class="config-select" @bind="_sttEngine">
                        <option value="auto">자동 감지</option>
                        <option value="whisper">Whisper (On-Premise)</option>
                        <option value="webspeech">Web Speech API</option>
                    </select>
                    <span class="config-hint">자동 감지: Whisper 서버 가용 시 우선 사용, 실패 시 Web Speech API fallback</span>
                </div>

                <!-- Render Mode -->
                <div class="config-section">
                    <label class="config-label">스트리밍 렌더링</label>
                    <select class="config-select" @bind="_renderMode">
                        <option value="jit">JIT 렌더링 (마크다운 실시간)</option>
                        <option value="fade">Fade 전환 (완료 후 렌더링)</option>
                        <option value="batch">한꺼번에 (완료까지 숨김)</option>
                    </select>
                    <span class="config-hint">JIT: 스트리밍 중 마크다운/코드 포맷 실시간 표시, 수식은 완료 후 렌더링</span>
                </div>
            </div>

            <div class="settings-footer">
                @if (!string.IsNullOrEmpty(_clientStatus))
                {
                    <span class="settings-status @(_clientStatusIsError ? "status-error" : "status-success")">@_clientStatus</span>
                }
                <button class="btn-primary-sm" @onclick="ApplyClientSettings">적용</button>
            </div>
        </div>

        <!-- ═══════════════════════════════════════════════════════════
             UPDATE HISTORY CARD
             ═══════════════════════════════════════════════════════════ -->
        <div class="settings-card">
            <div class="settings-header" style="cursor:pointer" @onclick="() => _historyOpen = !_historyOpen">
                <h1 class="settings-title">
                    <span class="settings-title-icon">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                        업데이트 히스토리
                    </span>
                </h1>
                <span class="changelog-toggle">@(_historyOpen ? "▼" : "▶")</span>
            </div>
            @if (_historyOpen)
            {
                <div class="settings-body changelog-body">
                    @foreach (var ver in Changelog)
                    {
                        <div class="changelog-entry">
                            <div class="changelog-header-row">
                                <span class="changelog-version">@ver.Version</span>
                                <span class="changelog-date">@ver.Date</span>
                            </div>
                            <ul class="changelog-items">
                                @foreach (var item in ver.Items)
                                {
                                    <li>@item</li>
                                }
                            </ul>
                        </div>
                    }
                </div>
            }
        </div>

        <!-- ===== Server Settings Link ===== -->
        <div style="text-align:center;">
            <button class="btn-secondary-sm" @onclick='() => Navigation.NavigateTo("/server/settings")'>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="8" rx="2" ry="2"/><rect x="2" y="14" width="20" height="8" rx="2" ry="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/></svg>
                서버 설정으로
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </button>
        </div>

    </div>
</div>

@code {
    private string _codeFont = "Cascadia Code";
    private string _sttEngine = "auto";
    private string _renderMode = "jit";
    private string? _clientStatus;
    private bool _clientStatusIsError;
    private bool _historyOpen;

    private record ChangelogEntry(string Version, string Date, string[] Items);

    private static readonly ChangelogEntry[] Changelog =
    [
        new("v1.9.0", "2025-02-27", [
            "듀얼 STT 엔진 지원 (Whisper + Web Speech API)",
            "음성 인식 엔진 자동 감지 및 수동 전환",
            "실시간 interim 인식 결과 표시",
            "녹음 타이머 및 도메인 프롬프트 바이어싱",
            "업데이트 히스토리 패널 추가"
        ]),
        new("v1.8.0", "2025-02-20", [
            "E2E 통합 테스트 프로젝트 (15개 WebSocket 테스트)",
            "대화 삭제 기능",
            "Settings 네비게이션 버그 수정"
        ]),
        new("v1.7.0", "2025-02-10", [
            "100개 문서 참조 테스트 추가",
            "RAG 파이프라인 토글 UI (Query Rewriting, LLM Reranking 등)",
            "Query Rewriting 기본 활성화"
        ]),
        new("v1.6.0", "2025-02-01", [
            "멀티클라이언트 WebSocket 라우팅 수정",
            "스트리밍 안정화 (truncation, stale stream 감지)",
            "크로스 브라우저 LaTeX 렌더링 수정"
        ]),
        new("v1.5.0", "2025-01-28", [
            "LaTeX/KaTeX 수학 수식 렌더링",
            "코드 블록 구문 강조 (highlight.js)",
            "Erlang 구문 강조 지원",
            "코드 폰트 설정 (Cascadia Code 등)"
        ]),
        new("v1.4.0", "2025-01-25", [
            "Graph RAG: 지식 그래프 양방향 탐색",
            "배치 엔티티 추출 및 그래프 관리 API",
            "그래프 컨텍스트 Advanced 파이프라인 통합"
        ]),
        new("v1.3.0", "2025-01-22", [
            "HuggingFace TGI Chat Provider 전환 (Ollama ↔ TGI)",
            "인용 텍스트 마크다운 렌더링",
            "PDF 인용 뷰어 패널"
        ]),
        new("v1.2.0", "2025-01-20", [
            "설정 페이지 분리 (클라이언트/서버)",
            "Tailscale VPN 외부 접속 스크립트",
            "Gate C (Safety), Gate B (Faithfulness) 강화",
            "Intent Routing 및 폴더 태그"
        ]),
        new("v1.1.0", "2025-01-18", [
            "Embedding Provider 전환 (Ollama/TEI)",
            "설정 모달 UI",
            "snowflake-arctic-embed2 임베딩 모델"
        ]),
        new("v1.0.0", "2025-01-15", [
            "초기 릴리스",
            "WebSocket 실시간 채팅 (NATS 메시지 브로커)",
            "RAG 파이프라인 (Qdrant 벡터 검색)",
            "Ollama LLM 스트리밍 응답",
            "Redis 대화 기록 저장",
            "Blazor Server 웹 클라이언트"
        ])
    ];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var saved = await JS.InvokeAsync<string>("clientSettings.getCodeFont");
                if (!string.IsNullOrEmpty(saved))
                    _codeFont = saved;

                var savedStt = await JS.InvokeAsync<string>("clientSettings.getSttEngine");
                if (!string.IsNullOrEmpty(savedStt))
                    _sttEngine = savedStt;

                var savedRender = await JS.InvokeAsync<string>("clientSettings.getRenderMode");
                if (!string.IsNullOrEmpty(savedRender))
                    _renderMode = savedRender;

                StateHasChanged();
            }
            catch { }
        }
    }

    private async Task ApplyClientSettings()
    {
        try
        {
            await JS.InvokeVoidAsync("clientSettings.setCodeFont", _codeFont);
            await JS.InvokeVoidAsync("clientSettings.setSttEngine", _sttEngine);
            await JS.InvokeVoidAsync("clientSettings.setRenderMode", _renderMode);
            _clientStatus = "클라이언트 설정이 적용되었습니다.";
            _clientStatusIsError = false;
        }
        catch (Exception ex)
        {
            _clientStatus = $"적용 실패: {ex.Message}";
            _clientStatusIsError = true;
        }
    }
}
