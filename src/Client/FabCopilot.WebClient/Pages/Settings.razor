@page "/settings"
@inject NavigationManager Navigation
@inject IJSRuntime JS

<div class="chat-app">
    <!-- ===== Panel Tab Bar ===== -->
    <div class="panel-tabs">
        <button class="panel-tab" @onclick='() => Navigation.NavigateTo("/")'>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="4" x2="21" y2="4"/><line x1="6" y1="10" x2="21" y2="10"/><line x1="6" y1="16" x2="21" y2="16"/><circle cx="3" cy="10" r="1" fill="currentColor" stroke="none"/><circle cx="3" cy="16" r="1" fill="currentColor" stroke="none"/></svg>
            <span>목록</span>
        </button>
        <button class="panel-tab" @onclick='() => Navigation.NavigateTo("/")'>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="7" opacity="0.3"/><path d="M12 2 L13.1 8.2 L17.4 4.6 L14.5 10.5 L21 10.3 L15.2 13 L18.8 18.4 L12.8 14.8 L12 22 L11.2 14.8 L5.2 18.4 L8.8 13 L3 10.3 L9.5 10.5 L6.6 4.6 L10.9 8.2 Z"/></svg>
            <span>채팅</span>
        </button>
        <button class="panel-tab" @onclick='() => Navigation.NavigateTo("/")'>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12V7H5a2 2 0 010-4h14v4"/><path d="M3 5v14a2 2 0 002 2h16v-5"/><path d="M18 12a2 2 0 100 4 2 2 0 000-4z"/></svg>
            <span>로그 분석</span>
        </button>
        <button class="panel-tab" @onclick='() => Navigation.NavigateTo("/")'>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
            <span>참고 문서</span>
        </button>
        <button class="panel-tab panel-tab-active">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/></svg>
            <span>설정</span>
        </button>
        <button class="panel-tab" @onclick='() => Navigation.NavigateTo("/server/settings")'>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
            <span>서버</span>
        </button>
        <span class="panel-tabs-version">v4.85.2</span>
    </div>

    <div class="settings-page">
        <div class="settings-container">

        <!-- ═══════════════════════════════════════════════════════════
             CLIENT SETTINGS CARD
             ═══════════════════════════════════════════════════════════ -->
        <div class="settings-card">
            <div class="settings-header">
                <h1 class="settings-title">
                    <span class="settings-title-icon">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
                        클라이언트 설정
                    </span>
                </h1>
                <span class="config-hint" style="margin:0">브라우저 로컬 저장, 재시작 불필요</span>
            </div>

            <div class="settings-body">
                <!-- Code Font -->
                <div class="config-section">
                    <label class="config-label">코드 폰트</label>
                    <select class="config-select" @bind="_codeFont">
                        <option value="Cascadia Code">Cascadia Code</option>
                        <option value="Fira Code">Fira Code</option>
                        <option value="Consolas">Consolas</option>
                        <option value="JetBrains Mono">JetBrains Mono</option>
                        <option value="D2Coding">D2Coding</option>
                    </select>
                    <span class="config-hint">코드 블록에 사용할 폰트 (로컬 설치 필요)</span>
                </div>

                <!-- STT Engine -->
                <div class="config-section">
                    <label class="config-label">음성 인식 엔진</label>
                    <select class="config-select" @bind="_sttEngine">
                        <option value="auto">자동 감지</option>
                        <option value="whisper">Whisper (On-Premise)</option>
                        <option value="webspeech">Web Speech API</option>
                    </select>
                    <span class="config-hint">자동 감지: Whisper 서버 가용 시 우선 사용, 실패 시 Web Speech API fallback</span>
                </div>

                <!-- Render Mode -->
                <div class="config-section">
                    <label class="config-label">스트리밍 렌더링</label>
                    <select class="config-select" @bind="_renderMode">
                        <option value="jit">JIT 렌더링 (마크다운 실시간)</option>
                        <option value="fade">Fade 전환 (완료 후 렌더링)</option>
                        <option value="batch">한꺼번에 (완료까지 숨김)</option>
                    </select>
                    <span class="config-hint">JIT: 스트리밍 중 마크다운/코드 포맷 실시간 표시, 수식은 완료 후 렌더링</span>
                </div>

                <!-- Response Timeout -->
                <div class="config-section">
                    <label class="config-label">응답 타임아웃</label>
                    <select class="config-select" @bind="_timeoutBudget">
                        <option value="30">30초</option>
                        <option value="60">1분</option>
                        <option value="180">3분 (기본)</option>
                        <option value="300">5분</option>
                    </select>
                    <span class="config-hint">응답 생성 시간이 설정값에 도달하면 경고를 표시합니다</span>
                </div>

                <!-- Auto TTS -->
                <div class="config-section">
                    <label class="config-label">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-2px;margin-right:4px"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M19.07 4.93a10 10 0 010 14.14M15.54 8.46a5 5 0 010 7.07"/></svg>
                        자동 TTS
                    </label>
                    <select class="config-select" @bind="_autoTts">
                        <option value="off">끄기</option>
                        <option value="on">켜기</option>
                    </select>
                    <span class="config-hint">응답이 생성되는 동안 문장 단위로 자동 음성 재생</span>
                </div>

                <!-- Debug Mode -->
                <div class="config-section">
                    <label class="config-label">디버그 모드</label>
                    <select class="config-select" @bind="_debugMode">
                        <option value="off">끄기</option>
                        <option value="on">켜기</option>
                    </select>
                    <span class="config-hint">TTS/STT 디버그 오버레이 표시 (개발자용)</span>
                </div>
            </div>

            <div class="settings-footer">
                @if (!string.IsNullOrEmpty(_clientStatus))
                {
                    <span class="settings-status @(_clientStatusIsError ? "status-error" : "status-success")">@_clientStatus</span>
                }
                <button class="btn-primary-sm" @onclick="ApplyClientSettings">적용</button>
            </div>
        </div>

        </div>
    </div>
</div>

@code {
    private string _codeFont = "Cascadia Code";
    private string _sttEngine = "auto";
    private string _renderMode = "jit";
    private string _timeoutBudget = "180";
    private string _autoTts = "on";
    private string _debugMode = "off";
    private string? _clientStatus;
    private bool _clientStatusIsError;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var saved = await JS.InvokeAsync<string>("clientSettings.getCodeFont");
                if (!string.IsNullOrEmpty(saved))
                    _codeFont = saved;

                var savedStt = await JS.InvokeAsync<string>("clientSettings.getSttEngine");
                if (!string.IsNullOrEmpty(savedStt))
                    _sttEngine = savedStt;

                var savedRender = await JS.InvokeAsync<string>("clientSettings.getRenderMode");
                if (!string.IsNullOrEmpty(savedRender))
                    _renderMode = savedRender;

                var savedTimeout = await JS.InvokeAsync<string>("clientSettings.getTimeoutBudget");
                if (!string.IsNullOrEmpty(savedTimeout))
                    _timeoutBudget = savedTimeout;

                var savedAutoTts = await JS.InvokeAsync<string>("clientSettings.getAutoTts");
                if (!string.IsNullOrEmpty(savedAutoTts))
                    _autoTts = savedAutoTts;

                var savedDebug = await JS.InvokeAsync<string>("clientSettings.getDebugMode");
                if (!string.IsNullOrEmpty(savedDebug))
                    _debugMode = savedDebug;

                StateHasChanged();
            }
            catch { }
        }
    }

    private async Task ApplyClientSettings()
    {
        try
        {
            await JS.InvokeVoidAsync("clientSettings.setCodeFont", _codeFont);
            await JS.InvokeVoidAsync("clientSettings.setSttEngine", _sttEngine);
            await JS.InvokeVoidAsync("clientSettings.setRenderMode", _renderMode);
            await JS.InvokeVoidAsync("clientSettings.setTimeoutBudget", _timeoutBudget);
            await JS.InvokeVoidAsync("clientSettings.setAutoTts", _autoTts);
            await JS.InvokeVoidAsync("clientSettings.setDebugMode", _debugMode);
            _clientStatus = "클라이언트 설정이 적용되었습니다.";
            _clientStatusIsError = false;
        }
        catch (Exception ex)
        {
            _clientStatus = $"적용 실패: {ex.Message}";
            _clientStatusIsError = true;
        }
    }
}
