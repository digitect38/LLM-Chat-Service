@page "/"
@using System.Text
@using Microsoft.Extensions.Options
@using FabCopilot.Contracts.Messages
@using FabCopilot.Observability.Metrics
@using FabCopilot.WebClient.Configuration
@using FabCopilot.WebClient.Models
@using FabCopilot.WebClient.Services
@inject ChatService ChatService
@inject IJSRuntime JS
@inject IOptions<ModelOptions> ModelOptionsAccessor
@inject IOptions<EquipmentOptions> EquipmentOptionsAccessor
@inject NavigationManager Navigation
@inject IConfiguration Configuration
@inject EmbeddingConfigService EmbeddingConfigService
@inject LogReaderService LogReaderService
@inject LogAnalyzerService LogAnalyzerService
@implements IAsyncDisposable

<div class="chat-app @AppThemeClass @DesktopPanelClass">
    <!-- ===== Panel Tab Bar ===== -->
    <div class="panel-tabs">
        <button class="panel-tab @(_activePanel == PanelKind.List ? "panel-tab-active" : "")"
                @onclick="() => SetActivePanel(PanelKind.List)">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="4" x2="21" y2="4"/><line x1="6" y1="10" x2="21" y2="10"/><line x1="6" y1="16" x2="21" y2="16"/><circle cx="3" cy="10" r="1" fill="currentColor" stroke="none"/><circle cx="3" cy="16" r="1" fill="currentColor" stroke="none"/></svg>
            <span>목록</span>
            @if (_conversationHistory.Count > 0)
            {
                <span class="tab-badge">@_conversationHistory.Count</span>
            }
        </button>
        <button class="panel-tab @(_activePanel == PanelKind.Chat ? "panel-tab-active" : "")"
                @onclick="() => SetActivePanel(PanelKind.Chat)">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="7" opacity="0.3"/><path d="M12 2 L13.1 8.2 L17.4 4.6 L14.5 10.5 L21 10.3 L15.2 13 L18.8 18.4 L12.8 14.8 L12 22 L11.2 14.8 L5.2 18.4 L8.8 13 L3 10.3 L9.5 10.5 L6.6 4.6 L10.9 8.2 Z"/></svg>
            <span>채팅</span>
            <span class="status-dot @(ChatService.IsConnected ? "dot-on" : "dot-off")"></span>
        </button>
        <button class="panel-tab @(_activePanel == PanelKind.Log ? "panel-tab-active" : "")"
                @onclick="() => SetActivePanel(PanelKind.Log)">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12V7H5a2 2 0 010-4h14v4"/><path d="M3 5v14a2 2 0 002 2h16v-5"/><path d="M18 12a2 2 0 100 4 2 2 0 000-4z"/></svg>
            <span>로그 분석</span>
        </button>
        <button class="panel-tab @(_activePanel == PanelKind.Cite ? "panel-tab-active" : "")"
                @onclick="() => SetActivePanel(PanelKind.Cite)">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
            <span>참고 문서</span>
            @if (_activeCitations is { Count: > 0 })
            {
                <span class="tab-badge">@_activeCitations.Count</span>
            }
        </button>
        <button class="panel-tab" @onclick='() => Navigation.NavigateTo("/settings")'>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/></svg>
            <span>설정</span>
        </button>
        <button class="panel-tab" @onclick='() => Navigation.NavigateTo("/server/settings")'>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
            <span>서버</span>
        </button>
        <span class="panel-tabs-version">@AppVersion</span>
    </div>

    <!-- ===== Panel Viewport ===== -->
    <div class="panel-viewport">
        <div class="panel-track" style="transform: translateX(-@((int)_activePanel * 25)%)">

            <!-- ── Panel 0: Conversation List ── -->
            <section class="panel panel-list">
                <div class="plist-top">
                    <h3>대화 기록</h3>
                    <button class="icon-btn" @onclick="StartNewChat" title="새 대화">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                    </button>
                </div>
                <nav class="plist-conversations">
                    @if (_isLoadingHistory)
                    {
                        <div class="plist-empty">기록 로딩 중...</div>
                    }
                    else if (_conversationHistory.Count == 0)
                    {
                        <div class="plist-empty">대화 기록 없음</div>
                    }
                    else
                    {
                        @foreach (var conv in _conversationHistory)
                        {
                            <div class="conv-item-wrapper">
                                <button class="conv-item @(conv.Id == _conversationId ? "conv-active" : "")"
                                        @onclick="() => SelectConversation(conv.Id)"
                                        title="@conv.Title">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
                                    <span class="conv-title">@conv.Title</span>
                                </button>
                                <button class="conv-delete-btn"
                                        @onclick="() => DeleteConversationAsync(conv.Id)"
                                        @onclick:stopPropagation="true"
                                        title="대화 삭제">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                                </button>
                            </div>
                        }
                    }
                </nav>
                <div class="plist-footer">
                    <div class="sidebar-equipment">
                        <select class="equipment-select"
                                @bind="EquipmentId"
                                disabled="@_isSending">
                            @foreach (var eq in _availableEquipment)
                            {
                                <option value="@eq.Id">@eq.DisplayName</option>
                            }
                        </select>
                        <span class="status-dot @(ChatService.IsConnected ? "dot-on" : "dot-off")"></span>
                    </div>
                </div>
            </section>

            <!-- ── Panel 1: Chat ── -->
            <section class="panel panel-chat">
                <!-- Top bar (chat-specific controls) -->
                <div class="chat-topbar">
                    <div class="render-mode-toggle">
                        <button class="toggle-btn @(_renderMode == "jit" ? "toggle-active" : "")"
                                @onclick='() => SetRenderMode("jit")'>JIT</button>
                        <button class="toggle-btn @(_renderMode == "fade" ? "toggle-active" : "")"
                                @onclick='() => SetRenderMode("fade")'>Fade</button>
                        <button class="toggle-btn @(_renderMode == "batch" ? "toggle-active" : "")"
                                @onclick='() => SetRenderMode("batch")'>Batch</button>
                        <button class="toggle-btn @(_renderMode == "sync" ? "toggle-active" : "")"
                                @onclick='() => SetRenderMode("sync")' title="TTS 음성과 동기화된 문장 단위 텍스트 표시">Sync</button>
                    </div>
                    <div class="topbar-spacer"></div>
                    <button class="icon-btn" @onclick="StartNewChat" title="새 대화">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                    </button>
                </div>

        <!-- Messages -->
        <div class="chat-messages" id="chatMessages">
            @if (_messages.Count == 0)
            {
                <div class="empty-state">
                    <div class="empty-logo">
                        <img src="images/eagle_256x256.png" alt="FabWise" class="welcome-eagle" />
                    </div>
                    <h1 class="empty-title">FabWise</h1>
                    <p class="empty-subtitle">반도체 장비 운영 어시스턴트</p>
                    <div class="empty-hints">
                        <div class="hint-card" @onclick='() => SetQuickMessage("CMP 패드 교체 주기는 어떻게 되나요?")'>CMP 패드 교체 주기</div>
                        <div class="hint-card" @onclick='() => SetQuickMessage("슬러리 유량 이상 시 조치 방법은?")'>슬러리 유량 이상 조치</div>
                        <div class="hint-card" @onclick='() => SetQuickMessage("MRR이 불안정한 원인은 무엇인가요?")'>MRR 불안정 원인</div>
                    </div>
                </div>
            }
            else
            {
                @for (var i = 0; i < _messages.Count; i++)
                {
                    var idx = i;
                    var msg = _messages[idx];
                    <div class="msg-row @(msg.IsUser ? "msg-user-row" : "msg-assistant-row")">
                        <div class="msg-wrapper">
                            <div class="msg-body">
                                @if (msg.IsEditing)
                                {
                                    <div class="msg-edit-area">
                                        <textarea class="edit-textarea" @bind="msg.EditText" @bind:event="oninput" rows="3"></textarea>
                                        <div class="edit-actions">
                                            <button class="btn-primary-sm" @onclick="() => SaveEdit(idx)">저장 후 전송</button>
                                            <button class="btn-secondary-sm" @onclick="() => CancelEdit(idx)">취소</button>
                                        </div>
                                    </div>
                                }
                                else if (msg.IsUser)
                                {
                                    <div class="msg-content user-text">@msg.Text</div>
                                }
                                else if (msg.IsStreaming && _renderMode == "batch")
                                {
                                    <div class="msg-content batch-loading">
                                        <div class="skeleton-line" style="width:85%"></div>
                                        <div class="skeleton-line" style="width:70%"></div>
                                        <div class="skeleton-line" style="width:45%"></div>
                                        <span class="batch-loading-text">응답 생성 중...</span>
                                    </div>
                                }
                                else if (msg.IsStreaming && string.IsNullOrEmpty(msg.Text))
                                {
                                    <div class="msg-content typing-indicator">
                                        <span class="typing-dot"></span>
                                        <span class="typing-dot"></span>
                                        <span class="typing-dot"></span>
                                    </div>
                                }
                                else if (msg.IsStreaming && _renderMode == "sync")
                                {
                                    var syncSplit = SplitTextBySentence(msg.Text, _syncRevealedCount, _syncAllRevealed);
                                    var syncRevealed = syncSplit.Item1;
                                    var syncUnrevealed = syncSplit.Item2;
                                    <div class="msg-content sync-text">
                                        @if (!string.IsNullOrEmpty(syncRevealed))
                                        {
                                            <span class="sync-revealed">@syncRevealed</span>
                                        }
                                        @if (!string.IsNullOrEmpty(syncUnrevealed))
                                        {
                                            <span class="sync-unrevealed">@syncUnrevealed</span>
                                        }
                                        <span class="streaming-cursor"></span>
                                    </div>
                                }
                                else if (msg.IsStreaming && _renderMode == "jit" && !string.IsNullOrEmpty(msg.RenderedHtml))
                                {
                                    <div class="msg-content rendered-markdown">@((MarkupString)msg.RenderedHtml)</div>
                                    <span class="streaming-cursor"></span>
                                }
                                else if (msg.IsStreaming)
                                {
                                    <div class="msg-content streaming-text">@msg.Text</div>
                                    <span class="streaming-cursor"></span>
                                }
                                else
                                {
                                    <div class="msg-content rendered-markdown @(msg.FadeIn ? "msg-fade-in" : "")">@((MarkupString)(msg.RenderedHtml ?? msg.Text))</div>
                                }
                                @if (!string.IsNullOrEmpty(msg.Error))
                                {
                                    <div class="msg-error">@msg.Error</div>
                                }
                                @if (!msg.IsStreaming && !msg.IsEditing)
                                {
                                    <div class="msg-actions">
                                        @if (msg.IsUser)
                                        {
                                            <button class="action-btn action-btn-edit" @onclick="() => StartEdit(idx)" title="편집" disabled="@_isSending">
                                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                            </button>
                                        }
                                        else
                                        {
                                            <button class="action-btn action-btn-copy @(msg.CopyFeedback ? "action-copied" : "")" @onclick="() => CopyMessage(idx)" title="복사">
                                                @if (msg.CopyFeedback)
                                                {
                                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                                                }
                                                else
                                                {
                                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
                                                }
                                            </button>
                                            <button class="action-btn action-btn-like @(msg.Feedback == 1 ? "action-active" : "")" @onclick="() => SendFeedback(idx, true)" title="좋아요">
                                                <svg width="16" height="16" viewBox="0 0 24 24" fill="@(msg.Feedback == 1 ? "currentColor" : "none")" stroke="currentColor" stroke-width="2"><path d="M14 9V5a3 3 0 00-3-3l-4 9v11h11.28a2 2 0 002-1.7l1.38-9a2 2 0 00-2-2.3zM7 22H4a2 2 0 01-2-2v-7a2 2 0 012-2h3"/></svg>
                                            </button>
                                            <button class="action-btn action-btn-dislike @(msg.Feedback == -1 ? "action-active" : "")" @onclick="() => SendFeedback(idx, false)" title="싫어요">
                                                <svg width="16" height="16" viewBox="0 0 24 24" fill="@(msg.Feedback == -1 ? "currentColor" : "none")" stroke="currentColor" stroke-width="2"><path d="M10 15v4a3 3 0 003 3l4-9V2H5.72a2 2 0 00-2 1.7l-1.38 9a2 2 0 002 2.3zm7-13h2.67A2.31 2.31 0 0122 4v7a2.31 2.31 0 01-2.33 2H17"/></svg>
                                            </button>
                                            <button class="action-btn action-btn-tts @(_ttsPlayingIdx == idx ? "action-active" : "")"
                                                    @onclick="() => PlayTts(idx)"
                                                    title="@(_ttsPlayingIdx == idx ? "TTS 중지" : "음성으로 듣기")"
                                                    disabled="@(_ttsLoading && _ttsPlayingIdx != idx)">
                                                @if (_ttsLoading && _ttsPlayingIdx == idx)
                                                {
                                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="spin-icon"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
                                                }
                                                else if (_ttsPlayingIdx == idx)
                                                {
                                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg>
                                                }
                                                else
                                                {
                                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M19.07 4.93a10 10 0 010 14.14"/><path d="M15.54 8.46a5 5 0 010 7.07"/></svg>
                                                }
                                            </button>
                                            @if (msg.Citations is { Count: > 0 })
                                            {
                                                <button class="action-btn action-btn-cite" @onclick="() => ShowCitations(idx)" title="참조 문서">
                                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                                                </button>
                                            }
                                            @if (msg.LatencyMs > 0)
                                            {
                                                <span class="msg-latency">@(msg.LatencyMs)ms</span>
                                            }
                                            @if (idx == _messages.Count - 1)
                                            {
                                                <button class="action-btn action-btn-regen" @onclick="RegenerateResponse" title="재생성" disabled="@_isSending">
                                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 11-2.12-9.36L23 10"/></svg>
                                                </button>
                                            }
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }
            }
        </div>

        <!-- Timeout Progress -->
        @if (_isSending)
        {
            <div class="timeout-progress">
                <div class="timeout-bar timeout-@_timeoutSeverity"
                     style="width: @(Math.Min(100, _elapsedSeconds * 100 / _timeoutBudgetSeconds))%"></div>
            </div>
            <div class="timeout-label">@_currentStage (@(_elapsedSeconds)초)</div>
        }

        @if (_showTimeoutNotification)
        {
            <div class="timeout-warning-popup timeout-level-@_timeoutLevel">
                <p>@_timeoutNotificationMessage</p>
                <div class="timeout-actions">
                    <button @onclick="ExtendTimeout">⏱ 시간 연장 (2x)</button>
                    <button @onclick="SimplifyQuery">💬 간단한 답변 요청</button>
                    @if (_hasPartialResponse)
                    {
                        <button @onclick="ShowPartialAndContinue">📄 부분 응답 표시</button>
                    }
                    <button @onclick="CancelTimeout" class="btn-cancel">✕ 취소 & 재시도</button>
                </div>
            </div>
        }

        @if (_ttsSendConfirmVisible)
        {
            <div class="tts-confirm-banner">
                <span class="tts-confirm-text">음성 재생 중입니다</span>
                <button class="tts-confirm-btn tts-confirm-stop" @onclick="() => TtsSendConfirm(true)">끊고 새 질문</button>
                <button class="tts-confirm-btn tts-confirm-keep" @onclick="() => TtsSendConfirm(false)">계속 듣기</button>
                <button class="tts-confirm-btn tts-confirm-cancel" @onclick="TtsSendCancel">취소</button>
            </div>
        }

        <!-- Input Area -->
        <div class="chat-input-wrapper">
            <div class="chat-input-box">
                <button class="upload-btn" @onclick="TriggerFileUpload" title="파일 업로드" disabled="@(_isSending || _isUploading)">
                    @if (_isUploading)
                    {
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="spin-icon"><path d="M21 12a9 9 0 11-6.219-8.56"/></svg>
                    }
                    else
                    {
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21.44 11.05l-9.19 9.19a6 6 0 01-8.49-8.49l9.19-9.19a4 4 0 015.66 5.66l-9.2 9.19a2 2 0 01-2.83-2.83l8.49-8.48"/></svg>
                    }
                </button>
                <button class="auto-tts-btn @(_autoTtsEnabled ? "auto-tts-on" : "")"
                        @onclick="ToggleAutoTts"
                        title="@(_autoTtsEnabled ? "자동 음성 대화 끄기" : "자동 음성 대화 켜기")">
                    @if (_autoTtsEnabled)
                    {
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M19.07 4.93a10 10 0 010 14.14"/><path d="M15.54 8.46a5 5 0 010 7.07"/></svg>
                    }
                    else
                    {
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><line x1="23" y1="9" x2="17" y2="15"/><line x1="17" y1="9" x2="23" y2="15"/></svg>
                    }
                </button>
                <button class="mic-btn @(_isRecording ? "mic-recording" : "") @(_isTranscribing ? "mic-transcribing" : "")"
                        @onclick="ToggleRecording"
                        disabled="@(_isSending || _isTranscribing || _isUploading)"
                        title="@(_isRecording ? "녹음 중지" : "음성 입력")">
                    @if (_isTranscribing)
                    {
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="spin-icon"><path d="M21 12a9 9 0 11-6.219-8.56"/></svg>
                    }
                    else if (_isRecording)
                    {
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><rect x="6" y="6" width="12" height="12" rx="2"/></svg>
                    }
                    else
                    {
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 1a3 3 0 00-3 3v8a3 3 0 006 0V4a3 3 0 00-3-3z"/><path d="M19 10v2a7 7 0 01-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg>
                    }
                </button>
                @if (_isRecording)
                {
                    <span class="recording-timer">@TimeSpan.FromSeconds(_recordingSeconds).ToString("mm\\:ss")</span>
                }
                <InputFile OnChange="HandleFileUpload" style="display:none" id="fileUploadInput" accept=".pdf,.md,.txt,.png,.jpg,.jpeg" />
                <div class="chat-textarea-wrapper">
                    <textarea id="chatInput"
                              class="chat-textarea"
                              @bind="UserMessage"
                              @bind:event="oninput"
                              @bind:after="AutoResizeInput"
                              @onkeydown="HandleKeyDown"
                              placeholder="@(_isRecording && !string.IsNullOrEmpty(_interimText) ? "" : "메시지를 입력하세요...")"
                              disabled="@_isSending"
                              rows="1"></textarea>
                    @if (_isRecording && !string.IsNullOrEmpty(_interimText))
                    {
                        <div class="interim-text">@_interimText</div>
                    }
                </div>
                @if (_isSending)
                {
                    <button class="input-action-btn stop-btn" @onclick="StopResponseAsync" title="중지">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><rect x="6" y="6" width="12" height="12" rx="2"/></svg>
                    </button>
                }
                else
                {
                    @if (_ttsStreamingActive || _ttsPlayingIdx >= 0)
                    {
                        <button class="input-action-btn tts-stop-btn" @onclick="StopTtsFromInput" title="TTS 중지">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><rect x="6" y="6" width="12" height="12" rx="2"/></svg>
                        </button>
                    }
                    <button class="input-action-btn send-btn"
                            @onclick="SendMessageAsync"
                            disabled="@string.IsNullOrWhiteSpace(UserMessage)"
                            title="전송">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="19" x2="12" y2="5"/><polyline points="5 12 12 5 19 12"/></svg>
                    </button>
                }
            </div>
            @if (_autoTtsEnabled && _isVoiceMode && _voicePhase != VoicePhase.Idle)
            {
                <div class="voice-status-bar @VoicePhaseCssClass">
                    @switch (_voicePhase)
                    {
                        case VoicePhase.Listening:
                            <span class="waveform-bars-inline">
                                <span class="wf-inline-bar"></span>
                                <span class="wf-inline-bar"></span>
                                <span class="wf-inline-bar"></span>
                                <span class="wf-inline-bar"></span>
                                <span class="wf-inline-bar"></span>
                            </span>
                            <span>듣는 중... @TimeSpan.FromSeconds(_recordingSeconds).ToString("mm\\:ss")</span>
                            break;
                        case VoicePhase.Transcribing:
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="spin-icon"><path d="M21 12a9 9 0 11-6.219-8.56"/></svg>
                            <span>변환 중...</span>
                            break;
                        case VoicePhase.Waiting:
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="spin-icon"><path d="M21 12a9 9 0 11-6.219-8.56"/></svg>
                            <span>응답 생성 중...</span>
                            break;
                        case VoicePhase.Speaking:
                            <span class="waveform-bars-inline waveform-bars-speaking">
                                <span class="wf-inline-bar"></span>
                                <span class="wf-inline-bar"></span>
                                <span class="wf-inline-bar"></span>
                                <span class="wf-inline-bar"></span>
                                <span class="wf-inline-bar"></span>
                            </span>
                            <span>음성 재생 중</span>
                            break;
                    }
                </div>
            }
            <voice-panel equipment-id="@EquipmentId"></voice-panel>
            <div class="input-disclaimer">FabWise은 장비 매뉴얼 기반으로 답변하며, 오류가 있을 수 있습니다.</div>
        </div>
            </section>

            <!-- ── Panel 2: Log Analyzer ── -->
            <section class="panel panel-log">
                <LogAnalyzerPane @ref="_logPaneRef"
                                 IsOpen="true"
                                 OnClose="() => SetActivePanel(PanelKind.Chat)"
                                 OnAnalyzeRequest="HandleLogAnalyzeRequest" />
            </section>

            <!-- ── Panel 3: Citations ── -->
            <section class="panel panel-cite">
                <CitationPane IsOpen="true"
                              Citations="_activeCitations"
                              AutoOpenPage="_autoOpenPage"
                              AutoOpenSeq="_autoOpenSeq"
                              OnClose="() => SetActivePanel(PanelKind.Chat)" />
            </section>

        </div>
    </div>
</div>

@* Error toast removed — errors logged to browser console only *@

@code {
    private const string AppVersion = "v4.86.0";
    private const string AppThemeClass = "theme-v485";

    private enum PanelKind { List = 0, Chat = 1, Log = 2, Cite = 3 }
    private PanelKind _activePanel = PanelKind.Chat;

    private string _equipmentId = "CMP01";
    private string EquipmentId
    {
        get => _equipmentId;
        set
        {
            if (_equipmentId == value) return;
            _equipmentId = value;
            _ = OnEquipmentChangedAsync();
        }
    }
    private string UserMessage { get; set; } = string.Empty;

    // Connection state
    private string _conversationId = Guid.NewGuid().ToString("N");
    private bool _isSending;
    private bool _isStopping;

    // UI state
    private List<CitationInfo>? _activeCitations;
    private string _selectedModelId = string.Empty;
    private string _searchMode = "hybrid";
    private string? _pendingLogContext;
    private string _renderMode = "jit";  // "jit" | "fade" | "batch" | "sync"

    // SYNC render mode: sentence-by-sentence reveal synced to TTS playback
    private int _syncRevealedCount;  // number of sentences spoken so far
    private bool _syncAllRevealed;   // true after TTS ends or streaming completes without TTS
    private List<ModelEntry> _availableModels = new();
    private List<EquipmentEntry> _availableEquipment = new();
    private readonly List<ChatMessageViewModel> _messages = new();

    // Conversation history (sidebar)
    private readonly List<ConversationItem> _conversationHistory = new();

    // Render throttle
    private int _renderCounter;
    private int _chunkCounter;
    private bool _renderPending;
    private Timer? _renderTimer;

    // Stale stream detection: auto-complete if no chunks arrive for N seconds
    private Timer? _staleStreamTimer;
    private const int StaleStreamTimeoutMs = 5000;

    // File upload
    private bool _isUploading;

    // Voice recording (STT)
    private bool _isRecording;
    private bool _isTranscribing;
    private string _interimText = "";
    private int _recordingSeconds;

    // Voice Mode (hands-free STT → LLM → TTS loop)
    private bool _isVoiceMode;
    private VoicePhase _voicePhase = VoicePhase.Idle;

    private enum VoicePhase { Idle, Listening, Transcribing, Waiting, Speaking }

    private string VoicePhaseCssClass => _voicePhase switch
    {
        VoicePhase.Listening => "voice-phase-listening",
        VoicePhase.Speaking => "voice-phase-speaking",
        VoicePhase.Transcribing or VoicePhase.Waiting => "voice-phase-processing",
        _ => ""
    };

    // Latency tracking
    private System.Diagnostics.Stopwatch? _latencyStopwatch;

    // Timeout progress (v4.83 enhanced)
    private Timer? _timeoutTimer;
    private int _elapsedSeconds;
    private string _currentStage = "";
    private bool _showTimeoutNotification;
    private string _timeoutSeverity = "normal";
    private int _timeoutBudgetSeconds = 180;
    private int _timeoutLevel; // 1=10s, 2=30s, 3=60s, 4=180s
    private string _timeoutNotificationMessage = "";
    private bool _hasPartialResponse;

    // Citation interop
    private DotNetObjectReference<Index>? _dotNetRef;
    private int? _autoOpenPage;
    private int _autoOpenSeq;

    // Log pane ref (for timestamp navigation)
    private LogAnalyzerPane? _logPaneRef;

    private bool _isLoadingHistory;

    protected override async Task OnInitializedAsync()
    {
        ChatService.OnMessageReceived += HandleChunkReceived;
        ChatService.OnStateChanged += HandleStateChanged;

        var opts = ModelOptionsAccessor.Value;
        _availableModels = opts.Available;

        // Load persisted model from LlmService config, fall back to WebClient default
        var persistedModel = EmbeddingConfigService.GetCurrentLlmModel();
        _selectedModelId = !string.IsNullOrEmpty(persistedModel)
            ? persistedModel
            : (!string.IsNullOrEmpty(opts.Default) ? opts.Default : _availableModels.FirstOrDefault()?.Id ?? "");

        _searchMode = EmbeddingConfigService.GetCurrentSearchMode();

        var eqOpts = EquipmentOptionsAccessor.Value;
        _availableEquipment = eqOpts.Available;
        if (_availableEquipment.Count > 0)
            _equipmentId = !string.IsNullOrEmpty(eqOpts.Default) ? eqOpts.Default : _availableEquipment[0].Id;

        await LoadConversationHistoryAsync();
    }

    // ─── Panel Navigation ─────────────────────────────────────────────

    private string DesktopPanelClass => _activePanel switch
    {
        PanelKind.Log => "dp-log",
        PanelKind.Cite => "dp-cite",
        _ => ""
    };

    private void SetActivePanel(PanelKind panel)
    {
        // Toggle: clicking the already-active right panel closes it
        if (_activePanel == panel && (panel == PanelKind.Log || panel == PanelKind.Cite))
            _activePanel = PanelKind.Chat;
        else
            _activePanel = panel;
        StateHasChanged();
    }

    private async Task StartNewChat()
    {
        // Exit voice mode if active
        if (_isVoiceMode) await ExitVoiceModeAsync();

        // Save current conversation to history
        SaveCurrentToHistory();

        // Reset state
        _messages.Clear();
        _conversationId = Guid.NewGuid().ToString("N");
        _isSending = false;
        _isStopping = false;

        // Disconnect and reconnect with fresh conversation
        if (ChatService.IsConnected)
        {
            await ChatService.DisconnectAsync();
        }

        StateHasChanged();
    }

    private async Task SelectConversation(string convId)
    {
        // 1. Switch to Chat panel FIRST — gives instant visual feedback on mobile
        _activePanel = PanelKind.Chat;
        StateHasChanged();
        // Yield to let Blazor flush the render before any blocking work.
        // Without this, translateX transition won't fire until SwitchConversation completes.
        await Task.Yield();

        // 2. If same conversation, just switch panel (no data reload needed)
        if (convId == _conversationId) return;

        // 3. Load conversation data (async, may take time)
        await SwitchConversation(convId);
    }

    private async Task SwitchConversation(string convId)
    {
        var target = _conversationHistory.FirstOrDefault(c => c.Id == convId);
        if (target is null || target.Id == _conversationId) return;

        // Exit voice mode if active
        if (_isVoiceMode) await ExitVoiceModeAsync();

        SaveCurrentToHistory();

        _conversationId = target.Id;
        _messages.Clear();

        // If the sidebar item already has cached messages, use them
        if (target.Messages.Count > 0)
        {
            _messages.AddRange(target.Messages.Select(m => new ChatMessageViewModel
            {
                Text = m.Text,
                RenderedHtml = m.RenderedHtml,
                IsUser = m.IsUser,
                Error = m.Error
            }));
        }
        else
        {
            // Lazy-load full messages from Redis
            try
            {
                var detail = await ChatService.GetConversationAsync(EquipmentId, convId);
                if (detail?.Messages is { Count: > 0 })
                {
                    foreach (var m in detail.Messages)
                    {
                        var isUser = m.Role == 0; // 0=User
                        var text = m.Text;
                        var html = isUser ? null : await RenderMarkdownAsync(text);
                        _messages.Add(new ChatMessageViewModel
                        {
                            Text = text,
                            RenderedHtml = html,
                            IsUser = isUser
                        });
                    }
                    // Cache into the sidebar item
                    target.Messages = _messages.Select(m => new ChatMessageViewModel
                    {
                        Text = m.Text, RenderedHtml = m.RenderedHtml, IsUser = m.IsUser, Error = m.Error
                    }).ToList();
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"[Error] 대화 로딩 실패: {ex.Message}");
            }
        }

        StateHasChanged();
        await ScrollToBottom();
    }

    private async Task DeleteConversationAsync(string convId)
    {
        var deleted = await ChatService.DeleteConversationAsync(EquipmentId, convId);
        if (!deleted) return;

        _conversationHistory.RemoveAll(c => c.Id == convId);

        // If the active conversation was deleted, start a new chat
        if (convId == _conversationId)
        {
            _messages.Clear();
            _conversationId = Guid.NewGuid().ToString("N");
            _isSending = false;
            _isStopping = false;
        }

        StateHasChanged();
    }

    private void SaveCurrentToHistory()
    {
        if (_messages.Count == 0) return;

        var existing = _conversationHistory.FirstOrDefault(c => c.Id == _conversationId);
        if (existing is not null)
        {
            existing.Messages = _messages.Select(m => new ChatMessageViewModel
            {
                Text = m.Text, RenderedHtml = m.RenderedHtml, IsUser = m.IsUser, Error = m.Error
            }).ToList();
        }
        else
        {
            var title = _messages.FirstOrDefault(m => m.IsUser)?.Text ?? "새 대화";
            if (title.Length > 30) title = title[..30] + "...";
            _conversationHistory.Insert(0, new ConversationItem
            {
                Id = _conversationId,
                Title = title,
                Messages = _messages.Select(m => new ChatMessageViewModel
                {
                    Text = m.Text, RenderedHtml = m.RenderedHtml, IsUser = m.IsUser, Error = m.Error
                }).ToList()
            });
        }
    }

    private async Task LoadConversationHistoryAsync()
    {
        _isLoadingHistory = true;
        StateHasChanged();
        try
        {
            var summaries = await ChatService.GetConversationListAsync(EquipmentId);
            _conversationHistory.Clear();
            foreach (var s in summaries)
            {
                _conversationHistory.Add(new ConversationItem
                {
                    Id = s.ConversationId,
                    Title = s.Title,
                    Messages = [] // lazy-loaded on click
                });
            }
        }
        catch { /* already logged in ChatService */ }
        finally
        {
            _isLoadingHistory = false;
            StateHasChanged();
        }
    }

    private async Task OnEquipmentChangedAsync()
    {
        SaveCurrentToHistory();
        _messages.Clear();
        _conversationId = Guid.NewGuid().ToString("N");
        if (ChatService.IsConnected)
            await ChatService.DisconnectAsync();
        try { await JS.InvokeVoidAsync("audioRecorder.updateEquipmentId", _equipmentId); } catch { }
        await LoadConversationHistoryAsync();
    }

    // ─── Connection ─────────────────────────────────────────────────────

    private async Task EnsureConnectedAsync()
    {
        if (ChatService.IsConnected) return;

        try
        {
            await ChatService.ConnectAsync(EquipmentId.Trim());
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[Error] 연결 실패: {ex.Message}");
            throw;
        }
    }

    // ─── Chat ───────────────────────────────────────────────────────────

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            // If recording in voice mode, exit voice mode first
            if (_isVoiceMode && _isRecording)
                await ExitVoiceModeAsync();

            await SendMessageAsync();
        }
    }

    private async Task AutoResizeInput()
    {
        try { await JS.InvokeVoidAsync("chatInput.autoResize", "chatInput"); } catch { }
    }

    private void SetQuickMessage(string text)
    {
        UserMessage = text;
        StateHasChanged();
    }

    private int _sendSeq;

    private async Task SendMessageAsync()
    {
        if (string.IsNullOrWhiteSpace(UserMessage) || _isSending || _isStopping)
            return;

        // If TTS is playing, ask user whether to stop or continue
        if (_ttsStreamingActive || _ttsPlayingIdx >= 0)
        {
            _ttsPendingMessage = UserMessage.Trim();
            _ttsSendConfirmVisible = true;
            StateHasChanged();
            return;
        }

        var text = UserMessage.Trim();
        UserMessage = string.Empty;
        _isSending = true;
        _chunkCounter = 0;
        var seq = ++_sendSeq;

        try { await JS.InvokeVoidAsync("console.warn",
            $"[Blazor] SEND #{seq} convId={_conversationId[..8]}… msg={text[..Math.Min(text.Length,40)]}"); } catch { }

        // Auto-connect
        try
        {
            await EnsureConnectedAsync();
        }
        catch
        {
            _isSending = false;
            StateHasChanged();
            return;
        }

        _messages.Add(new ChatMessageViewModel { Text = text, IsUser = true });
        _messages.Add(new ChatMessageViewModel { IsUser = false, IsStreaming = true });
        _latencyStopwatch = System.Diagnostics.Stopwatch.StartNew();
        StartTimeoutTimer();

        // Pre-unlock AudioContext during user gesture for Auto TTS
        if (_autoTtsEnabled && !_isVoiceMode)
        {
            try { await JS.InvokeVoidAsync("fabTts.unlockAudio"); } catch { }
        }
        StateHasChanged();
        await ScrollToBottom();

        try
        {
            var logContext = _pendingLogContext ?? BuildAutoLogContext(text);
            _pendingLogContext = null;
            await ChatService.SendMessageAsync(_conversationId, EquipmentId.Trim(), text, _selectedModelId, _searchMode, logContext);
            try { await JS.InvokeVoidAsync("console.warn",
                $"[Blazor] SENT #{seq} convId={_conversationId[..8]}… OK"); } catch { }
        }
        catch (Exception ex)
        {
            var last = _messages.LastOrDefault(m => !m.IsUser);
            if (last is not null) { last.Error = ex.Message; last.IsStreaming = false; }
            _isSending = false;
            StateHasChanged();
        }

        try { await JS.InvokeVoidAsync("chatInput.resetHeight", "chatInput"); } catch { }
    }

    private async Task TtsSendConfirm(bool stopTts)
    {
        _ttsSendConfirmVisible = false;
        var pending = _ttsPendingMessage;
        _ttsPendingMessage = null;

        if (string.IsNullOrWhiteSpace(pending)) return;

        if (stopTts)
        {
            // Stop current TTS → new response will get TTS
            if (_ttsStreamingActive) { _ttsStreamingActive = false; try { await JS.InvokeVoidAsync("fabTts.stop"); } catch { } }
            else { try { await JS.InvokeVoidAsync("fabTts.stop"); } catch { } }
            _ttsPlayingIdx = -1;
        }
        else
        {
            // Keep current TTS playing → disable TTS for this response only
            _autoTtsEnabled = false;
        }

        UserMessage = pending;
        StateHasChanged();
        await SendMessageAsync();

        // Restore autoTts if it was temporarily disabled
        if (!stopTts)
        {
            var saved = await JS.InvokeAsync<string>("clientSettings.getAutoTts");
            _autoTtsEnabled = saved == "on";
        }
    }

    private void TtsSendCancel()
    {
        _ttsSendConfirmVisible = false;
        _ttsPendingMessage = null;
        StateHasChanged();
    }

    private async Task StopResponseAsync()
    {
        _isStopping = true;
        StopRenderTimer();
        StopStaleStreamTimer();
        StopTimeoutTimer();

        // Notify machine: BUTTON.STOP → stopping → cleanup
        try { await JS.InvokeVoidAsync("voiceMachine.send", "BUTTON.STOP"); } catch { }

        // Stop streaming TTS if active
        if (_ttsStreamingActive)
        {
            _ttsStreamingActive = false;
            try { await JS.InvokeVoidAsync("fabTts.stop"); } catch { }
            _ttsPlayingIdx = -1;
        }

        var assistantMsg = _messages.LastOrDefault(m => !m.IsUser && m.IsStreaming);
        if (assistantMsg is not null)
        {
            assistantMsg.IsStreaming = false;
            if (!string.IsNullOrEmpty(assistantMsg.Text))
                assistantMsg.RenderedHtml = await RenderMarkdownAsync(assistantMsg.Text);
        }

        // Reset conversationId so old LLM Worker tokens (still flowing on the old
        // NATS subject chat.stream.{oldConversationId}) don't mix with the next response.
        _conversationId = Guid.NewGuid().ToString("N");

        // Disconnect FIRST, then allow new sends — prevents race where the user sends
        // a new message on the old WebSocket while the old LLM Worker is still streaming.
        await ChatService.DisconnectAsync();
        try { await ChatService.ConnectAsync(EquipmentId.Trim()); } catch { }

        _isSending = false;
        _isStopping = false;
        StateHasChanged();
    }

    // ─── Edit / Copy / Regenerate ───────────────────────────────────────

    private void StartEdit(int index)
    {
        if (_isSending || index < 0 || index >= _messages.Count) return;
        var msg = _messages[index];
        if (!msg.IsUser) return;
        msg.IsEditing = true;
        msg.EditText = msg.Text;
        StateHasChanged();
    }

    private async Task SaveEdit(int index)
    {
        var msg = _messages[index];
        var newText = msg.EditText?.Trim();
        if (string.IsNullOrEmpty(newText)) { CancelEdit(index); return; }

        msg.Text = newText;
        msg.IsEditing = false;

        // Remove all messages after this one
        if (index + 1 < _messages.Count)
            _messages.RemoveRange(index + 1, _messages.Count - index - 1);

        // Send as new request
        _isSending = true;
        _messages.Add(new ChatMessageViewModel { IsUser = false, IsStreaming = true });
        StateHasChanged();
        await ScrollToBottom();

        try
        {
            await EnsureConnectedAsync();
            // New conversation for the edited branch
            _conversationId = Guid.NewGuid().ToString("N");
            await ChatService.SendMessageAsync(_conversationId, EquipmentId.Trim(), newText, _selectedModelId, _searchMode);
        }
        catch (Exception ex)
        {
            var last = _messages.LastOrDefault(m => !m.IsUser);
            if (last is not null) { last.Error = ex.Message; last.IsStreaming = false; }
            _isSending = false;
            StateHasChanged();
        }
    }

    private void CancelEdit(int index)
    {
        if (index >= 0 && index < _messages.Count)
        {
            _messages[index].IsEditing = false;
            _messages[index].EditText = string.Empty;
        }
        StateHasChanged();
    }

    private async Task CopyMessage(int index)
    {
        if (index < 0 || index >= _messages.Count) return;
        var msg = _messages[index];
        try
        {
            await JS.InvokeVoidAsync("clipboard.copyText", msg.Text);
            msg.CopyFeedback = true;
            StateHasChanged();
            await Task.Delay(2000);
            msg.CopyFeedback = false;
            StateHasChanged();
        }
        catch { }
    }

    private async Task RegenerateResponse()
    {
        if (_isSending) return;

        // Find the last user message
        var lastUserIdx = -1;
        for (var i = _messages.Count - 1; i >= 0; i--)
        {
            if (_messages[i].IsUser) { lastUserIdx = i; break; }
        }
        if (lastUserIdx < 0) return;

        var userText = _messages[lastUserIdx].Text;

        // Remove the last assistant message
        if (lastUserIdx + 1 < _messages.Count)
            _messages.RemoveRange(lastUserIdx + 1, _messages.Count - lastUserIdx - 1);

        _isSending = true;
        _messages.Add(new ChatMessageViewModel { IsUser = false, IsStreaming = true });
        StateHasChanged();
        await ScrollToBottom();

        try
        {
            await EnsureConnectedAsync();
            _conversationId = Guid.NewGuid().ToString("N");
            await ChatService.SendMessageAsync(_conversationId, EquipmentId.Trim(), userText, _selectedModelId, _searchMode);
        }
        catch (Exception ex)
        {
            var last = _messages.LastOrDefault(m => !m.IsUser);
            if (last is not null) { last.Error = ex.Message; last.IsStreaming = false; }
            _isSending = false;
            StateHasChanged();
        }
    }

    // ─── Feedback ─────────────────────────────────────────────────────

    private async Task SendFeedback(int index, bool isPositive)
    {
        if (index < 0 || index >= _messages.Count) return;
        var msg = _messages[index];
        if (msg.IsUser) return;

        // Toggle: clicking the same button clears it
        var newValue = msg.Feedback == (isPositive ? 1 : -1) ? 0 : (isPositive ? 1 : -1);
        msg.Feedback = newValue;
        StateHasChanged();

        // Send to backend audit trail (only when setting, not clearing)
        if (newValue != 0)
        {
            await ChatService.SendFeedbackAsync(_conversationId, EquipmentId, index, isPositive);
        }
    }

    // ─── Citation Interop ─────────────────────────────────────────────

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("citationInterop.init", _dotNetRef);
            await JS.InvokeVoidAsync("logTimestampInterop.init", _dotNetRef);

            // Unified engine: always use React TS voice-panel
            // initReactVoicePanel이 recorder init + dotNetRef 전달 처리
            try { await JS.InvokeVoidAsync("initReactVoicePanel", _dotNetRef, EquipmentId); } catch { }

            // Mobile swipe navigation
            try { await JS.InvokeVoidAsync("panelSwipe.init", _dotNetRef); } catch { }

            var savedRenderMode = await JS.InvokeAsync<string>("clientSettings.getRenderMode");
            if (!string.IsNullOrEmpty(savedRenderMode))
            {
                _renderMode = savedRenderMode;
            }

            var savedTimeout = await JS.InvokeAsync<string>("clientSettings.getTimeoutBudget");
            if (!string.IsNullOrEmpty(savedTimeout) && int.TryParse(savedTimeout, out var budget))
            {
                _timeoutBudgetSeconds = budget;
            }

            var savedAutoTts = await JS.InvokeAsync<string>("clientSettings.getAutoTts");
            _autoTtsEnabled = savedAutoTts == "on";

            // Sync auto TTS state with voice machine & pre-acquire permissions
            if (_autoTtsEnabled)
            {
                try { await JS.InvokeVoidAsync("voiceMachine.send", "AUTO_TTS_ON"); } catch { }
                try { await JS.InvokeVoidAsync("fabTts.requestPermissions"); } catch { }
            }

            StateHasChanged();
        }
    }

    [JSInvokable]
    public void SwipePrev()
    {
        if (_activePanel > PanelKind.List)
        {
            _activePanel--;
            StateHasChanged();
        }
    }

    [JSInvokable]
    public void SwipeNext()
