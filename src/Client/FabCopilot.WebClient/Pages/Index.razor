@page "/"
@using Microsoft.Extensions.Options
@using FabCopilot.Contracts.Messages
@using FabCopilot.Observability.Metrics
@using FabCopilot.WebClient.Configuration
@using FabCopilot.WebClient.Services
@inject ChatService ChatService
@inject IJSRuntime JS
@inject IOptions<ModelOptions> ModelOptionsAccessor
@inject IOptions<EquipmentOptions> EquipmentOptionsAccessor
@inject NavigationManager Navigation
@inject IConfiguration Configuration
@inject EmbeddingConfigService EmbeddingConfigService
@inject LogReaderService LogReaderService
@inject LogAnalyzerService LogAnalyzerService
@implements IAsyncDisposable

<div class="chat-app">
    <!-- ===== Sidebar ===== -->
    <aside class="sidebar @(_sidebarOpen ? "" : "sidebar-closed")">
        <div class="sidebar-top">
            <button class="icon-btn" @onclick="ToggleSidebar" title="사이드바 닫기">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="9" y1="3" x2="9" y2="21"/></svg>
            </button>
            <button class="icon-btn" @onclick="StartNewChat" title="새 대화">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            </button>
        </div>

        <nav class="sidebar-conversations">
            @if (_isLoadingHistory)
            {
                <div class="sidebar-empty">기록 로딩 중...</div>
            }
            else if (_conversationHistory.Count == 0)
            {
                <div class="sidebar-empty">대화 기록 없음</div>
            }
            else
            {
                @foreach (var conv in _conversationHistory)
                {
                    <div class="conv-item-wrapper">
                        <button class="conv-item @(conv.Id == _conversationId ? "conv-active" : "")"
                                @onclick="() => SwitchConversation(conv.Id)"
                                title="@conv.Title">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
                            <span class="conv-title">@conv.Title</span>
                        </button>
                        <button class="conv-delete-btn"
                                @onclick="() => DeleteConversationAsync(conv.Id)"
                                @onclick:stopPropagation="true"
                                title="대화 삭제">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                        </button>
                    </div>
                }
            }
        </nav>

        <div class="sidebar-footer">
            <div class="sidebar-equipment">
                <select class="equipment-select"
                        @bind="EquipmentId"
                        disabled="@_isSending">
                    @foreach (var eq in _availableEquipment)
                    {
                        <option value="@eq.Id">@eq.DisplayName</option>
                    }
                </select>
                <span class="status-dot @(ChatService.IsConnected ? "dot-on" : "dot-off")"></span>
            </div>
            <button class="sidebar-settings-btn" @onclick='() => Navigation.NavigateTo("/settings")'>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/></svg>
                설정
            </button>
            <button class="sidebar-settings-btn" @onclick='() => Navigation.NavigateTo("/server/settings")'>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
                서버 설정
            </button>
        </div>
    </aside>

    <!-- ===== Main Content ===== -->
    <main class="chat-main">
        <!-- Top bar -->
        <div class="chat-topbar">
            @if (!_sidebarOpen)
            {
                <button class="icon-btn" @onclick="ToggleSidebar" title="사이드바 열기">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="9" y1="3" x2="9" y2="21"/></svg>
                </button>
                <button class="icon-btn" @onclick="StartNewChat" title="새 대화">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                </button>
            }
            <div class="render-mode-toggle">
                <button class="toggle-btn @(_renderMode == "jit" ? "toggle-active" : "")"
                        @onclick='() => SetRenderMode("jit")'>JIT</button>
                <button class="toggle-btn @(_renderMode == "fade" ? "toggle-active" : "")"
                        @onclick='() => SetRenderMode("fade")'>Fade</button>
                <button class="toggle-btn @(_renderMode == "batch" ? "toggle-active" : "")"
                        @onclick='() => SetRenderMode("batch")'>Batch</button>
            </div>
            <div class="topbar-spacer"></div>
            <button class="topbar-icon-btn @(_logPaneOpen ? "topbar-icon-active" : "")"
                    @onclick="ToggleLogPane"
                    title="@(_logPaneOpen ? "로그 분석 패널 닫기" : "로그 분석 패널 열기")">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12V7H5a2 2 0 010-4h14v4"/><path d="M3 5v14a2 2 0 002 2h16v-5"/><path d="M18 12a2 2 0 100 4 2 2 0 000-4z"/></svg>
            </button>
            <button class="topbar-icon-btn @(_citationPaneOpen ? "topbar-icon-active" : "")"
                    @onclick="ToggleCitationPane"
                    title="@(_citationPaneOpen ? "참조 패널 닫기" : "참조 패널 열기")">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
            </button>
        </div>

        <!-- Messages -->
        <div class="chat-messages" id="chatMessages">
            @if (_messages.Count == 0)
            {
                <div class="empty-state">
                    <div class="empty-logo">
                        <svg width="48" height="48" viewBox="0 0 24 24" fill="none">
                            <circle cx="12" cy="12" r="7" fill="white" opacity="0.18"/>
                            <path d="M12 2 L13.1 8.2 L17.4 4.6 L14.5 10.5 L21 10.3 L15.2 13 L18.8 18.4 L12.8 14.8 L12 22 L11.2 14.8 L5.2 18.4 L8.8 13 L3 10.3 L9.5 10.5 L6.6 4.6 L10.9 8.2 Z" fill="white"/>
                        </svg>
                    </div>
                    <h1 class="empty-title">Fab Copilot</h1>
                    <p class="empty-subtitle">반도체 장비 운영 어시스턴트</p>
                    <div class="empty-hints">
                        <div class="hint-card" @onclick='() => SetQuickMessage("CMP 패드 교체 주기는 어떻게 되나요?")'>CMP 패드 교체 주기</div>
                        <div class="hint-card" @onclick='() => SetQuickMessage("슬러리 유량 이상 시 조치 방법은?")'>슬러리 유량 이상 조치</div>
                        <div class="hint-card" @onclick='() => SetQuickMessage("MRR이 불안정한 원인은 무엇인가요?")'>MRR 불안정 원인</div>
                    </div>
                </div>
            }
            else
            {
                @for (var i = 0; i < _messages.Count; i++)
                {
                    var idx = i;
                    var msg = _messages[idx];
                    <div class="msg-row @(msg.IsUser ? "msg-user-row" : "msg-assistant-row")">
                        <div class="msg-wrapper">
                            <div class="msg-avatar">
                                @if (msg.IsUser)
                                {
                                    <div class="avatar avatar-user">
                                        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg>
                                    </div>
                                }
                                else
                                {
                                    <div class="avatar avatar-assistant">
                                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                                            <circle cx="12" cy="12" r="7" fill="white" opacity="0.18"/>
                                            <path d="M12 2 L13.1 8.2 L17.4 4.6 L14.5 10.5 L21 10.3 L15.2 13 L18.8 18.4 L12.8 14.8 L12 22 L11.2 14.8 L5.2 18.4 L8.8 13 L3 10.3 L9.5 10.5 L6.6 4.6 L10.9 8.2 Z" fill="white"/>
                                        </svg>
                                    </div>
                                }
                            </div>
                            <div class="msg-body">
                                <div class="msg-sender">@(msg.IsUser ? "나" : "Fab Copilot")</div>
                                @if (msg.IsEditing)
                                {
                                    <div class="msg-edit-area">
                                        <textarea class="edit-textarea" @bind="msg.EditText" @bind:event="oninput" rows="3"></textarea>
                                        <div class="edit-actions">
                                            <button class="btn-primary-sm" @onclick="() => SaveEdit(idx)">저장 후 전송</button>
                                            <button class="btn-secondary-sm" @onclick="() => CancelEdit(idx)">취소</button>
                                        </div>
                                    </div>
                                }
                                else if (msg.IsUser)
                                {
                                    <div class="msg-content user-text">@msg.Text</div>
                                }
                                else if (msg.IsStreaming && _renderMode == "batch")
                                {
                                    <div class="msg-content batch-loading">
                                        <div class="skeleton-line" style="width:85%"></div>
                                        <div class="skeleton-line" style="width:70%"></div>
                                        <div class="skeleton-line" style="width:45%"></div>
                                        <span class="batch-loading-text">응답 생성 중...</span>
                                    </div>
                                }
                                else if (msg.IsStreaming && string.IsNullOrEmpty(msg.Text))
                                {
                                    <div class="msg-content typing-indicator">
                                        <span class="typing-dot"></span>
                                        <span class="typing-dot"></span>
                                        <span class="typing-dot"></span>
                                    </div>
                                }
                                else if (msg.IsStreaming && _renderMode == "jit" && !string.IsNullOrEmpty(msg.RenderedHtml))
                                {
                                    <div class="msg-content rendered-markdown">@((MarkupString)msg.RenderedHtml)</div>
                                    <span class="streaming-cursor"></span>
                                }
                                else if (msg.IsStreaming)
                                {
                                    <div class="msg-content streaming-text">@msg.Text</div>
                                    <span class="streaming-cursor"></span>
                                }
                                else
                                {
                                    <div class="msg-content rendered-markdown @(msg.FadeIn ? "msg-fade-in" : "")">@((MarkupString)(msg.RenderedHtml ?? msg.Text))</div>
                                }
                                @if (!string.IsNullOrEmpty(msg.Error))
                                {
                                    <div class="msg-error">@msg.Error</div>
                                }
                                @if (!msg.IsStreaming && !msg.IsEditing)
                                {
                                    <div class="msg-actions">
                                        @if (msg.IsUser)
                                        {
                                            <button class="action-btn" @onclick="() => StartEdit(idx)" title="편집" disabled="@_isSending">
                                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                            </button>
                                        }
                                        else
                                        {
                                            <button class="action-btn @(msg.CopyFeedback ? "action-copied" : "")" @onclick="() => CopyMessage(idx)" title="복사">
                                                @if (msg.CopyFeedback)
                                                {
                                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                                                }
                                                else
                                                {
                                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
                                                }
                                            </button>
                                            <button class="action-btn @(msg.Feedback == 1 ? "action-active" : "")" @onclick="() => SendFeedback(idx, true)" title="좋아요">
                                                <svg width="16" height="16" viewBox="0 0 24 24" fill="@(msg.Feedback == 1 ? "currentColor" : "none")" stroke="currentColor" stroke-width="2"><path d="M14 9V5a3 3 0 00-3-3l-4 9v11h11.28a2 2 0 002-1.7l1.38-9a2 2 0 00-2-2.3zM7 22H4a2 2 0 01-2-2v-7a2 2 0 012-2h3"/></svg>
                                            </button>
                                            <button class="action-btn @(msg.Feedback == -1 ? "action-active" : "")" @onclick="() => SendFeedback(idx, false)" title="싫어요">
                                                <svg width="16" height="16" viewBox="0 0 24 24" fill="@(msg.Feedback == -1 ? "currentColor" : "none")" stroke="currentColor" stroke-width="2"><path d="M10 15v4a3 3 0 003 3l4-9V2H5.72a2 2 0 00-2 1.7l-1.38 9a2 2 0 002 2.3zm7-13h2.67A2.31 2.31 0 0122 4v7a2.31 2.31 0 01-2.33 2H17"/></svg>
                                            </button>
                                            <button class="action-btn @(_ttsPlayingIdx == idx ? "action-active" : "")"
                                                    @onclick="() => PlayTts(idx)"
                                                    title="@(_ttsPlayingIdx == idx ? "TTS 중지" : "음성으로 듣기")"
                                                    disabled="@(_ttsLoading && _ttsPlayingIdx != idx)">
                                                @if (_ttsLoading && _ttsPlayingIdx == idx)
                                                {
                                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="spin-icon"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
                                                }
                                                else if (_ttsPlayingIdx == idx)
                                                {
                                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg>
                                                }
                                                else
                                                {
                                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M19.07 4.93a10 10 0 010 14.14"/><path d="M15.54 8.46a5 5 0 010 7.07"/></svg>
                                                }
                                            </button>
                                            @if (msg.Citations is { Count: > 0 })
                                            {
                                                <button class="action-btn" @onclick="() => ShowCitations(idx)" title="참조 문서">
                                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                                                </button>
                                            }
                                            @if (msg.LatencyMs > 0)
                                            {
                                                <span class="msg-latency">@(msg.LatencyMs)ms</span>
                                            }
                                            @if (idx == _messages.Count - 1)
                                            {
                                                <button class="action-btn" @onclick="RegenerateResponse" title="재생성" disabled="@_isSending">
                                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 11-2.12-9.36L23 10"/></svg>
                                                </button>
                                            }
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }
            }
        </div>

        <!-- Timeout Progress -->
        @if (_isSending)
        {
            <div class="timeout-progress">
                <div class="timeout-bar timeout-@_timeoutSeverity"
                     style="width: @(Math.Min(100, _elapsedSeconds * 100 / _timeoutBudgetSeconds))%"></div>
            </div>
            <div class="timeout-label">@_currentStage (@(_elapsedSeconds)초)</div>
        }

        @if (_showTimeoutNotification)
        {
            <div class="timeout-warning-popup timeout-level-@_timeoutLevel">
                <p>@_timeoutNotificationMessage</p>
                <div class="timeout-actions">
                    <button @onclick="ExtendTimeout">⏱ 시간 연장 (2x)</button>
                    <button @onclick="SimplifyQuery">💬 간단한 답변 요청</button>
                    @if (_hasPartialResponse)
                    {
                        <button @onclick="ShowPartialAndContinue">📄 부분 응답 표시</button>
                    }
                    <button @onclick="CancelTimeout" class="btn-cancel">✕ 취소 & 재시도</button>
                </div>
            </div>
        }

        <!-- Input Area -->
        <div class="chat-input-wrapper">
            <div class="chat-input-box">
                <button class="upload-btn" @onclick="TriggerFileUpload" title="파일 업로드" disabled="@(_isSending || _isUploading)">
                    @if (_isUploading)
                    {
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="spin-icon"><path d="M21 12a9 9 0 11-6.219-8.56"/></svg>
                    }
                    else
                    {
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21.44 11.05l-9.19 9.19a6 6 0 01-8.49-8.49l9.19-9.19a4 4 0 015.66 5.66l-9.2 9.19a2 2 0 01-2.83-2.83l8.49-8.48"/></svg>
                    }
                </button>
                <button class="voice-mode-btn @(_isVoiceMode ? "voice-mode-active " + VoicePhaseCssClass : "")"
                        @onclick="ToggleVoiceMode"
                        title="@(_isVoiceMode ? "음성 모드 종료" : "음성 모드")">
                    @if (_isVoiceMode && (_voicePhase == VoicePhase.Transcribing || _voicePhase == VoicePhase.Waiting))
                    {
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="spin-icon"><path d="M21 12a9 9 0 11-6.219-8.56"/></svg>
                    }
                    else
                    {
                        <svg width="18" height="16" viewBox="0 0 20 16" class="waveform-icon">
                            <rect class="wf-bar" x="1"  y="5"  width="2" height="6"  rx="1" fill="currentColor"/>
                            <rect class="wf-bar" x="5"  y="2"  width="2" height="12" rx="1" fill="currentColor"/>
                            <rect class="wf-bar" x="9"  y="0"  width="2" height="16" rx="1" fill="currentColor"/>
                            <rect class="wf-bar" x="13" y="3"  width="2" height="10" rx="1" fill="currentColor"/>
                            <rect class="wf-bar" x="17" y="5"  width="2" height="6"  rx="1" fill="currentColor"/>
                        </svg>
                    }
                </button>
                @if (!_isVoiceMode)
                {
                    <button class="mic-btn @(_isRecording ? "mic-recording" : "") @(_isTranscribing ? "mic-transcribing" : "")"
                            @onclick="ToggleRecording"
                            disabled="@(_isSending || _isTranscribing || _isUploading)"
                            title="@(_isRecording ? "녹음 중지" : "음성 입력")">
                        @if (_isTranscribing)
                        {
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="spin-icon"><path d="M21 12a9 9 0 11-6.219-8.56"/></svg>
                        }
                        else if (_isRecording)
                        {
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><rect x="6" y="6" width="12" height="12" rx="2"/></svg>
                        }
                        else
                        {
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 1a3 3 0 00-3 3v8a3 3 0 006 0V4a3 3 0 00-3-3z"/><path d="M19 10v2a7 7 0 01-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg>
                        }
                    </button>
                    @if (_isRecording)
                    {
                        <span class="recording-timer">@TimeSpan.FromSeconds(_recordingSeconds).ToString("mm\\:ss")</span>
                    }
                }
                <InputFile OnChange="HandleFileUpload" style="display:none" id="fileUploadInput" accept=".pdf,.md,.txt,.png,.jpg,.jpeg" />
                <div class="chat-textarea-wrapper">
                    <textarea id="chatInput"
                              class="chat-textarea"
                              @bind="UserMessage"
                              @bind:event="oninput"
                              @bind:after="AutoResizeInput"
                              @onkeydown="HandleKeyDown"
                              placeholder="@(_isRecording && !string.IsNullOrEmpty(_interimText) ? "" : "메시지를 입력하세요...")"
                              disabled="@_isSending"
                              rows="1"></textarea>
                    @if (_isRecording && !string.IsNullOrEmpty(_interimText))
                    {
                        <div class="interim-text">@_interimText</div>
                    }
                </div>
                @if (_isSending)
                {
                    <button class="input-action-btn stop-btn" @onclick="StopResponseAsync" title="중지">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><rect x="6" y="6" width="12" height="12" rx="2"/></svg>
                    </button>
                }
                else
                {
                    <button class="input-action-btn send-btn"
                            @onclick="SendMessageAsync"
                            disabled="@string.IsNullOrWhiteSpace(UserMessage)"
                            title="전송">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="19" x2="12" y2="5"/><polyline points="5 12 12 5 19 12"/></svg>
                    </button>
                }
            </div>
            @if (_isVoiceMode && _voicePhase != VoicePhase.Idle)
            {
                <div class="voice-status-bar @VoicePhaseCssClass">
                    @switch (_voicePhase)
                    {
                        case VoicePhase.Listening:
                            <span class="waveform-bars-inline">
                                <span class="wf-inline-bar"></span>
                                <span class="wf-inline-bar"></span>
                                <span class="wf-inline-bar"></span>
                                <span class="wf-inline-bar"></span>
                                <span class="wf-inline-bar"></span>
                            </span>
                            <span>듣는 중... @TimeSpan.FromSeconds(_recordingSeconds).ToString("mm\\:ss")</span>
                            break;
                        case VoicePhase.Transcribing:
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="spin-icon"><path d="M21 12a9 9 0 11-6.219-8.56"/></svg>
                            <span>변환 중...</span>
                            break;
                        case VoicePhase.Waiting:
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="spin-icon"><path d="M21 12a9 9 0 11-6.219-8.56"/></svg>
                            <span>응답 생성 중...</span>
                            break;
                        case VoicePhase.Speaking:
                            <span class="waveform-bars-inline waveform-bars-speaking">
                                <span class="wf-inline-bar"></span>
                                <span class="wf-inline-bar"></span>
                                <span class="wf-inline-bar"></span>
                                <span class="wf-inline-bar"></span>
                                <span class="wf-inline-bar"></span>
                            </span>
                            <span>음성 재생 중</span>
                            break;
                    }
                </div>
            }
            <div class="input-disclaimer">Fab Copilot은 장비 매뉴얼 기반으로 답변하며, 오류가 있을 수 있습니다.</div>
        </div>
    </main>

    <!-- ===== Log Analyzer Pane ===== -->
    <LogAnalyzerPane IsOpen="_logPaneOpen"
                     OnClose="CloseLogPane" />

    <!-- ===== Citation Pane ===== -->
    <CitationPane IsOpen="_citationPaneOpen"
                  Citations="_activeCitations"
                  AutoOpenPage="_autoOpenPage"
                  AutoOpenSeq="_autoOpenSeq"
                  OnClose="CloseCitationPane" />
</div>

@if (!string.IsNullOrEmpty(_connectionError))
{
    <div class="toast-error" @onclick="() => _connectionError = null">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
        @_connectionError
    </div>
}

@code {
    private string _equipmentId = "CMP01";
    private string EquipmentId
    {
        get => _equipmentId;
        set
        {
            if (_equipmentId == value) return;
            _equipmentId = value;
            _ = OnEquipmentChangedAsync();
        }
    }
    private string UserMessage { get; set; } = string.Empty;

    // Connection state
    private string _conversationId = Guid.NewGuid().ToString("N");
    private string? _connectionError;
    private bool _isSending;
    private bool _isStopping;

    // UI state
    private bool _sidebarOpen = true;
    private bool _citationPaneOpen;
    private bool _logPaneOpen;
    private List<CitationInfo>? _activeCitations;
    private string _selectedModelId = string.Empty;
    private string _searchMode = "hybrid";
    private string _renderMode = "jit";  // "jit" | "fade" | "batch"
    private List<ModelEntry> _availableModels = new();
    private List<EquipmentEntry> _availableEquipment = new();
    private readonly List<ChatMessageViewModel> _messages = new();

    // Conversation history (sidebar)
    private readonly List<ConversationItem> _conversationHistory = new();

    // Render throttle
    private int _renderCounter;
    private bool _renderPending;
    private Timer? _renderTimer;

    // Stale stream detection: auto-complete if no chunks arrive for N seconds
    private Timer? _staleStreamTimer;
    private const int StaleStreamTimeoutMs = 5000;

    // File upload
    private bool _isUploading;

    // Voice recording (STT)
    private bool _isRecording;
    private bool _isTranscribing;
    private string _interimText = "";
    private int _recordingSeconds;

    // Voice Mode (hands-free STT → LLM → TTS loop)
    private bool _isVoiceMode;
    private VoicePhase _voicePhase = VoicePhase.Idle;

    private enum VoicePhase { Idle, Listening, Transcribing, Waiting, Speaking }

    private string VoicePhaseCssClass => _voicePhase switch
    {
        VoicePhase.Listening => "voice-phase-listening",
        VoicePhase.Speaking => "voice-phase-speaking",
        VoicePhase.Transcribing or VoicePhase.Waiting => "voice-phase-processing",
        _ => ""
    };

    // Latency tracking
    private System.Diagnostics.Stopwatch? _latencyStopwatch;

    // Timeout progress (v4.83 enhanced)
    private Timer? _timeoutTimer;
    private int _elapsedSeconds;
    private string _currentStage = "";
    private bool _showTimeoutNotification;
    private string _timeoutSeverity = "normal";
    private int _timeoutBudgetSeconds = 180;
    private int _timeoutLevel; // 1=10s, 2=30s, 3=60s, 4=180s
    private string _timeoutNotificationMessage = "";
    private bool _hasPartialResponse;

    // Citation interop
    private DotNetObjectReference<Index>? _dotNetRef;
    private int? _autoOpenPage;
    private int _autoOpenSeq;

    private bool _isLoadingHistory;

    protected override async Task OnInitializedAsync()
    {
        ChatService.OnMessageReceived += HandleChunkReceived;
        ChatService.OnStateChanged += HandleStateChanged;

        var opts = ModelOptionsAccessor.Value;
        _availableModels = opts.Available;

        // Load persisted model from LlmService config, fall back to WebClient default
        var persistedModel = EmbeddingConfigService.GetCurrentLlmModel();
        _selectedModelId = !string.IsNullOrEmpty(persistedModel)
            ? persistedModel
            : (!string.IsNullOrEmpty(opts.Default) ? opts.Default : _availableModels.FirstOrDefault()?.Id ?? "");

        _searchMode = EmbeddingConfigService.GetCurrentSearchMode();

        var eqOpts = EquipmentOptionsAccessor.Value;
        _availableEquipment = eqOpts.Available;
        if (_availableEquipment.Count > 0)
            _equipmentId = !string.IsNullOrEmpty(eqOpts.Default) ? eqOpts.Default : _availableEquipment[0].Id;

        await LoadConversationHistoryAsync();
    }

    // ─── Sidebar ────────────────────────────────────────────────────────

    private void ToggleSidebar() => _sidebarOpen = !_sidebarOpen;

    private async Task StartNewChat()
    {
        // Exit voice mode if active
        if (_isVoiceMode) await ExitVoiceModeAsync();

        // Save current conversation to history
        SaveCurrentToHistory();

        // Reset state
        _messages.Clear();
        _conversationId = Guid.NewGuid().ToString("N");
        _isSending = false;
        _isStopping = false;

        // Disconnect and reconnect with fresh conversation
        if (ChatService.IsConnected)
        {
            await ChatService.DisconnectAsync();
        }

        StateHasChanged();
    }

    private async Task SwitchConversation(string convId)
    {
        var target = _conversationHistory.FirstOrDefault(c => c.Id == convId);
        if (target is null || target.Id == _conversationId) return;

        // Exit voice mode if active
        if (_isVoiceMode) await ExitVoiceModeAsync();

        SaveCurrentToHistory();

        _conversationId = target.Id;
        _messages.Clear();

        // If the sidebar item already has cached messages, use them
        if (target.Messages.Count > 0)
        {
            _messages.AddRange(target.Messages.Select(m => new ChatMessageViewModel
            {
                Text = m.Text,
                RenderedHtml = m.RenderedHtml,
                IsUser = m.IsUser,
                Error = m.Error
            }));
        }
        else
        {
            // Lazy-load full messages from Redis
            var detail = await ChatService.GetConversationAsync(EquipmentId, convId);
            if (detail?.Messages is { Count: > 0 })
            {
                foreach (var m in detail.Messages)
                {
                    var isUser = m.Role == 0; // 0=User
                    var text = m.Text;
                    var html = isUser ? null : await RenderMarkdownAsync(text);
                    _messages.Add(new ChatMessageViewModel
                    {
                        Text = text,
                        RenderedHtml = html,
                        IsUser = isUser
                    });
                }
                // Cache into the sidebar item
                target.Messages = _messages.Select(m => new ChatMessageViewModel
                {
                    Text = m.Text, RenderedHtml = m.RenderedHtml, IsUser = m.IsUser, Error = m.Error
                }).ToList();
            }
        }

        StateHasChanged();
        await ScrollToBottom();
    }

    private async Task DeleteConversationAsync(string convId)
    {
        var deleted = await ChatService.DeleteConversationAsync(EquipmentId, convId);
        if (!deleted) return;

        _conversationHistory.RemoveAll(c => c.Id == convId);

        // If the active conversation was deleted, start a new chat
        if (convId == _conversationId)
        {
            _messages.Clear();
            _conversationId = Guid.NewGuid().ToString("N");
            _isSending = false;
            _isStopping = false;
        }

        StateHasChanged();
    }

    private void SaveCurrentToHistory()
    {
        if (_messages.Count == 0) return;

        var existing = _conversationHistory.FirstOrDefault(c => c.Id == _conversationId);
        if (existing is not null)
        {
            existing.Messages = _messages.Select(m => new ChatMessageViewModel
            {
                Text = m.Text, RenderedHtml = m.RenderedHtml, IsUser = m.IsUser, Error = m.Error
            }).ToList();
        }
        else
        {
            var title = _messages.FirstOrDefault(m => m.IsUser)?.Text ?? "새 대화";
            if (title.Length > 30) title = title[..30] + "...";
            _conversationHistory.Insert(0, new ConversationItem
            {
                Id = _conversationId,
                Title = title,
                Messages = _messages.Select(m => new ChatMessageViewModel
                {
                    Text = m.Text, RenderedHtml = m.RenderedHtml, IsUser = m.IsUser, Error = m.Error
                }).ToList()
            });
        }
    }

    private async Task LoadConversationHistoryAsync()
    {
        _isLoadingHistory = true;
        StateHasChanged();
        try
        {
            var summaries = await ChatService.GetConversationListAsync(EquipmentId);
            _conversationHistory.Clear();
            foreach (var s in summaries)
            {
                _conversationHistory.Add(new ConversationItem
                {
                    Id = s.ConversationId,
                    Title = s.Title,
                    Messages = [] // lazy-loaded on click
                });
            }
        }
        catch { /* already logged in ChatService */ }
        finally
        {
            _isLoadingHistory = false;
            StateHasChanged();
        }
    }

    private async Task OnEquipmentChangedAsync()
    {
        SaveCurrentToHistory();
        _messages.Clear();
        _conversationId = Guid.NewGuid().ToString("N");
        if (ChatService.IsConnected)
            await ChatService.DisconnectAsync();
        try { await JS.InvokeVoidAsync("audioRecorder.updateEquipmentId", _equipmentId); } catch { }
        await LoadConversationHistoryAsync();
    }

    // ─── Connection ─────────────────────────────────────────────────────

    private async Task EnsureConnectedAsync()
    {
        if (ChatService.IsConnected) return;

        _connectionError = null;
        try
        {
            await ChatService.ConnectAsync(EquipmentId.Trim());
        }
        catch (Exception ex)
        {
            _connectionError = $"연결 실패: {ex.Message}";
            throw;
        }
    }

    // ─── Chat ───────────────────────────────────────────────────────────

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            // If recording in voice mode, exit voice mode first
            if (_isVoiceMode && _isRecording)
                await ExitVoiceModeAsync();

            await SendMessageAsync();
        }
    }

    private async Task AutoResizeInput()
    {
        try { await JS.InvokeVoidAsync("chatInput.autoResize", "chatInput"); } catch { }
    }

    private void SetQuickMessage(string text)
    {
        UserMessage = text;
        StateHasChanged();
    }

    private async Task SendMessageAsync()
    {
        if (string.IsNullOrWhiteSpace(UserMessage) || _isSending)
            return;

        var text = UserMessage.Trim();
        UserMessage = string.Empty;
        _isSending = true;

        // Auto-connect
        try
        {
            await EnsureConnectedAsync();
        }
        catch
        {
            _isSending = false;
            StateHasChanged();
            return;
        }

        _messages.Add(new ChatMessageViewModel { Text = text, IsUser = true });
        _messages.Add(new ChatMessageViewModel { IsUser = false, IsStreaming = true });
        _latencyStopwatch = System.Diagnostics.Stopwatch.StartNew();
        StartTimeoutTimer();
        StateHasChanged();
        await ScrollToBottom();

        try
        {
            await ChatService.SendMessageAsync(_conversationId, EquipmentId.Trim(), text, _selectedModelId, _searchMode);
        }
        catch (Exception ex)
        {
            var last = _messages.LastOrDefault(m => !m.IsUser);
            if (last is not null) { last.Error = ex.Message; last.IsStreaming = false; }
            _isSending = false;
            StateHasChanged();
        }

        try { await JS.InvokeVoidAsync("chatInput.resetHeight", "chatInput"); } catch { }
    }

    private async Task StopResponseAsync()
    {
        _isStopping = true;
        StopRenderTimer();
        StopStaleStreamTimer();

        // Stop streaming TTS if active
        if (_ttsStreamingActive)
        {
            _ttsStreamingActive = false;
            try { await JS.InvokeVoidAsync("fabTts.stop"); } catch { }
            _ttsPlayingIdx = -1;
        }

        var assistantMsg = _messages.LastOrDefault(m => !m.IsUser && m.IsStreaming);
        if (assistantMsg is not null)
        {
            assistantMsg.IsStreaming = false;
            if (!string.IsNullOrEmpty(assistantMsg.Text))
                assistantMsg.RenderedHtml = await RenderMarkdownAsync(assistantMsg.Text);
        }

        _isSending = false;
        await ChatService.DisconnectAsync();
        try { await ChatService.ConnectAsync(EquipmentId.Trim()); } catch { }

        _isStopping = false;
        StateHasChanged();
    }

    // ─── Edit / Copy / Regenerate ───────────────────────────────────────

    private void StartEdit(int index)
    {
        if (_isSending || index < 0 || index >= _messages.Count) return;
        var msg = _messages[index];
        if (!msg.IsUser) return;
        msg.IsEditing = true;
        msg.EditText = msg.Text;
        StateHasChanged();
    }

    private async Task SaveEdit(int index)
    {
        var msg = _messages[index];
        var newText = msg.EditText?.Trim();
        if (string.IsNullOrEmpty(newText)) { CancelEdit(index); return; }

        msg.Text = newText;
        msg.IsEditing = false;

        // Remove all messages after this one
        if (index + 1 < _messages.Count)
            _messages.RemoveRange(index + 1, _messages.Count - index - 1);

        // Send as new request
        _isSending = true;
        _messages.Add(new ChatMessageViewModel { IsUser = false, IsStreaming = true });
        StateHasChanged();
        await ScrollToBottom();

        try
        {
            await EnsureConnectedAsync();
            // New conversation for the edited branch
            _conversationId = Guid.NewGuid().ToString("N");
            await ChatService.SendMessageAsync(_conversationId, EquipmentId.Trim(), newText, _selectedModelId, _searchMode);
        }
        catch (Exception ex)
        {
            var last = _messages.LastOrDefault(m => !m.IsUser);
            if (last is not null) { last.Error = ex.Message; last.IsStreaming = false; }
            _isSending = false;
            StateHasChanged();
        }
    }

    private void CancelEdit(int index)
    {
        if (index >= 0 && index < _messages.Count)
        {
            _messages[index].IsEditing = false;
            _messages[index].EditText = string.Empty;
        }
        StateHasChanged();
    }

    private async Task CopyMessage(int index)
    {
        if (index < 0 || index >= _messages.Count) return;
        var msg = _messages[index];
        try
        {
            await JS.InvokeVoidAsync("clipboard.copyText", msg.Text);
            msg.CopyFeedback = true;
            StateHasChanged();
            await Task.Delay(2000);
            msg.CopyFeedback = false;
            StateHasChanged();
        }
        catch { }
    }

    private async Task RegenerateResponse()
    {
        if (_isSending) return;

        // Find the last user message
        var lastUserIdx = -1;
        for (var i = _messages.Count - 1; i >= 0; i--)
        {
            if (_messages[i].IsUser) { lastUserIdx = i; break; }
        }
        if (lastUserIdx < 0) return;

        var userText = _messages[lastUserIdx].Text;

        // Remove the last assistant message
        if (lastUserIdx + 1 < _messages.Count)
            _messages.RemoveRange(lastUserIdx + 1, _messages.Count - lastUserIdx - 1);

        _isSending = true;
        _messages.Add(new ChatMessageViewModel { IsUser = false, IsStreaming = true });
        StateHasChanged();
        await ScrollToBottom();

        try
        {
            await EnsureConnectedAsync();
            _conversationId = Guid.NewGuid().ToString("N");
            await ChatService.SendMessageAsync(_conversationId, EquipmentId.Trim(), userText, _selectedModelId, _searchMode);
        }
        catch (Exception ex)
        {
            var last = _messages.LastOrDefault(m => !m.IsUser);
            if (last is not null) { last.Error = ex.Message; last.IsStreaming = false; }
            _isSending = false;
            StateHasChanged();
        }
    }

    // ─── Feedback ─────────────────────────────────────────────────────

    private async Task SendFeedback(int index, bool isPositive)
    {
        if (index < 0 || index >= _messages.Count) return;
        var msg = _messages[index];
        if (msg.IsUser) return;

        // Toggle: clicking the same button clears it
        var newValue = msg.Feedback == (isPositive ? 1 : -1) ? 0 : (isPositive ? 1 : -1);
        msg.Feedback = newValue;
        StateHasChanged();

        // Send to backend audit trail (only when setting, not clearing)
        if (newValue != 0)
        {
            await ChatService.SendFeedbackAsync(_conversationId, EquipmentId, index, isPositive);
        }
    }

    // ─── Citation Interop ─────────────────────────────────────────────

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("citationInterop.init", _dotNetRef);

            await JS.InvokeVoidAsync("audioRecorder.init", _dotNetRef, EquipmentId);

            var savedRenderMode = await JS.InvokeAsync<string>("clientSettings.getRenderMode");
            if (!string.IsNullOrEmpty(savedRenderMode))
            {
                _renderMode = savedRenderMode;
            }

            var savedTimeout = await JS.InvokeAsync<string>("clientSettings.getTimeoutBudget");
            if (!string.IsNullOrEmpty(savedTimeout) && int.TryParse(savedTimeout, out var budget))
            {
                _timeoutBudgetSeconds = budget;
            }

            StateHasChanged();
        }
    }

    [JSInvokable]
    public Task OnCitationPageClick(int page)
    {
        // Ensure we have citations from the last assistant message
        if (_activeCitations is not { Count: > 0 })
        {
            var lastAssistant = _messages.LastOrDefault(m => !m.IsUser && m.Citations is { Count: > 0 });
            if (lastAssistant?.Citations is not null)
            {
                _activeCitations = lastAssistant.Citations;
            }
        }

        _autoOpenPage = page;
        _autoOpenSeq++;  // increment so CitationPane detects repeated clicks on same page
        _citationPaneOpen = true;
        StateHasChanged();
        return Task.CompletedTask;
    }

    // ─── Citation Pane ─────────────────────────────────────────────────

    private void ShowCitations(int index)
    {
        if (index < 0 || index >= _messages.Count) return;
        var msg = _messages[index];
        if (msg.Citations is { Count: > 0 })
        {
            _activeCitations = msg.Citations;
            _citationPaneOpen = true;
            StateHasChanged();
        }
    }

    private void CloseCitationPane()
    {
        _citationPaneOpen = false;
        _autoOpenPage = null;
        StateHasChanged();
    }

    private void ToggleCitationPane()
    {
        if (_citationPaneOpen)
        {
            CloseCitationPane();
        }
        else
        {
            // Re-open with last active citations, or show empty state
            if (_activeCitations is null || _activeCitations.Count == 0)
            {
                // Find last assistant message with citations
                var lastWithCitations = _messages.LastOrDefault(m => !m.IsUser && m.Citations is { Count: > 0 });
                if (lastWithCitations is not null)
                    _activeCitations = lastWithCitations.Citations;
            }
            _citationPaneOpen = true;
            StateHasChanged();
        }
    }

    // ─── Log Analyzer Pane ─────────────────────────────────────────────

    private void ToggleLogPane()
    {
        _logPaneOpen = !_logPaneOpen;
        StateHasChanged();
    }

    private void CloseLogPane()
    {
        _logPaneOpen = false;
        StateHasChanged();
    }

    // ─── TTS (Text-to-Speech) ───────────────────────────────────────────

    private int _ttsPlayingIdx = -1;
    private bool _ttsLoading;
    private bool _ttsStreamingActive;

    private async Task PlayLastTts()
    {
        // Find last assistant message
        var lastIdx = -1;
        for (var i = _messages.Count - 1; i >= 0; i--)
        {
            if (!_messages[i].IsUser && !string.IsNullOrWhiteSpace(_messages[i].Text))
            {
                lastIdx = i;
                break;
            }
        }
        if (lastIdx < 0) return;
        await PlayTts(lastIdx);
    }

    private async Task PlayTts(int idx)
    {
        // Stop streaming TTS if active before manual play
        if (_ttsStreamingActive)
        {
            _ttsStreamingActive = false;
            await JS.InvokeVoidAsync("fabTts.stop");
        }

        // If already playing this message, stop it
        if (_ttsPlayingIdx == idx)
        {
            await JS.InvokeVoidAsync("fabTts.stop");
            _ttsPlayingIdx = -1;
            return;
        }

        var msg = _messages[idx];
        if (string.IsNullOrWhiteSpace(msg.Text)) return;

        _ttsPlayingIdx = idx;
        _ttsLoading = true;
        StateHasChanged();

        try
        {
            var gatewayBase = Configuration["Gateway:HttpUrl"] ?? "http://localhost:5000";
            // Strip markdown for cleaner TTS input
            var ttsText = System.Text.RegularExpressions.Regex.Replace(
                msg.Text, @"\*\*|##|#+\s|`[^`]*`|\[([^\]]*)\]\([^\)]*\)", "$1").Trim();
            if (string.IsNullOrWhiteSpace(ttsText)) ttsText = msg.Text;
            await JS.InvokeVoidAsync("fabTts.play", gatewayBase, ttsText, _dotNetRef);
        }
        catch (Exception ex)
        {
            _connectionError = $"TTS 오류: {ex.Message}";
            _ttsPlayingIdx = -1;
        }
        finally
        {
            _ttsLoading = false;
            StateHasChanged();
        }
    }

    [JSInvokable]
    public void OnTtsEnded()
    {
        _ttsPlayingIdx = -1;
        _ttsStreamingActive = false;

        if (_isVoiceMode)
        {
            _ = InvokeAsync(async () =>
            {
                StateHasChanged();
                await VoiceStartListeningAsync();
            });
            return;
        }

        InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public void OnTtsError(string error)
    {
        _connectionError = $"TTS 오류: {error}";
        _ttsPlayingIdx = -1;
        _ttsLoading = false;
        _ttsStreamingActive = false;

        if (_isVoiceMode)
        {
            // TTS failed but voice mode continues — skip to next listening cycle
            _ = InvokeAsync(async () =>
            {
                StateHasChanged();
                await Task.Delay(1000); // brief pause so user sees the error toast
                if (_isVoiceMode) await VoiceStartListeningAsync();
            });
            return;
        }

        InvokeAsync(StateHasChanged);
    }

    // ─── Voice Recording (STT) ─────────────────────────────────────────

    private async Task ToggleRecording()
    {
        if (_isVoiceMode) { await ToggleVoiceMode(); return; }

        if (_isRecording)
        {
            _isRecording = false;
            _recordingSeconds = 0;
            // For Whisper mode, show transcribing spinner while server processes
            var engine = await JS.InvokeAsync<string>("audioRecorder.getEngine");
            if (engine == "whisper")
                _isTranscribing = true;
            await JS.InvokeVoidAsync("audioRecorder.stop");
        }
        else
        {
            _interimText = "";
            _recordingSeconds = 0;
            var started = await JS.InvokeAsync<bool>("audioRecorder.start");
            _isRecording = started;
        }
    }

    [JSInvokable]
    public Task OnTranscriptionComplete(string text)
    {
        _isTranscribing = false;
        _isRecording = false;
        _interimText = "";
        _recordingSeconds = 0;

        if (_isVoiceMode)
        {
            _voicePhase = VoicePhase.Transcribing;
            StateHasChanged();
            // Auto-send in voice mode
            _ = InvokeAsync(async () => await VoiceAutoSendAsync(text));
            return Task.CompletedTask;
        }

        if (!string.IsNullOrWhiteSpace(text))
            UserMessage = text;
        StateHasChanged();
        return Task.CompletedTask;
    }

    [JSInvokable]
    public Task OnTranscriptionError(string error)
    {
        _isTranscribing = false;
        _isRecording = false;
        _interimText = "";
        _recordingSeconds = 0;
        _connectionError = $"음성 인식 실패: {error}";

        if (_isVoiceMode)
            _ = InvokeAsync(async () => await ExitVoiceModeAsync());

        StateHasChanged();
        return Task.CompletedTask;
    }

    [JSInvokable]
    public Task OnInterimResult(string text, bool isFinal)
    {
        if (isFinal)
        {
            _interimText = "";
            _isRecording = false;
            _recordingSeconds = 0;

            if (_isVoiceMode)
            {
                _voicePhase = VoicePhase.Transcribing;
                StateHasChanged();
                _ = InvokeAsync(async () => await VoiceAutoSendAsync(text));
                return Task.CompletedTask;
            }

            UserMessage = text;
        }
        else
        {
            _interimText = text;
        }
        StateHasChanged();
        return Task.CompletedTask;
    }

    [JSInvokable]
    public Task OnRecordingTick(int seconds)
    {
        _recordingSeconds = seconds;
        StateHasChanged();
        return Task.CompletedTask;
    }

    // ─── Voice Mode (hands-free loop) ────────────────────────────────────

    private async Task ToggleVoiceMode()
    {
        if (_isVoiceMode)
        {
            await ExitVoiceModeAsync();
        }
        else
        {
            // User gesture context — acquire mic + unlock audio ONCE for entire session
            try { await JS.InvokeVoidAsync("fabTts.unlockAudio"); } catch { }

            // Pre-acquire mic — returns false if permission denied
            bool micAcquired = false;
            try { micAcquired = await JS.InvokeAsync<bool>("audioRecorder.setVoiceMode", true); }
            catch { micAcquired = false; }

            if (!micAcquired)
            {
                _connectionError = "마이크 권한이 거부되었습니다. 브라우저 설정에서 마이크 접근을 허용하세요.";
                StateHasChanged();
                return;
            }

            _isVoiceMode = true;
            StateHasChanged();
            await VoiceStartListeningAsync();
        }
    }

    private async Task ExitVoiceModeAsync()
    {
        _isVoiceMode = false;
        _voicePhase = VoicePhase.Idle;
        _ttsStreamingActive = false;

        // Disable silence auto-stop
        try { await JS.InvokeVoidAsync("audioRecorder.setVoiceMode", false); } catch { }

        // Stop recording if active
        if (_isRecording)
        {
            _isRecording = false;
            _recordingSeconds = 0;
            try { await JS.InvokeVoidAsync("audioRecorder.stop"); } catch { }
        }

        // Stop TTS if playing
        if (_ttsPlayingIdx >= 0)
        {
            try { await JS.InvokeVoidAsync("fabTts.stop"); } catch { }
            _ttsPlayingIdx = -1;
        }

        _isTranscribing = false;
        _ttsLoading = false;
        _interimText = "";
        StateHasChanged();
    }

    private async Task VoiceStartListeningAsync()
    {
        if (!_isVoiceMode) return;

        _voicePhase = VoicePhase.Listening;
        _interimText = "";
        _recordingSeconds = 0;
        StateHasChanged();

        try
        {
            // setVoiceMode(true) already called in ToggleVoiceMode — mic is pre-acquired
            var started = await JS.InvokeAsync<bool>("audioRecorder.start");
            _isRecording = started;
            if (!started)
            {
                await ExitVoiceModeAsync();
                _connectionError = "마이크 시작 실패";
            }
        }
        catch (Exception ex)
        {
            await ExitVoiceModeAsync();
            _connectionError = $"마이크 오류: {ex.Message}";
        }
        StateHasChanged();
    }

    private async Task VoiceAutoSendAsync(string text)
    {
        if (!_isVoiceMode || string.IsNullOrWhiteSpace(text)) return;

        _voicePhase = VoicePhase.Waiting;
        StateHasChanged();

        UserMessage = text;
        await SendMessageAsync();
    }

    private async Task VoiceAutoTtsAsync()
    {
        if (!_isVoiceMode) return;

        // Find the last completed assistant message
        var lastIdx = -1;
        for (var i = _messages.Count - 1; i >= 0; i--)
        {
            if (!_messages[i].IsUser && !string.IsNullOrWhiteSpace(_messages[i].Text) && !_messages[i].IsStreaming)
            {
                lastIdx = i;
                break;
            }
        }
        if (lastIdx < 0)
        {
            // No message to speak — restart listening
            await VoiceStartListeningAsync();
            return;
        }

        _voicePhase = VoicePhase.Speaking;
        StateHasChanged();
        await PlayTts(lastIdx);
    }

    // ─── File Upload ─────────────────────────────────────────────────────

    private async Task TriggerFileUpload()
    {
        try { await JS.InvokeVoidAsync("document.getElementById('fileUploadInput').click"); } catch { }
    }

    private async Task HandleFileUpload(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is null) return;

        _isUploading = true;
        StateHasChanged();

        try
        {
            var gatewayBase = "http://localhost:5000";
            using var http = new HttpClient { BaseAddress = new Uri(gatewayBase) };
            using var content = new MultipartFormDataContent();
            using var stream = file.OpenReadStream(maxAllowedSize: 50 * 1024 * 1024);
            var streamContent = new StreamContent(stream);
            content.Add(streamContent, "file", file.Name);

            var response = await http.PostAsync($"/api/upload/{EquipmentId.Trim()}", content);

            if (response.IsSuccessStatusCode)
            {
                _messages.Add(new ChatMessageViewModel
                {
                    Text = $"[파일 업로드 완료: {file.Name} ({file.Size / 1024}KB)]",
                    IsUser = true
                });
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                _messages.Add(new ChatMessageViewModel
                {
                    Text = $"[파일 업로드 실패: {file.Name}]",
                    IsUser = true,
                    Error = error
                });
            }
        }
        catch (Exception ex)
        {
            _messages.Add(new ChatMessageViewModel
            {
                Text = $"[파일 업로드 오류: {file.Name}]",
                IsUser = true,
                Error = ex.Message
            });
        }
        finally
        {
            _isUploading = false;
            StateHasChanged();
            await ScrollToBottom();
        }
    }

    // ─── Streaming handler ──────────────────────────────────────────────

    private void HandleChunkReceived(FabCopilot.Contracts.Messages.ChatStreamChunk chunk)
    {
        if (_isStopping) return;

        InvokeAsync(async () =>
        {
            if (_isStopping) return;

            var assistantMsg = _messages.LastOrDefault(m => !m.IsUser && m.IsStreaming);
            if (assistantMsg is null)
            {
                assistantMsg = new ChatMessageViewModel { IsUser = false, IsStreaming = true };
                _messages.Add(assistantMsg);

                // Voice mode: start streaming TTS for real-time sentence playback
                if (_isVoiceMode)
                {
                    try
                    {
                        _voicePhase = VoicePhase.Speaking;
                        _ttsPlayingIdx = _messages.Count - 1;
                        await JS.InvokeVoidAsync("fabTts.playStream", _dotNetRef);
                        _ttsStreamingActive = true;
                    }
                    catch { _ttsStreamingActive = false; }
                }
            }

            if (!string.IsNullOrEmpty(chunk.Error))
            {
                assistantMsg.Error = chunk.Error;
                assistantMsg.IsStreaming = false;
                _isSending = false;
                StopRenderTimer();
                StopStaleStreamTimer();
                StopTimeoutTimer();
                assistantMsg.RenderedHtml = await RenderMarkdownAsync(assistantMsg.Text);

                // Voice mode: exit on error
                if (_isVoiceMode)
                {
                    _ttsStreamingActive = false;
                    await ExitVoiceModeAsync();
                }

                StateHasChanged();
                await ScrollToBottom();
            }
            else if (chunk.IsComplete)
            {
                assistantMsg.IsStreaming = false;
                _isSending = false;
                StopRenderTimer();
                StopStaleStreamTimer();
                StopTimeoutTimer();
                assistantMsg.RenderedHtml = await RenderMarkdownAsync(assistantMsg.Text);
                if (_renderMode == "fade")
                    assistantMsg.FadeIn = true;

                // Record latency
                if (_latencyStopwatch is not null)
                {
                    _latencyStopwatch.Stop();
                    assistantMsg.LatencyMs = _latencyStopwatch.ElapsedMilliseconds;
                    _latencyStopwatch = null;
                }

                // Store citations from the completion chunk
                if (chunk.Citations is { Count: > 0 })
                {
                    assistantMsg.Citations = chunk.Citations;
                    _activeCitations = chunk.Citations;
                    _citationPaneOpen = true;
                }

                StateHasChanged();
                await ScrollToBottom();

                // Voice mode: flush streaming TTS or fall back to full-text TTS
                if (_isVoiceMode)
                {
                    if (_ttsStreamingActive)
                    {
                        // Flush remaining buffer — OnTtsEnded callback handles voice cycle
                        try { await JS.InvokeVoidAsync("fabTts.flushStream"); } catch { }
                    }
                    else
                    {
                        await VoiceAutoTtsAsync();
                    }
                }
            }
            else
            {
                assistantMsg.Text += chunk.Token;

                // Feed token to streaming TTS for real-time sentence synthesis
                if (_ttsStreamingActive)
                {
                    try { await JS.InvokeVoidAsync("fabTts.feedText", chunk.Token); } catch { }
                }

                if (_renderMode != "batch")
                {
                    _renderCounter++;
                    ScheduleRenderUpdate();
                }
                // batch 모드: Text만 축적, 렌더 안 함 → IsComplete 시 한 번에 표시
                ResetStaleStreamTimer();
            }
        });
    }

    private void ScheduleRenderUpdate()
    {
        if (_renderPending) return;
        _renderPending = true;
        var interval = _renderMode == "jit" ? 300 : 100;
        _renderTimer ??= new Timer(_ =>
        {
            InvokeAsync(async () =>
            {
                _renderPending = false;
                var msg = _messages.LastOrDefault(m => !m.IsUser && m.IsStreaming);
                if (msg is not null)
                {
                    if (_renderMode == "jit" && !string.IsNullOrEmpty(msg.Text))
                    {
                        try
                        {
                            msg.RenderedHtml = await JS.InvokeAsync<string>(
                                "chatRenderer.renderMarkdownLite", msg.Text);
                        }
                        catch { /* JS interop may fail during dispose */ }
                    }
                    StateHasChanged();
                    await ScrollToBottom();
                }
            });
        }, null, Timeout.Infinite, Timeout.Infinite);
        _renderTimer.Change(interval, Timeout.Infinite);
    }

    private void StopRenderTimer()
    {
        _renderPending = false;
        _renderTimer?.Change(Timeout.Infinite, Timeout.Infinite);
    }

    // ─── Stale Stream Detection ──────────────────────────────────────────

    private void ResetStaleStreamTimer()
    {
        _staleStreamTimer ??= new Timer(_ =>
        {
            InvokeAsync(async () =>
            {
                // No chunk received for StaleStreamTimeoutMs — treat as complete
                var msg = _messages.LastOrDefault(m => !m.IsUser && m.IsStreaming);
                if (msg is null || !_isSending) return;

                msg.IsStreaming = false;
                _isSending = false;
                StopRenderTimer();
                StopTimeoutTimer();
                msg.RenderedHtml = await RenderMarkdownAsync(msg.Text);

                if (_latencyStopwatch is not null)
                {
                    _latencyStopwatch.Stop();
                    msg.LatencyMs = _latencyStopwatch.ElapsedMilliseconds;
                    _latencyStopwatch = null;
                }

                StateHasChanged();
                await ScrollToBottom();
            });
        }, null, Timeout.Infinite, Timeout.Infinite);
        _staleStreamTimer.Change(StaleStreamTimeoutMs, Timeout.Infinite);
    }

    private void StopStaleStreamTimer()
    {
        _staleStreamTimer?.Change(Timeout.Infinite, Timeout.Infinite);
    }

    // ─── Timeout Handling (v3.2 §5.3) ──────────────────────────────────

    private void StartTimeoutTimer()
    {
        _elapsedSeconds = 0;
        _showTimeoutNotification = false;
        _timeoutSeverity = "normal";
        // _timeoutBudgetSeconds is kept from Settings (default 180)
        _currentStage = "검색 중...";
        _timeoutLevel = 0;
        _hasPartialResponse = false;

        _timeoutTimer?.Dispose();
        _timeoutTimer = new Timer(_ =>
        {
            InvokeAsync(() =>
            {
                if (!_isSending) return;

                _elapsedSeconds++;

                // Check if we have partial response content
                var lastMsg = _messages.LastOrDefault(m => !m.IsUser);
                _hasPartialResponse = lastMsg != null && !string.IsNullOrEmpty(lastMsg.Text) && lastMsg.Text.Length > 20;

                // Infer stage from elapsed time
                _currentStage = _elapsedSeconds switch
                {
                    <= 5 => "검색 중...",
                    <= 10 => "문서 분석 중...",
                    <= 30 => "답변 생성 중...",
                    _ => "응답 대기 중..."
                };

                // Progressive notification at 10s/30s/60s/180s
                var newLevel = _elapsedSeconds switch
                {
                    >= 180 => 4,
                    >= 60 => 3,
                    >= 30 => 2,
                    >= 10 => 1,
                    _ => 0
                };

                // Show notification when level changes
                if (newLevel > _timeoutLevel)
                {
                    _timeoutLevel = newLevel;
                    _timeoutNotificationMessage = _timeoutLevel switch
                    {
                        1 => $"응답 생성 중입니다... ({_elapsedSeconds}초 경과)",
                        2 => $"응답 시간이 길어지고 있습니다. ({_elapsedSeconds}초 경과) 복잡한 쿼리일 수 있습니다.",
                        3 => $"예상보다 응답이 지연되고 있습니다. ({_elapsedSeconds}초 경과) 쿼리를 간소화하시겠습니까?",
                        4 => $"응답 시간이 매우 길어지고 있습니다. ({_elapsedSeconds}초 경과) 서버 상태를 확인해 주세요.",
                        _ => ""
                    };

                    if (_timeoutLevel >= 2)
                    {
                        _showTimeoutNotification = true;
                    }
                }
                else if (_showTimeoutNotification)
                {
                    // Update message with current elapsed time
                    _timeoutNotificationMessage = _timeoutLevel switch
                    {
                        2 => $"응답 시간이 길어지고 있습니다. ({_elapsedSeconds}초 경과) 복잡한 쿼리일 수 있습니다.",
                        3 => $"예상보다 응답이 지연되고 있습니다. ({_elapsedSeconds}초 경과) 쿼리를 간소화하시겠습니까?",
                        4 => $"응답 시간이 매우 길어지고 있습니다. ({_elapsedSeconds}초 경과) 서버 상태를 확인해 주세요.",
                        _ => _timeoutNotificationMessage
                    };
                }

                // Severity for progress bar color
                if (_elapsedSeconds >= _timeoutBudgetSeconds * 0.9)
                {
                    if (_timeoutSeverity != "exceeded")
                        FabMetrics.TimeoutOccurrenceCount.Add(1);
                    _timeoutSeverity = "exceeded";
                    _showTimeoutNotification = true;
                }
                else if (_elapsedSeconds >= _timeoutBudgetSeconds * 0.6)
                    _timeoutSeverity = "critical";
                else if (_elapsedSeconds >= 30)
                    _timeoutSeverity = "warning";
                else
                    _timeoutSeverity = "normal";

                StateHasChanged();
            });
        }, null, 1000, 1000);
    }

    private void StopTimeoutTimer()
    {
        _timeoutTimer?.Dispose();
        _timeoutTimer = null;
        _showTimeoutNotification = false;
        _elapsedSeconds = 0;
        _timeoutLevel = 0;
    }

    private void ExtendTimeout()
    {
        FabMetrics.TimeoutExtendCount.Add(1);
        _timeoutBudgetSeconds = Math.Min(_timeoutBudgetSeconds * 2, 600);
        _showTimeoutNotification = false;
        _timeoutSeverity = "warning";
        StateHasChanged();
    }

    private async Task CancelTimeout()
    {
        FabMetrics.TimeoutCancelCount.Add(1);
        _showTimeoutNotification = false;
        StopTimeoutTimer();
        await StopResponseAsync();
    }

    private async Task SimplifyQuery()
    {
        FabMetrics.TimeoutSimplifyCount.Add(1);
        _showTimeoutNotification = false;
        StopTimeoutTimer();

        // Find the last user message
        var lastUserMsg = _messages.LastOrDefault(m => m.IsUser);
        var originalText = lastUserMsg?.Text ?? "";

        await StopResponseAsync();

        if (!string.IsNullOrWhiteSpace(originalText))
        {
            UserMessage = $"간단히 답변해주세요: {originalText}";
            StateHasChanged();
            await SendMessageAsync();
        }
    }

    private async Task ShowPartialAndContinue()
    {
        // Keep the partial response visible, dismiss the notification
        _showTimeoutNotification = false;
        var lastMsg = _messages.LastOrDefault(m => !m.IsUser);
        if (lastMsg != null)
        {
            lastMsg.Text += "\n\n---\n⚠️ *응답이 지연되어 부분 응답을 표시합니다. 응답이 완료되면 자동으로 업데이트됩니다.*";
            lastMsg.RenderedHtml = await RenderMarkdownAsync(lastMsg.Text);
        }
        StateHasChanged();
    }

    // ─── Render Mode ─────────────────────────────────────────────────────

    private async Task SetRenderMode(string mode)
    {
        _renderMode = mode;
        await JS.InvokeVoidAsync("clientSettings.setRenderMode", mode);
        StateHasChanged();
    }

    // ─── State / Lifecycle ──────────────────────────────────────────────

    private void HandleStateChanged(System.Net.WebSockets.WebSocketState state)
    {
        InvokeAsync(async () =>
        {
            // Auto-exit voice mode on WebSocket disconnect to prevent orphaned recording
            if (_isVoiceMode && state != System.Net.WebSockets.WebSocketState.Open)
            {
                try { await ExitVoiceModeAsync(); } catch { }
                _connectionError = "서버 연결이 끊겨 음성 모드가 종료되었습니다.";
            }
            StateHasChanged();
        });
    }

    private async Task ScrollToBottom()
    {
        try { await JS.InvokeVoidAsync("chatScroll.scrollToBottom", "chatMessages"); } catch { }
    }

    private async Task<string> RenderMarkdownAsync(string text)
    {
        try { return await JS.InvokeAsync<string>("chatRenderer.renderMarkdown", text); }
        catch { return text; }
    }

    public async ValueTask DisposeAsync()
    {
        if (_isVoiceMode) { try { await ExitVoiceModeAsync(); } catch { } }
        ChatService.OnMessageReceived -= HandleChunkReceived;
        ChatService.OnStateChanged -= HandleStateChanged;
        if (_renderTimer is not null) await _renderTimer.DisposeAsync();
        if (_staleStreamTimer is not null) await _staleStreamTimer.DisposeAsync();
        _timeoutTimer?.Dispose();
        try { await JS.InvokeVoidAsync("citationInterop.dispose"); } catch { }
        try { await JS.InvokeVoidAsync("audioRecorder.dispose"); } catch { }
        _dotNetRef?.Dispose();
        await ChatService.DisconnectAsync();
    }

    // ─── Models ─────────────────────────────────────────────────────────

    private sealed class ChatMessageViewModel
    {
        public string Text { get; set; } = string.Empty;
        public string? RenderedHtml { get; set; }
        public bool IsUser { get; set; }
        public bool IsStreaming { get; set; }
        public bool IsEditing { get; set; }
        public string EditText { get; set; } = string.Empty;
        public bool CopyFeedback { get; set; }
        public bool FadeIn { get; set; }
        public string? Error { get; set; }
        public List<CitationInfo>? Citations { get; set; }
        public int Feedback { get; set; } // 0=none, 1=positive, -1=negative
        public long LatencyMs { get; set; }
    }

    private sealed class ConversationItem
    {
        public string Id { get; set; } = string.Empty;
        public string Title { get; set; } = "새 대화";
        public List<ChatMessageViewModel> Messages { get; set; } = [];
    }
