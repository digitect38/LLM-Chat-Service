    // ─── Log ↔ Chat Integration ─────────────────────────────────────────

    private static readonly HashSet<string> LogKeywords = new(StringComparer.OrdinalIgnoreCase)
    {
        "로그", "에러", "오류", "경고", "장애", "예외", "스택",
        "log", "error", "warning", "exception", "stacktrace",
        "서비스 상태", "서비스 헬스", "service health",
        "최근 에러", "에러 분석", "로그 분석", "장애 분석"
    };

    private static bool DetectLogIntent(string message)
    {
        return LogKeywords.Any(kw => message.Contains(kw, StringComparison.OrdinalIgnoreCase));
    }

    private string? BuildAutoLogContext(string userMessage)
    {
        if (!DetectLogIntent(userMessage)) return null;

        var sb = new StringBuilder();

        var now = DateTime.Now;
        var recentErrors = LogAnalyzerService.GetTopErrors(now.AddHours(-1), now);
        if (recentErrors.Count > 0)
        {
            sb.AppendLine("## 최근 1시간 Top 에러:");
            foreach (var err in recentErrors.Take(10))
                sb.AppendLine($"- [{err.Count}회] {err.ServiceName}: {err.MessageTemplate}");
        }

        var health = LogAnalyzerService.GetServiceHealth(now.AddHours(-1), now);
        if (health.Count > 0)
        {
            sb.AppendLine("\n## 서비스 헬스:");
            foreach (var svc in health)
                sb.AppendLine($"- {svc.ServiceName}: Total={svc.TotalCount}, ERR={svc.ErrorCount}, WRN={svc.WarningCount}");
        }

        return sb.Length > 0 ? sb.ToString() : null;
    }

    private async Task HandleLogAnalyzeRequest(LogAnalysisRequest request)
    {
        UserMessage = request.UserMessage;
        _pendingLogContext = request.LogContext;
        StateHasChanged();
        await SendMessageAsync();
    }

    // ─── TTS (Text-to-Speech) ───────────────────────────────────────────

    private int _ttsPlayingIdx = -1;
    private bool _ttsLoading;
    private bool _ttsStreamingActive;
    private bool _ttsInitPending;
    private bool _autoTtsEnabled;
    // Voice engine unified: React + TypeScript + XState v5
    private bool _ttsSendConfirmVisible;
    private string? _ttsPendingMessage;

    private async Task PlayLastTts()
    {
        // Find last assistant message
        var lastIdx = -1;
        for (var i = _messages.Count - 1; i >= 0; i--)
        {
            if (!_messages[i].IsUser && !string.IsNullOrWhiteSpace(_messages[i].Text))
            {
                lastIdx = i;
                break;
            }
        }
        if (lastIdx < 0) return;
        await PlayTts(lastIdx);
    }

    private async Task StopTtsFromInput()
    {
        if (_ttsStreamingActive)
        {
            _ttsStreamingActive = false;
            try { await JS.InvokeVoidAsync("fabTts.stop"); } catch { }
        }
        else if (_ttsPlayingIdx >= 0)
        {
            try { await JS.InvokeVoidAsync("fabTts.stop"); } catch { }
        }
        _ttsPlayingIdx = -1;
        _ttsLoading = false;
        StateHasChanged();
    }

    private async Task PlayTts(int idx)
    {
        // Stop streaming TTS if active before manual play
        if (_ttsStreamingActive)
        {
            _ttsStreamingActive = false;
            await JS.InvokeVoidAsync("fabTts.stop");
        }

        // If already playing this message, stop it
        if (_ttsPlayingIdx == idx)
        {
            await JS.InvokeVoidAsync("fabTts.stop");
            _ttsPlayingIdx = -1;
            return;
        }

        var msg = _messages[idx];
        if (string.IsNullOrWhiteSpace(msg.Text)) return;

        _ttsPlayingIdx = idx;
        _ttsLoading = true;
        StateHasChanged();

        try
        {
            // If the message is still streaming, start streaming TTS so sentences
            // play as they arrive instead of waiting for the full response.
            if (msg.IsStreaming)
            {
                await JS.InvokeVoidAsync("fabTts.playStream", _dotNetRef);
                _ttsStreamingActive = true;
                // Feed already-accumulated text so earlier sentences play immediately
                if (!string.IsNullOrEmpty(msg.Text))
                {
                    await JS.InvokeVoidAsync("fabTts.feedText", msg.Text);
                }
            }
            else
            {
                var gatewayBase = Configuration["Gateway:HttpUrl"] ?? "http://localhost:5000";
                // Strip markdown for cleaner TTS input
                var ttsText = System.Text.RegularExpressions.Regex.Replace(
                    msg.Text, @"\*\*|##|#+\s|`[^`]*`|\[([^\]]*)\]\([^\)]*\)", "$1").Trim();
                if (string.IsNullOrWhiteSpace(ttsText)) ttsText = msg.Text;
                await JS.InvokeVoidAsync("fabTts.play", gatewayBase, ttsText, _dotNetRef);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[Error] TTS 오류: {ex.Message}");
            _ttsPlayingIdx = -1;
            _ttsStreamingActive = false;
        }
        finally
        {
            _ttsLoading = false;
            StateHasChanged();
        }
    }

    [JSInvokable]
    public void OnTtsEnded()
    {
        // Idempotent: skip if already handled
        if (_ttsPlayingIdx < 0 && !_ttsStreamingActive && !_ttsLoading) return;

        _ttsPlayingIdx = -1;
        _ttsStreamingActive = false;
        _ttsLoading = false;

        // Machine drives the cycle: TTS_ENDED in responding → ttsDone=true → idle (if screenDone)
        // SYNC mode: reveal all remaining text when TTS ends
        _syncAllRevealed = true;
        InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public void OnTtsSentenceBoundary(int idx, string text, bool isLast)
    {
        // SYNC render mode: reveal one more sentence as TTS plays it
        if (_renderMode != "sync") return;
        _syncRevealedCount = idx + 1;  // idx is 0-based; count = idx + 1
        if (isLast) _syncAllRevealed = true;
        InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public void OnTtsError(string error)
    {
        Console.WriteLine($"[Error] TTS 오류: {error}");
        _ttsPlayingIdx = -1;
        _ttsLoading = false;
        _ttsStreamingActive = false;

        // Machine drives the cycle: TTS_ERROR in responding → ttsDone=true → idle
        InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public void OnBargeIn()
    {
        _ttsPlayingIdx = -1;
        _ttsStreamingActive = false;

        // Machine handles BARGE_IN: stopTts + ttsDone=true → idle (if screenDone)
        // Then idle.autoListenDelay → listening (if voiceMode)
        InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public void OnVoiceCommand(string command)
    {
        if (command == "stop")
        {
            _ttsPlayingIdx = -1;
            _ttsStreamingActive = false;

            // Machine handles VOICE_CMD: → stopping → cleanup → idle
            InvokeAsync(StateHasChanged);
        }
    }

    // ─── Voice Recording (STT) ─────────────────────────────────────────

    private async Task ToggleRecording()
    {
        // If voice conversation is active (autoTts + voiceMode), stop it
        if (_isVoiceMode)
        {
            await ExitVoiceModeAsync();
            return;
        }

        if (_isRecording)
        {
            _isRecording = false;
            _recordingSeconds = 0;
            try
            {
                // For Whisper mode, show transcribing spinner while server processes
                var engine = await JS.InvokeAsync<string>("audioRecorder.getEngine");
                if (engine == "whisper")
                    _isTranscribing = true;
                await JS.InvokeVoidAsync("audioRecorder.stop");
            }
            catch
            {
                _isTranscribing = false;
            }
        }
        else
        {
            // When Auto TTS is on, enter voice conversation mode (auto-send + auto-listen loop)
            if (_autoTtsEnabled)
            {
                try { await JS.InvokeVoidAsync("fabTts.unlockAudio"); } catch { }
                bool micAcquired = false;
                try { micAcquired = await JS.InvokeAsync<bool>("audioRecorder.setVoiceMode", true); }
                catch { micAcquired = false; }

                if (!micAcquired)
                {
                    Console.WriteLine("[Error] 마이크 권한이 거부되었습니다.");
                    StateHasChanged();
                    return;
                }

                _isVoiceMode = true;
                // VOICE_ENTER → machine enters listening state → entry action calls OnMachineStartListening
                try { await JS.InvokeVoidAsync("voiceMachine.send", "VOICE_ENTER"); } catch { }
                StateHasChanged();
                return;
            }

            _interimText = "";
            _recordingSeconds = 0;
            try
            {
                var started = await JS.InvokeAsync<bool>("audioRecorder.start");
                _isRecording = started;
                if (!started) Console.WriteLine("[Error] 마이크 시작에 실패했습니다");
            }
            catch (Exception ex)
            {
                Console.WriteLine($"[Error] 음성 인식 오류: {ex.Message}");
            }
        }
    }

    [JSInvokable]
    public Task OnTranscriptionComplete(string text)
    {
        _isTranscribing = false;
        _isRecording = false;
        _interimText = "";
        _recordingSeconds = 0;

        if (_isVoiceMode)
        {
            // Machine events sent directly from JS callbacks (unified engine)
            StateHasChanged();
            return Task.CompletedTask;
        }

        if (!string.IsNullOrWhiteSpace(text))
            UserMessage = text;
        StateHasChanged();
        return Task.CompletedTask;
    }

    [JSInvokable]
    public Task OnTranscriptionError(string error)
    {
        _isTranscribing = false;
        _isRecording = false;
        _interimText = "";
        _recordingSeconds = 0;

        if (_isVoiceMode)
        {
            // Machine events sent from JS. Only update UI error display for fatal errors.
            var isFatal = error.Contains("연결") || error.Contains("권한") || error.Contains("connect");
            if (isFatal) Console.WriteLine($"[Error] 음성 인식 실패: {error}");
            StateHasChanged();
            return Task.CompletedTask;
        }

        // Log fatal errors (permission, server connection) — suppress transient STT errors
        var showError = error.Contains("권한") || error.Contains("연결") || error.Contains("connect") || error.Contains("Gateway");
        if (showError)
            Console.WriteLine($"[Error] 음성 인식 실패: {error}");
        StateHasChanged();
        return Task.CompletedTask;
    }

    [JSInvokable]
    public Task OnInterimResult(string text, bool isFinal)
    {
        if (isFinal)
        {
            _interimText = "";
            _isRecording = false;
            _recordingSeconds = 0;

            if (_isVoiceMode)
            {
                // React engine handles MIC.FINAL directly from JS callbacks
                StateHasChanged();
                return Task.CompletedTask;
            }

            UserMessage = text;
        }
        else
        {
            _interimText = text;
        }
        StateHasChanged();
        return Task.CompletedTask;
    }

    [JSInvokable]
    public Task OnRecordingTick(int seconds)
    {
        _recordingSeconds = seconds;
        StateHasChanged();
        return Task.CompletedTask;
    }

    // ─── Voice Mode (hands-free loop) ────────────────────────────────────

    private async Task ToggleAutoTts()
    {
        _autoTtsEnabled = !_autoTtsEnabled;
        await JS.InvokeVoidAsync("clientSettings.setAutoTts", _autoTtsEnabled ? "on" : "off");
        // Machine handles unlockAudio, prepareMic/releaseMic via AUTO_TTS_ON/OFF actions
        try { await JS.InvokeVoidAsync("voiceMachine.send", _autoTtsEnabled ? "AUTO_TTS_ON" : "AUTO_TTS_OFF"); } catch { }
        if (!_autoTtsEnabled && _isVoiceMode)
        {
            await ExitVoiceModeAsync();
        }
    }

    private async Task ExitVoiceModeAsync()
    {
        _isVoiceMode = false;
        _voicePhase = VoicePhase.Idle;
        _ttsStreamingActive = false;

        // Notify voice state machine
        try { await JS.InvokeVoidAsync("voiceMachine.send", "VOICE_EXIT"); } catch { }

        // Disable silence auto-stop
        try { await JS.InvokeVoidAsync("audioRecorder.setVoiceMode", false); } catch { }

        // Stop recording if active
        if (_isRecording)
        {
            _isRecording = false;
            _recordingSeconds = 0;
            try { await JS.InvokeVoidAsync("audioRecorder.stop"); } catch { }
        }

        // Stop TTS if playing
        if (_ttsPlayingIdx >= 0)
        {
            try { await JS.InvokeVoidAsync("fabTts.stop"); } catch { }
            _ttsPlayingIdx = -1;
        }

        _isTranscribing = false;
        _ttsLoading = false;
        _interimText = "";
        StateHasChanged();
    }

    private async Task VoiceStartListeningAsync()
    {
        if (!_isVoiceMode) return;

        _voicePhase = VoicePhase.Listening;
        _interimText = "";
        _recordingSeconds = 0;
        StateHasChanged();

        try
        {
            // setVoiceMode(true) already called in ToggleRecording — mic is pre-acquired
            var started = await JS.InvokeAsync<bool>("audioRecorder.start");
            _isRecording = started;
            if (!started)
            {
                await ExitVoiceModeAsync();
                Console.WriteLine("[Error] 마이크 시작 실패");
            }
        }
        catch (Exception ex)
        {
            await ExitVoiceModeAsync();
            Console.WriteLine($"[Error] 마이크 오류: {ex.Message}");
        }
        StateHasChanged();
    }

    private async Task VoiceAutoSendAsync(string text)
    {
        if (!_isVoiceMode || string.IsNullOrWhiteSpace(text)) return;

        _voicePhase = VoicePhase.Waiting;
        StateHasChanged();

        UserMessage = text;
        await SendMessageAsync();
    }

    private async Task VoiceAutoTtsAsync()
    {
        if (!_isVoiceMode) return;

        // Find the last completed assistant message
        var lastIdx = -1;
        for (var i = _messages.Count - 1; i >= 0; i--)
        {
            if (!_messages[i].IsUser && !string.IsNullOrWhiteSpace(_messages[i].Text) && !_messages[i].IsStreaming)
            {
                lastIdx = i;
                break;
            }
        }
        if (lastIdx < 0)
        {
            // No message to speak — machine will complete responding via SCREEN.DONE + ttsDone
            // If TTS not enabled, isResponseComplete guard handles it
            return;
        }

        _voicePhase = VoicePhase.Speaking;
        StateHasChanged();
        await PlayTts(lastIdx);
    }

    // ─── Machine Callbacks (called by JS v2.4 sequential machine) ──────────

    [JSInvokable]
    public Task OnMachineStartListening()
    {
        _voicePhase = VoicePhase.Listening;
        _interimText = "";
        _recordingSeconds = 0;
        _isRecording = true;
        StateHasChanged();
        // React engine: recorder.start() is called directly from JS actions.ts
        // This method is only called for UI state update (fire-and-forget from JS)
        return Task.CompletedTask;
    }

    [JSInvokable]
    public async Task OnMachineSendMessage(string text)
    {
        if (string.IsNullOrWhiteSpace(text))
        {
            try { await JS.InvokeVoidAsync("voiceMachine.send", "LLM.ERROR"); } catch { }
            return;
        }

        _voicePhase = VoicePhase.Waiting;
        StateHasChanged();

        UserMessage = text;
        await SendMessageAsync();

        // If SendMessageAsync hit a guard (_isSending already true, empty message),
        // it returned without starting → signal error to machine.
        if (!_isSending)
        {
            try { await JS.InvokeVoidAsync("voiceMachine.send", "LLM.ERROR"); } catch { }
        }
        // If send started, HandleChunkReceived will emit LLM.STREAMING / SCREEN.DONE / LLM.ERROR
    }

    [JSInvokable]
    public void OnMachineIdle()
    {
        // Machine entered idle state. If voiceMode, autoListenDelay will restart listening.
        // Reset recording UI state to prevent stale "0:00" display
        _isRecording = false;
        _recordingSeconds = 0;
        _isSending = false;  // Hide stop button — response cycle complete
        if (_isVoiceMode)
            _voicePhase = VoicePhase.Idle;
        InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public void OnMachineResponding()
    {
        // Machine entered responding state (LLM streaming started)
        if (_isVoiceMode)
            _voicePhase = VoicePhase.Speaking;
        InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public void OnMachineStopping()
    {
        // Machine entered stopping state (cleanup in progress)
        InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public void OnMachineRecovering(string errorCode, string errorMessage, int retryCount)
    {
        // Machine entered recovering state — show retry status with user-friendly message
        var friendlyMsg = GetFriendlyErrorMessage(errorCode, errorMessage);
        Console.WriteLine($"[Error] ⟳ {friendlyMsg} (재시도 {retryCount}/2)");
        InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public void OnMachineRecoveryFailed(string errorCode, string errorMessage)
    {
        // Recovery failed after max retries — show final error with user-friendly message
        Console.WriteLine("[Error] ✕ 여러 번 시도했지만 실패했어요. 다시 말씀해 주세요.");
        InvokeAsync(StateHasChanged);
    }

    /// <summary>
    /// Map error codes to user-friendly Korean messages (v2.4 §6.3)
    /// </summary>
    private static string GetFriendlyErrorMessage(string errorCode, string fallback)
    {
        return errorCode switch
        {
            "NETWORK_TIMEOUT"    => "연결이 잠시 불안정했어요. 다시 시도할게요.",
            "RATE_LIMIT"         => "잠시 후 다시 시도할게요.",
            "LLM_UNAVAILABLE"    => "서비스가 잠시 응답하지 않아요. 다시 시도할게요.",
            "STREAM_INTERRUPTED" => "응답이 끊겼어요. 다시 시작할게요.",
            "LLM_ERROR"          => "응답 처리 중 오류가 발생했어요. 다시 시도할게요.",
            "LLM_STREAM_ERROR"   => "응답 스트리밍이 중단되었어요. 다시 시도할게요.",
            "TIMEOUT"            => "응답 시간이 초과되었어요. 다시 시도할게요.",
            "INTERNAL_ERROR"     => "죄송해요, 문제가 발생했어요.",
            _                    => string.IsNullOrEmpty(fallback) ? "알 수 없는 오류가 발생했어요." : fallback,
        };
    }

    [JSInvokable]
    public async Task OnMachineExitVoiceMode()
    {
        if (_isVoiceMode)
            await ExitVoiceModeAsync();
    }

    [JSInvokable]
    public async Task OnSendConfirm(bool stopTts, string pendingText)
    {
        // Called from machine's confirmStopAndSend / confirmKeepAndSend actions
        _ttsSendConfirmVisible = false;
        _ttsPendingMessage = null;

        if (string.IsNullOrWhiteSpace(pendingText)) return;

        if (stopTts)
        {
            if (_ttsStreamingActive) { _ttsStreamingActive = false; try { await JS.InvokeVoidAsync("fabTts.stop"); } catch { } }
            else { try { await JS.InvokeVoidAsync("fabTts.stop"); } catch { } }
            _ttsPlayingIdx = -1;
        }
        else
        {
            _autoTtsEnabled = false;
        }

        UserMessage = pendingText;
        StateHasChanged();
        await SendMessageAsync();

        if (!stopTts)
        {
            var saved = await JS.InvokeAsync<string>("clientSettings.getAutoTts");
            _autoTtsEnabled = saved == "on";
        }
    }

    // ─── File Upload ─────────────────────────────────────────────────────

    private async Task TriggerFileUpload()
    {
        try { await JS.InvokeVoidAsync("domHelper.clickElement", "fileUploadInput"); } catch { }
    }

    private async Task HandleFileUpload(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is null) return;

        _isUploading = true;
        StateHasChanged();

        try
        {
            var gatewayBase = Configuration["Gateway:HttpUrl"] ?? "http://localhost:5000";
            using var http = new HttpClient { BaseAddress = new Uri(gatewayBase) };
            using var content = new MultipartFormDataContent();
            using var stream = file.OpenReadStream(maxAllowedSize: 50 * 1024 * 1024);
            var streamContent = new StreamContent(stream);
            content.Add(streamContent, "file", file.Name);

            var response = await http.PostAsync($"/api/upload/{EquipmentId.Trim()}", content);

            if (response.IsSuccessStatusCode)
            {
                _messages.Add(new ChatMessageViewModel
                {
                    Text = $"[파일 업로드 완료: {file.Name} ({file.Size / 1024}KB)]",
                    IsUser = true
                });
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                _messages.Add(new ChatMessageViewModel
                {
                    Text = $"[파일 업로드 실패: {file.Name}]",
                    IsUser = true,
                    Error = error
                });
            }
        }
        catch (Exception ex)
        {
            _messages.Add(new ChatMessageViewModel
            {
                Text = $"[파일 업로드 오류: {file.Name}]",
                IsUser = true,
                Error = ex.Message
            });
        }
        finally
        {
            _isUploading = false;
            StateHasChanged();
            await ScrollToBottom();
        }
    }

    // ─── Streaming handler ──────────────────────────────────────────────

    private void HandleChunkReceived(FabCopilot.Contracts.Messages.ChatStreamChunk chunk)
    {
        if (_isStopping || !_isSending) return;

        InvokeAsync(async () =>
        {
            if (_isStopping || !_isSending) return;

            // Definitive guard: reject chunks from a different conversation.
            if (!string.IsNullOrEmpty(chunk.ConversationId) && chunk.ConversationId != _conversationId)
                return;

            var assistantMsg = _messages.LastOrDefault(m => !m.IsUser && m.IsStreaming);
            if (assistantMsg is null)
            {
                assistantMsg = new ChatMessageViewModel { IsUser = false, IsStreaming = true };
                _messages.Add(assistantMsg);
            }

            // ────────────────────────────────────────────────────────────────
            // CRITICAL: All state mutations happen SYNCHRONOUSLY below.
            // NO await before token append — this guarantees token ordering
            // even when multiple InvokeAsync callbacks interleave at await points.
            // ────────────────────────────────────────────────────────────────

            if (!string.IsNullOrEmpty(chunk.Error))
            {
                assistantMsg.Error = chunk.Error;
                assistantMsg.IsStreaming = false;
                _isSending = false;
                StopRenderTimer();
                StopStaleStreamTimer();
                StopTimeoutTimer();

                // Async work (rendering, TTS cleanup) — safe after state is set
                assistantMsg.RenderedHtml = await RenderMarkdownAsync(assistantMsg.Text);
                if (_isVoiceMode)
                {
                    _ttsStreamingActive = false;
                }
                // Notify machine of LLM error with details (recovering state uses these)
                try {
                    await JS.InvokeVoidAsync("voiceMachine.send",
                        new { type = "LLM.ERROR", @params = new { error = new { code = "LLM_ERROR", message = chunk.Error ?? "LLM 처리 실패" } } });
                } catch { }
                StateHasChanged();
                await ScrollToBottom();
            }
            else if (chunk.IsComplete)
            {
                assistantMsg.IsStreaming = false;
                _isSending = false;
                StopRenderTimer();
                StopStaleStreamTimer();
                StopTimeoutTimer();
                if (_renderMode == "fade")
                    assistantMsg.FadeIn = true;
                // SYNC mode: reveal everything when streaming completes
                _syncAllRevealed = true;

                // Record latency
                if (_latencyStopwatch is not null)
                {
                    _latencyStopwatch.Stop();
                    assistantMsg.LatencyMs = _latencyStopwatch.ElapsedMilliseconds;
                    _latencyStopwatch = null;
                }

                // Store citations
                if (chunk.Citations is { Count: > 0 })
                {
                    assistantMsg.Citations = chunk.Citations;
                    _activeCitations = chunk.Citations;
                    _activePanel = PanelKind.Cite;
                }

                // Integrity check: log accumulated text at completion
                try
                {
                    var preview = assistantMsg.Text.Length > 200
                        ? assistantMsg.Text[..200]
                        : assistantMsg.Text;
                    await JS.InvokeVoidAsync("console.warn",
                        $"[Blazor] COMPLETE chunks={_chunkCounter} len={assistantMsg.Text.Length} text={preview}");
                } catch { }

                // Async work — render final markdown
                assistantMsg.RenderedHtml = await RenderMarkdownAsync(assistantMsg.Text);
                StateHasChanged();
                await ScrollToBottom();

                // Notify machine: screen output complete
                try { await JS.InvokeVoidAsync("voiceMachine.send", "SCREEN.DONE"); } catch { }

                // TTS flush (after UI is updated)
                if (_ttsStreamingActive)
                {
                    try { await JS.InvokeVoidAsync("fabTts.flushStream"); } catch { }
                    // Machine is in responding — TTS_ENDED will set ttsDone, then isResponseComplete → idle
                }
                else if (_isVoiceMode)
                {
                    await VoiceAutoTtsAsync();
                    // VoiceAutoTtsAsync starts PlayTts → OnTtsEnded → machine TTS_ENDED
                }
                else
                {
                    // No TTS active — signal TTS done so machine can transition out of responding
                    try { await JS.InvokeVoidAsync("voiceMachine.send", "TTS_ENDED"); } catch { }
                }
            }
            else
            {
                // ═══ TOKEN APPEND — must be synchronous, no await above ═══
                _chunkCounter++;
                assistantMsg.Text += chunk.Token;

                if (_renderMode != "batch")
                {
                    _renderCounter++;
                    ScheduleRenderUpdate();
                }
                ResetStaleStreamTimer();

                // ═══ ASYNC work below — token is already safely appended ═══

                // Notify machine on first chunk: processing → responding
                if (_chunkCounter == 1)
                {
                    // Reset SYNC mode reveal state for new response
                    _syncRevealedCount = 0;
                    // If TTS won't play, reveal all text immediately (no boundaries to wait for)
                    _syncAllRevealed = !(_isVoiceMode || _autoTtsEnabled);
                    try { await JS.InvokeVoidAsync("voiceMachine.send", "LLM.STREAMING"); } catch { }
                }

                // Start streaming TTS on first token (once per response)
                // _ttsInitPending prevents re-entry: tokens during init are NOT fed
                // individually — they're covered by feedText(assistantMsg.Text) after init.
                if (!_ttsStreamingActive && !_ttsInitPending && (_isVoiceMode || _autoTtsEnabled))
                {
                    _ttsInitPending = true; // synchronous guard before await
                    try
                    {
                        if (_isVoiceMode) _voicePhase = VoicePhase.Speaking;
                        _ttsPlayingIdx = _messages.Count - 1;
                        await JS.InvokeVoidAsync("fabTts.playStream", _dotNetRef);
                        _ttsStreamingActive = true;
                        _ttsInitPending = false;
                        // Feed ALL text accumulated during init
                        await JS.InvokeVoidAsync("fabTts.feedText", assistantMsg.Text);
                    }
                    catch
                    {
                        _ttsStreamingActive = false;
                        _ttsInitPending = false;
                    }
                }
                else if (_ttsStreamingActive)
                {
                    // Normal path: feed individual token
                    try { await JS.InvokeVoidAsync("fabTts.feedText", chunk.Token); } catch { }
                }
                // else: _ttsInitPending — skip feed, will be covered after init
            }
        });
    }

    private void ScheduleRenderUpdate()
    {
        if (_renderPending) return;
        _renderPending = true;
        var interval = _renderMode == "jit" ? 150 : 100;
        _renderTimer ??= new Timer(_ =>
        {
            InvokeAsync(async () =>
            {
                _renderPending = false;
                var msg = _messages.LastOrDefault(m => !m.IsUser && m.IsStreaming);
                if (msg is not null)
                {
                    if (_renderMode == "jit" && !string.IsNullOrEmpty(msg.Text))
                    {
                        try
                        {
                            msg.RenderedHtml = await JS.InvokeAsync<string>(
                                "chatRenderer.renderMarkdownLite", msg.Text);
                        }
                        catch { /* JS interop may fail during dispose */ }
                    }
                    StateHasChanged();
                    await ScrollToBottom();
                }
            });
        }, null, Timeout.Infinite, Timeout.Infinite);
        _renderTimer.Change(interval, Timeout.Infinite);
    }

    private void StopRenderTimer()
    {
        _renderPending = false;
        _renderTimer?.Change(Timeout.Infinite, Timeout.Infinite);
    }

    // ─── Stale Stream Detection ──────────────────────────────────────────

    private void ResetStaleStreamTimer()
    {
        _staleStreamTimer ??= new Timer(_ =>
        {
            InvokeAsync(async () =>
            {
                // No chunk received for StaleStreamTimeoutMs — treat as complete
                var msg = _messages.LastOrDefault(m => !m.IsUser && m.IsStreaming);
                if (msg is null || !_isSending) return;

                msg.IsStreaming = false;
                _isSending = false;
                StopRenderTimer();
                StopTimeoutTimer();
                msg.RenderedHtml = await RenderMarkdownAsync(msg.Text);

                if (_latencyStopwatch is not null)
                {
                    _latencyStopwatch.Stop();
                    msg.LatencyMs = _latencyStopwatch.ElapsedMilliseconds;
                    _latencyStopwatch = null;
                }

                StateHasChanged();
                await ScrollToBottom();
            });
        }, null, Timeout.Infinite, Timeout.Infinite);
        _staleStreamTimer.Change(StaleStreamTimeoutMs, Timeout.Infinite);
    }

    private void StopStaleStreamTimer()
    {
        _staleStreamTimer?.Change(Timeout.Infinite, Timeout.Infinite);
    }

    // ─── Timeout Handling (v3.2 §5.3) ──────────────────────────────────

    private void StartTimeoutTimer()
    {
        _elapsedSeconds = 0;
        _showTimeoutNotification = false;
        _timeoutSeverity = "normal";
        // _timeoutBudgetSeconds is kept from Settings (default 180)
        _currentStage = "검색 중...";
        _timeoutLevel = 0;
        _hasPartialResponse = false;

        _timeoutTimer?.Dispose();
        _timeoutTimer = new Timer(_ =>
        {
            InvokeAsync(() =>
            {
                if (!_isSending) return;

                _elapsedSeconds++;

                // Check if we have partial response content
                var lastMsg = _messages.LastOrDefault(m => !m.IsUser);
                _hasPartialResponse = lastMsg != null && !string.IsNullOrEmpty(lastMsg.Text) && lastMsg.Text.Length > 20;

                // Infer stage from elapsed time
                _currentStage = _elapsedSeconds switch
                {
                    <= 5 => "검색 중...",
                    <= 10 => "문서 분석 중...",
                    <= 30 => "답변 생성 중...",
                    _ => "응답 대기 중..."
                };

                // Progressive notification at 10s/30s/60s/180s
                var newLevel = _elapsedSeconds switch
                {
                    >= 180 => 4,
                    >= 60 => 3,
                    >= 30 => 2,
                    >= 10 => 1,
                    _ => 0
                };

                // Show notification when level changes
                if (newLevel > _timeoutLevel)
                {
                    _timeoutLevel = newLevel;
                    _timeoutNotificationMessage = _timeoutLevel switch
                    {
                        1 => $"응답 생성 중입니다... ({_elapsedSeconds}초 경과)",
                        2 => $"응답 시간이 길어지고 있습니다. ({_elapsedSeconds}초 경과) 복잡한 쿼리일 수 있습니다.",
                        3 => $"예상보다 응답이 지연되고 있습니다. ({_elapsedSeconds}초 경과) 쿼리를 간소화하시겠습니까?",
                        4 => $"응답 시간이 매우 길어지고 있습니다. ({_elapsedSeconds}초 경과) 서버 상태를 확인해 주세요.",
                        _ => ""
                    };

                    if (_timeoutLevel >= 2)
                    {
                        _showTimeoutNotification = true;
                    }
                }
                else if (_showTimeoutNotification)
                {
                    // Update message with current elapsed time
                    _timeoutNotificationMessage = _timeoutLevel switch
                    {
                        2 => $"응답 시간이 길어지고 있습니다. ({_elapsedSeconds}초 경과) 복잡한 쿼리일 수 있습니다.",
                        3 => $"예상보다 응답이 지연되고 있습니다. ({_elapsedSeconds}초 경과) 쿼리를 간소화하시겠습니까?",
                        4 => $"응답 시간이 매우 길어지고 있습니다. ({_elapsedSeconds}초 경과) 서버 상태를 확인해 주세요.",
                        _ => _timeoutNotificationMessage
                    };
                }

                // Severity for progress bar color
                if (_elapsedSeconds >= _timeoutBudgetSeconds * 0.9)
                {
                    if (_timeoutSeverity != "exceeded")
                        FabMetrics.TimeoutOccurrenceCount.Add(1);
                    _timeoutSeverity = "exceeded";
                    _showTimeoutNotification = true;
                }
                else if (_elapsedSeconds >= _timeoutBudgetSeconds * 0.6)
                    _timeoutSeverity = "critical";
                else if (_elapsedSeconds >= 30)
                    _timeoutSeverity = "warning";
                else
                    _timeoutSeverity = "normal";

                StateHasChanged();
            });
        }, null, 1000, 1000);
    }

    private void StopTimeoutTimer()
    {
        _timeoutTimer?.Dispose();
        _timeoutTimer = null;
        _showTimeoutNotification = false;
        _elapsedSeconds = 0;
        _timeoutLevel = 0;
    }

    private void ExtendTimeout()
    {
        FabMetrics.TimeoutExtendCount.Add(1);
        _timeoutBudgetSeconds = Math.Min(_timeoutBudgetSeconds * 2, 600);
        _showTimeoutNotification = false;
        _timeoutSeverity = "warning";
        StateHasChanged();
    }

    private async Task CancelTimeout()
    {
        FabMetrics.TimeoutCancelCount.Add(1);
        _showTimeoutNotification = false;
        StopTimeoutTimer();
        await StopResponseAsync();
    }

    private async Task SimplifyQuery()
    {
        FabMetrics.TimeoutSimplifyCount.Add(1);
        _showTimeoutNotification = false;
        StopTimeoutTimer();

        // Find the last user message
        var lastUserMsg = _messages.LastOrDefault(m => m.IsUser);
        var originalText = lastUserMsg?.Text ?? "";

        await StopResponseAsync();

        if (!string.IsNullOrWhiteSpace(originalText))
        {
            UserMessage = $"간단히 답변해주세요: {originalText}";
            StateHasChanged();
            await SendMessageAsync();
        }
    }

    private async Task ShowPartialAndContinue()
    {
        // Keep the partial response visible, dismiss the notification
        _showTimeoutNotification = false;
        var lastMsg = _messages.LastOrDefault(m => !m.IsUser);
        if (lastMsg != null)
        {
            lastMsg.Text += "\n\n---\n⚠️ *응답이 지연되어 부분 응답을 표시합니다. 응답이 완료되면 자동으로 업데이트됩니다.*";
            lastMsg.RenderedHtml = await RenderMarkdownAsync(lastMsg.Text);
        }
        StateHasChanged();
    }

    // ─── Render Mode ─────────────────────────────────────────────────────

    private async Task SetRenderMode(string mode)
    {
        _renderMode = mode;
        // Reset sync state when switching modes
        if (mode == "sync") { _syncRevealedCount = 0; _syncAllRevealed = false; }
        await JS.InvokeVoidAsync("clientSettings.setRenderMode", mode);
        StateHasChanged();
    }

    // ─── SYNC mode: sentence splitter ─────────────────────────────────────
    // Splits text into (revealed, unrevealed) based on sentence boundary count.
    // Uses same sentence boundary heuristics as TTS pipeline:
    //   period/!/? + space, CJK enders (。！？), paragraph breaks (\n\n)

    private static (string revealed, string unrevealed) SplitTextBySentence(
        string text, int revealedCount, bool allRevealed)
    {
        if (string.IsNullOrEmpty(text) || allRevealed)
            return (text, string.Empty);

        if (revealedCount <= 0)
            return (string.Empty, text);

        // Walk through text counting sentence boundaries
        int boundaries = 0;
        int splitPos = text.Length;

        for (int i = 0; i < text.Length - 1; i++)
        {
            char c = text[i];
            char next = text[i + 1];

            // Sentence enders followed by whitespace: . ! ? 。 ! ？
            if ((c == '.' || c == '!' || c == '?' || c == '\u3002' || c == '\uFF01' || c == '\uFF1F')
                && char.IsWhiteSpace(next))
            {
                boundaries++;
                if (boundaries >= revealedCount)
                {
                    // Include the punctuation, skip to next non-whitespace
                    splitPos = i + 1;
                    while (splitPos < text.Length && char.IsWhiteSpace(text[splitPos]))
                        splitPos++;
                    break;
                }
            }
            // Paragraph break: \n\n
            else if (c == '\n' && next == '\n')
            {
                boundaries++;
                if (boundaries >= revealedCount)
                {
                    splitPos = i;
                    while (splitPos < text.Length && text[splitPos] == '\n')
                        splitPos++;
                    break;
                }
            }
        }

        // Not enough boundaries found → reveal everything
        if (boundaries < revealedCount)
            return (text, string.Empty);

        return (text[..splitPos], splitPos < text.Length ? text[splitPos..] : string.Empty);
    }

    // ─── State / Lifecycle ──────────────────────────────────────────────

    private void HandleStateChanged(System.Net.WebSockets.WebSocketState state)
    {
        InvokeAsync(async () =>
        {
            // Auto-exit voice mode on WebSocket disconnect to prevent orphaned recording
            if (_isVoiceMode && state != System.Net.WebSockets.WebSocketState.Open)
            {
                // Notify machine to exit cleanly
                try { await JS.InvokeVoidAsync("voiceMachine.send", "WS_DISCONNECT"); } catch { }
                try { await ExitVoiceModeAsync(); } catch { }
                try { await JS.InvokeVoidAsync("console.warn", "[Blazor] Voice mode exited: WebSocket disconnected"); } catch { }
            }
            StateHasChanged();
        });
    }

    private async Task ScrollToBottom()
    {
        try { await JS.InvokeVoidAsync("chatScroll.scrollToBottom", "chatMessages"); } catch { }
    }

    private async Task<string> RenderMarkdownAsync(string text)
    {
        try { return await JS.InvokeAsync<string>("chatRenderer.renderMarkdown", text); }
        catch { return text; }
    }

    public async ValueTask DisposeAsync()
    {
        if (_isVoiceMode) { try { await ExitVoiceModeAsync(); } catch { } }
        ChatService.OnMessageReceived -= HandleChunkReceived;
        ChatService.OnStateChanged -= HandleStateChanged;
        if (_renderTimer is not null) await _renderTimer.DisposeAsync();
        if (_staleStreamTimer is not null) await _staleStreamTimer.DisposeAsync();
        _timeoutTimer?.Dispose();
        try { await JS.InvokeVoidAsync("citationInterop.dispose"); } catch { }
        try { await JS.InvokeVoidAsync("logTimestampInterop.dispose"); } catch { }
        try { await JS.InvokeVoidAsync("audioRecorder.dispose"); } catch { }
        _dotNetRef?.Dispose();
        await ChatService.DisconnectAsync();
    }

    // ─── Models ─────────────────────────────────────────────────────────

    private sealed class ChatMessageViewModel
    {
        public string Text { get; set; } = string.Empty;
        public string? RenderedHtml { get; set; }
        public bool IsUser { get; set; }
        public bool IsStreaming { get; set; }
        public bool IsEditing { get; set; }
        public string EditText { get; set; } = string.Empty;
        public bool CopyFeedback { get; set; }
        public bool FadeIn { get; set; }
        public string? Error { get; set; }
        public List<CitationInfo>? Citations { get; set; }
        public int Feedback { get; set; } // 0=none, 1=positive, -1=negative
        public long LatencyMs { get; set; }
    }

    private sealed class ConversationItem
    {
        public string Id { get; set; } = string.Empty;
        public string Title { get; set; } = "새 대화";
        public List<ChatMessageViewModel> Messages { get; set; } = [];
    }
}
